            </template>
          </div>

          <script>
            /* ==========================
               CONFIG
            ========================== */
            const API_CIDADES = "/api/cidades";
            const API_LISTAR_CIDADES = "/api/admin/regioes/imagens";
            const API_SALVAR_CIDADES = "/api/admin/regioes/imagens";
            const API_EXCLUIR_CIDADES = "/api/admin/regioes/imagens";

            /* ==========================
               INIT
            ========================== */
            document.addEventListener("DOMContentLoaded", () => {
              carregarCidades();

              document.getElementById("selectCidade")
                .addEventListener("change", carregarImagensRegiao);
            });

            /* ==========================
               CARREGAR CIDADES
            ========================== */
            async function carregarCidades() {
              try {
                const res = await fetch(API_CIDADES);
                const data = await res.json();

                const select = document.getElementById("selectCidade");
                select.innerHTML = `<option value="">Selecione uma cidade</option>`;

                data.forEach(loc => {
                  const option = document.createElement("option");
                  option.value = loc.nome;
                  option.textContent = `${loc.nome} - ${loc.estado}`;
                  select.appendChild(option);
                });

              } catch (err) {
                console.error("Erro ao carregar cidades:", err);
              }
            }

            /* ==========================
               ADICIONAR ITEM
            ========================== */
            function adicionarImagemRegiao(dados = {}) {
              const template = document.getElementById("templateRegiao");
              const clone = template.content.cloneNode(true);
              const item = clone.querySelector(".slide-item");

              const inputId = item.querySelector(".input-id");
              const inputImagem = item.querySelector(".input-imagem");
              const preview = item.querySelector(".preview");
              const btnRemover = item.querySelector(".btn-remover");

              if (dados.id) inputId.value = dados.id;
              if (dados.imagem) preview.src = dados.imagem;

              /* PREVIEW */
              inputImagem.addEventListener("change", () => {
                const file = inputImagem.files[0];
                if (file) preview.src = URL.createObjectURL(file);
              });

              /* REMOVER */
              btnRemover.addEventListener("click", async () => {
                const id = inputId.value;

                if (!id) {
                  item.remove();
                  verificarEmptyState();
                  return;
                }

                if (!confirm("Deseja excluir esta imagem?")) return;

                try {
                  const res = await fetch(`${API_EXCLUIR_CIDADES}/${id}`, {
                    method: "DELETE"
                  });

                  if (res.ok) {
                    item.remove();
                    verificarEmptyState();
                  } else {
                    alert("Erro ao excluir");
                  }

                } catch (err) {
                  console.error(err);
                }
              });

              document.getElementById("listaRegiao").appendChild(clone);
              verificarEmptyState();
            }

            /* ==========================
               CARREGAR IMAGENS
            ========================== */
            async function carregarImagensRegiao() {
              const cidade = document.getElementById("selectCidade").value;

              const lista = document.getElementById("listaRegiao");
              const empty = document.getElementById("emptyRegiao");

              lista.innerHTML = "";

              if (!cidade) {
                empty.classList.remove("d-none");
                return;
              }

              try {
                const res = await fetch(`${API_LISTAR_CIDADES}?cidade=${encodeURIComponent(cidade)}`);
                const imagens = await res.json();

                if (!imagens.length) {
                  empty.classList.remove("d-none");
                  return;
                }

                empty.classList.add("d-none");

                imagens.forEach(img => {
                  adicionarImagemRegiao({
                    id: img.id,
                    imagem: `/uploads/anuncios/${img.imagem}`
                  });
                });

              } catch (err) {
                console.error("Erro ao carregar imagens:", err);
              }
            }

            /* ==========================
               SALVAR
            ========================== */
            async function salvarImagensRegiao() {
              const cidade = document.getElementById("selectCidade").value;
              const itens = document.querySelectorAll(".slide-item");

              if (!cidade) {
                alert("Selecione uma cidade");
                return;
              }

              if (itens.length === 0) {
                alert("Adicione pelo menos uma imagem");
                return;
              }

              const formData = new FormData();
              formData.append("cidade", cidade);

              itens.forEach(item => {
                const id = item.querySelector(".input-id").value;
                const fileInput = item.querySelector(".input-imagem");
                const file = fileInput.files[0];

                formData.append("ids[]", id || "");
                formData.append("temImagem[]", file ? "true" : "false");

                if (file) formData.append("imagens", file);
              });

              try {
                const res = await fetch(API_SALVAR_CIDADES, {
                  method: "POST",
                  body: formData
                });

                const json = await res.json();

                if (res.ok) {
                  alert("Salvo com sucesso!");
                  carregarImagensRegiao();
                } else {
                  alert(json.message || "Erro ao salvar");
                }

              } catch (err) {
                console.error("Erro ao salvar:", err);
              }
            }

            /* ==========================
               EMPTY STATE
            ========================== */
            function verificarEmptyState() {
              const lista = document.getElementById("listaRegiao");
              const empty = document.getElementById("emptyRegiao");

              if (lista.children.length === 0) {
                empty.classList.remove("d-none");
              } else {
                empty.classList.add("d-none");
              }
            }
          </script>

          <script>
            /* ==========================
               CONFIG
            ========================== */
            const API_CONFIG_LISTAR = "/api/configuracoes-site";
            const API_CONFIG_SALVAR = "/api/admin/configuracoes-site";


            /* ==========================
               ESTADO LOCAL
            ========================== */
            let removerLogo = false;
            let removerFavicon = false;


            /* ==========================
               PREVIEW DE IMAGEM
            ========================== */
            function previewImagem(input, previewId) {
              const file = input.files[0];
              if (!file) return;

              const preview = document.getElementById(previewId);
              preview.src = URL.createObjectURL(file);
            }


            /* ==========================
               MARCAR PARA EXCLUIR
            ========================== */
            function marcarRemocao(tipo) {
              if (tipo === "logo") {
                removerLogo = true;
                document.getElementById("previewLogo").src = "";
                document.getElementById("inputLogo").value = "";
              }

              if (tipo === "favicon") {
                removerFavicon = true;
                document.getElementById("previewFavicon").src = "";
                document.getElementById("inputFavicon").value = "";
              }
            }


            /* ==========================
               CARREGAR CONFIGURAÇÕES
            ========================== */
            async function carregarConfiguracoesSite() {
              try {
                const resposta = await fetch(API_CONFIG_LISTAR);
                const config = await resposta.json();

                if (!config) return;

                if (config.logo) {
                  document.getElementById("previewLogo").src =
                    "/uploads/anuncios/" + config.logo;

                  document.getElementById("logoAtual").value = config.logo;
                }

                if (config.favicon) {
                  document.getElementById("previewFavicon").src =
                    "/uploads/anuncios/" + config.favicon;

                  document.getElementById("faviconAtual").value = config.favicon;
                }

              } catch (erro) {
                console.error("Erro ao carregar configurações:", erro);
              }
            }


            /* ==========================
               SALVAR ALTERAÇÕES
            ========================== */
            async function salvarImagensSiteConfig() {
              const formData = new FormData();

              const fileLogo = document.getElementById("inputLogo").files[0];
              const fileFavicon = document.getElementById("inputFavicon").files[0];

              formData.append("removerLogo", removerLogo);
              formData.append("removerFavicon", removerFavicon);

              if (fileLogo) formData.append("logo", fileLogo);
              if (fileFavicon) formData.append("favicon", fileFavicon);

              try {
                const resposta = await fetch(API_CONFIG_SALVAR, {
                  method: "POST",
                  body: formData
                });

                const json = await resposta.json();

                if (resposta.ok) {
                  alert(json.message || "Configurações salvas!");
                  removerLogo = false;
                  removerFavicon = false;
                  carregarConfiguracoesSite();
                } else {
                  alert(json.message || "Erro ao salvar.");
                }

              } catch (erro) {
                console.error("Erro ao salvar:", erro);
                alert("Erro de conexão com o servidor.");
              }
            }


            /* ==========================
               EVENTOS DOS INPUTS
            ========================== */
            document.getElementById("inputLogo")
              .addEventListener("change", function () {
                removerLogo = false;
                previewImagem(this, "previewLogo");
              });

            document.getElementById("inputFavicon")
              .addEventListener("change", function () {
                removerFavicon = false;
                previewImagem(this, "previewFavicon");
              });

            document.getElementById("btnRemoverLogo")
              .addEventListener("click", () => marcarRemocao("logo"));

            document.getElementById("btnRemoverFavicon")
              .addEventListener("click", () => marcarRemocao("favicon"));


            /* ==========================
               AUTO LOAD
            ========================== */
            document.addEventListener("DOMContentLoaded", () => {
              carregarConfiguracoesSite();
            });
          </script>

          <!-- ============================= -->
          <!-- CARROSSEL HOME (ADMIN) -->
          <!-- ============================= -->

          <div class="card">
            <div class="card-body">

              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Carrossel da Página Home</h5>
                <button class="btn btn-primary" onclick="adicionarSlide()">
                  + Nova imagem
                </button>
              </div>

              <!-- Lista de slides -->
              <div id="listaSlides" class="d-flex flex-column gap-3"></div>

              <!-- Ações globais -->
              <div class="d-grid mt-4">
                <button class="btn btn-primary" onclick="salvarImagensSite()">
                  Salvar alterações
                </button>
              </div>

            </div>
          </div>


          <!-- ============================= -->
          <!-- TEMPLATE DO SLIDE -->
          <!-- ============================= -->
          <template id="templateSlide">

            <div class="card slide-item border">

              <!-- ID do banco -->
              <input type="hidden" class="input-id">

              <div class="card-body">

                <div class="row g-3 align-items-center">

                  <!-- PREVIEW + UPLOAD -->
                  <div class="col-md-3 text-center">
                    <img class="preview img-fluid rounded mb-2 border" style="max-height:120px; object-fit:cover;">
                    <input type="file" class="form-control input-imagem" accept="image/*">
                    <small class="text-muted">Nova imagem (opcional)</small>
                  </div>

                  <!-- DADOS DO SLIDE -->
                  <div class="col-md-7">

                    <input type="text" class="form-control mb-2 input-titulo"
                      placeholder="Título exibido sobre a imagem">

                    <input type="text" class="form-control mb-2 input-descricao" placeholder="Descrição">

                    <input type="text" class="form-control mb-3 input-link" placeholder="Link ao clicar">

                    <div class="d-flex align-items-center gap-4">

                      <div class="form-check">
                        <input class="form-check-input input-ativo" type="checkbox" checked>
                        <label class="form-check-label">
                          Visível no site
                        </label>
                      </div>

                      <div>
                        <label class="form-label mb-0">Ordem</label>
                        <input type="number" class="form-control input-ordem" value="0" style="width:90px;">
                      </div>

                    </div>

                  </div>

                  <!-- AÇÕES -->
                  <div class="col-md-2">

                    <div class="d-grid gap-2">

                      <button type="button" class="btn btn-outline-danger btn-remover">
                        Excluir
                      </button>

                      <small class="text-muted text-center">
                        Marcar para remover
                      </small>

                    </div>

                  </div>

                </div>

              </div>

            </div>

          </template>


        </div>

      </div>

      <div class="painel-content" id="analise">
        <section class="mt-3">
          <div id="cards-anuncios-analise" class="d-flex flex-wrap gap-3">
            <!-- Cards inseridos via JS -->
          </div>
        </section>
      </div>

      <div class="painel-content" id="publicados">
        <section class="mt-3">
          <div id="cards-anuncios-publicados" class="d-flex flex-wrap gap-3">
            <!-- Cards inseridos via JS -->
          </div>
        </section>
      </div>

      <div class="painel-content" id="perfil">
        <div class="container mt-4" style="max-width:500px">

          <h3 class="mb-3">Dados do Administrador</h3>

          <div class="mb-3">
            <label class="form-label">Email</label>
            <input id="adminEmail" type="email" class="form-control">
          </div>

          <div class="mb-3">
            <label class="form-label">Nova senha</label>
            <input id="adminSenha" type="password" class="form-control">
          </div>

          <div class="mb-3">
            <label class="form-label">Confirmar nova senha</label>
            <input id="adminConfirmarSenha" type="password" class="form-control">
          </div>

          <button class="btn btn-danger w-100" onclick="salvarAdmin()">
            Atualizar dados
          </button>

        </div>
        <script>
          async function carregarAdmin() {
            try {
              const res = await fetch('/api/admin/usuario');
              const admin = await res.json();

              document.getElementById("adminEmail").value = admin.email || "";

            } catch (erro) {
              alert("Erro ao carregar dados do admin");
            }
          }

          async function salvarAdmin() {
            const email = document.getElementById("adminEmail").value.trim();
            const senha = document.getElementById("adminSenha").value;
            const confirmar = document.getElementById("adminConfirmarSenha").value;

            if (!email) {
              alert("Informe o email");
              return;
            }

            if (senha && senha !== confirmar) {
              alert("As senhas não coincidem");
              return;
            }

            try {
              const res = await fetch('/api/admin/usuario', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  email,
                  senha // se vazio, backend ignora
                })
              });

              const dados = await res.json();
              alert(dados.message);

              document.getElementById("adminSenha").value = "";
              document.getElementById("adminConfirmarSenha").value = "";

            } catch (erro) {
              alert("Erro ao atualizar dados");
            }
          }

          carregarAdmin();
        </script>
      </div>

    </div>

  </section>

  <script src="./../../js/header-admin.js"></script>

  <%- include('../reutilizavel/js-dependencias-sessao') %>

    <script src="./../../js/admin/gerenciamento-de-usuarios.js"></script>
    <script src="./../../js/admin/anuncios-em-analise.js"></script>
    <script src="./../../js/admin/anuncios-publicados.js"></script>
    <script src="./../../js/admin/adicionar-imagens-carrossel.js" defer></script>
</body>

</html>

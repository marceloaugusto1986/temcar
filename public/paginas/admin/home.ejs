<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Painel do admin</title>

  <script src="./../js/site-config.js" defers></script>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

  <!-- Flatpickr CSS -->
  <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet">
  <link href="https://npmcdn.com/flatpickr/dist/themes/material_blue.css" rel="stylesheet">

  <!-- Select2 — busca nas listas de cidades e bairros -->
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

  <link rel="stylesheet" href="./../../css/dashboard.css">
  <link rel="stylesheet" href="./../../css/mobile.css">
</head>

<style>
  .painel-nav {
    font-size: 0.95rem;
  }

  .painel-link {
    background: transparent;
    border: none;
    padding: 6px 14px;
    font-weight: 600;
    color: #555;
    border-radius: 20px;
    transition: all 0.2s ease;
  }

  .painel-link:hover {
    background: #fdeaea;
    color: #C90B0C;
  }

  .painel-link.active {
    background: #C90B0C;
    color: #fff;
  }

  .painel-content {
    display: none;
    animation: fade 0.3s ease;
  }

  .painel-content.active {
    display: block;
  }

  @keyframes fade {
    from {
      opacity: 0;
      transform: translateY(5px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<style>
  .info-box {
    padding: 0.75rem 1rem;
    border: 1px solid #9fa1a3;
    border-radius: 0.5rem;
    background-color: #fdfdfd;
    height: 100%;
  }

  .form-control {
    border: 1px solid #9fa1a3;
    background-color: #fdfdfd;
  }

  .info-label {
    display: block;
    font-size: 0.75rem;
    color: #6c757d;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
    letter-spacing: 0.03em;
  }

  .info-value {
    font-weight: 500;
    word-break: break-word;
  }
</style>

<style>
  .vehicle-card {
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .vehicle-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.15);
  }
</style>

<!-- Descrição do card do anunciante -->
<style>
  .descricao-card {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<!-- Status do card (análise/ativo) -->
<style>
  .vehicle-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    width: 280px;
  }

  .vehicle-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.15);
  }

  .badge-status {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 10;
  }
</style>

<style>
  .home-carousel-card {
    border-color: #d9dee5;
    border-radius: 8px;
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.05);
  }

  .home-carousel-grid {
    display: grid;
    grid-template-columns: minmax(260px, 330px) minmax(260px, 1fr) 112px;
    gap: 20px;
    align-items: start;
  }

  .home-carousel-media-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .home-carousel-media label,
  .home-carousel-fields label {
    font-weight: 600;
  }

  .home-carousel-media .preview {
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: none !important;
    object-fit: cover;
    background: #f6f7f9;
  }

  .home-carousel-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: stretch;
  }

  .home-carousel-options {
    display: flex;
    gap: 20px;
    align-items: end;
    flex-wrap: wrap;
  }

  @media (max-width: 992px) {
    .home-carousel-grid {
      grid-template-columns: 1fr;
    }

    .home-carousel-actions {
      flex-direction: row;
      align-items: center;
    }
  }

  @media (max-width: 576px) {
    .home-carousel-media-grid {
      grid-template-columns: 1fr;
    }
  }
</style>


<body>
  <section class="container my-5">

    <!-- Header do Painel -->
    <div class="bg-white shadow-sm rounded mb-4">

      <div class="d-flex flex-wrap align-items-center justify-content-between p-3">

        <h4 class="fw-bold m-0" style="color:#C90B0C;">
          Painel do Admin
        </h4>

        <nav class="painel-nav d-flex flex-wrap gap-3 mt-3 mt-md-0">

          <button class="painel-link active" data-target="anunciantes">
            Anunciantes
          </button>

          <button class="painel-link" data-target="seo">
            SEO Avançado
          </button>

          <button class="painel-link" data-target="cidades">
            Cidades
          </button>

          <!-- ✅ NOVA ABA BAIRROS -->
          <button class="painel-link" data-target="bairros">
            Bairros
          </button>

          <button class="painel-link" data-target="banners">
            Banners
          </button>

          <button class="painel-link" data-target="editar-textos">
            Menu de serviços
          </button>

          <button class="painel-link" data-target="editar-imagens">
            Edição de imagens
          </button>

          <button class="painel-link" data-target="analise">
            Em análise
          </button>

          <button class="painel-link" data-target="publicados">
            Publicados
          </button>

          <button class="painel-link" data-target="perfil">
            Perfil
          </button>
          <button class="painel-link" onclick="logout()">
            Sair
          </button>

        </nav>
      </div>

    </div>

    <!-- Conteúdo -->
    <div class="bg-white shadow-sm rounded p-4">

      <div class="painel-content active" id="anunciantes">

        <section class="tabela-usuarios">

          <div class="table-responsive">
            <table class="table align-middle table-borderless admin-table">
              <thead class="text-muted small">
                <tr>
                  <th>Nome</th>
                  <th>E-mail</th>
                  <th>Tipo</th>
                  <th>Cidade</th>
                  <th>WhatsApp</th>
                  <th>Cadastro</th>
                  <th class="text-center">Ações</th>
                </tr>
              </thead>

              <tbody id="usuariosTableBody">
                <!-- Conteúdo dinâmico -->
              </tbody>
            </table>
          </div>

        </section>

        <section class="visualizar-usuario d-none">

          <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="mb-0">Perfil do Usuário</h4>
            <button class="btn btn-sm btn-outline-secondary" onclick="fecharVisualizacao()">
              Voltar
            </button>
          </div>

          <div id="perfilUsuario" class="row g-4"></div>

          <hr class="my-4">

          <section class="mt-4">
            <h4 class="mb-0" style="margin-bottom: 10px !important;">Anúncios</h4>
            <div id="cards-analise" class="d-flex flex-wrap gap-3 pb-2">
              <!-- Cards inseridos via JavaScript -->
            </div>
          </section>

        </section>

      </div>

      <div class="painel-content" id="seo">
        <div class="container mt-4" style="max-width:800px">

          <div class="container mt-4">

            <h3>SEO das Páginas</h3>

            <!-- SELETOR DE PÁGINA -->
            <div class="card mb-4">
              <div class="card-body">

                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label">Selecionar Página</label>
                    <select id="paginaSelecionada" class="form-select">
                      <option value="">Escolher...</option>
                      <option value="home">Home</option>
                      <option value="venda">Venda</option>
                      <option value="buscar_revendas">Buscar Revendas</option>
                      <option value="anunciar">Anunciar</option>
                      <option value="login">Login</option>
                      <option value="cadastro_particular">Cadastro Particular</option>
                      <option value="cadastro_revenda">Cadastro Revenda</option>
                      <option value="criar_conta">Criar Conta</option>
                      <option value="cadastro">Cadastro</option>
                      <option value="revenda">Revenda</option>
                      <option value="particular">Particular</option>
                      <option value="carros">Carros</option>
                      <option value="motos">Motos</option>
                      <option value="utilitarios">Utilitários</option>
                      <option value="comprar">Comprar</option>
                      <option value="vender">Vender</option>
                      <option value="quem_somos">Quem Somos</option>
                      <option value="fale_conosco">Fale Conosco</option>
                      <option value="regras_gerais">Regras Gerais</option>
                      <option value="politica_privacidade">Política de Privacidade</option>
                      <option value="termos_uso">Termos de Uso</option>
                      <option value="pagina_erro">Página de erro</option>
                      <option value="planos">Planos</option>
                      <option value="buscar_cidades">Buscar Cidades</option>
                      <option value="cidade">Cidade</option>
                    </select>
                  </div>
                </div>

              </div>
            </div>


            <!-- FORMULÁRIO -->
            <div class="card mb-4">
              <div class="card-body">

                <form id="formSeo">
                  <input type="hidden" id="seoId">

                  <div class="row g-3">

                    <div class="col-md-8">
                      <label class="form-label">Meta Title</label>
                      <input type="text" id="titulo" class="form-control" required>
                    </div>

                    <div class="col-md-12">
                      <label class="form-label">Meta Description</label>
                      <textarea id="descricao" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="col-md-12">
                      <label class="form-label">Meta Keywords</label>
                      <input type="text" id="keywords" class="form-control">
                    </div>

                    <div class="col-md-6">
                      <label class="form-label">H1 da Página</label>
                      <input type="text" id="texto_h1" class="form-control">
                    </div>

                    <div class="col-md-6">
                      <label class="form-label">Link Canônico</label>
                      <input type="text" id="link_canonico" class="form-control">
                    </div>

                    <div class="col-md-12 d-none">
                      <label class="form-label">Texto SEO</label>
                      <textarea id="texto_conteudo" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="col-md-2 d-flex align-items-end">
                      <div class="form-check">
                        <input type="checkbox" id="ativo" class="form-check-input" checked>
                        <label class="form-check-label">Ativo</label>
                      </div>
                    </div>

                  </div>

                  <div class="mt-3">
                    <button class="btn btn-primary" type="submit">Salvar</button>
                    <button class="btn btn-secondary" type="button" onclick="resetFormSeo()">Cancelar</button>
                  </div>

                  <div class="mt-3 text-muted">
                    Placeholders: #marca, #modelo, #cidade, #estado, #veiculo, #bairro, #revenda
                  </div>

                </form>

              </div>
            </div>


            <!-- TABELA -->
            <div class="card">
              <div class="card-body">

                <table class="table table-striped align-middle">
                  <thead>
                    <tr>
                      <th>Título</th>
                      <th>Status</th>
                      <th style="width:160px">Ações</th>
                    </tr>
                  </thead>
                  <tbody id="tabelaSeo"></tbody>
                </table>

              </div>
            </div>

          </div>

          <script>
            let paginaAtual = null;

            document.getElementById('paginaSelecionada').addEventListener('change', function () {
              paginaAtual = this.value;
              resetFormSeo();
              carregarSeoDaPagina();
            });

            async function carregarSeoDaPagina() {
              if (!paginaAtual) return;
              const res = await fetch(`/api/seo-templates/pagina/${paginaAtual}`);
              const dados = await res.json();
              const tbody = document.getElementById('tabelaSeo');
              tbody.innerHTML = '';
              if (!dados.length) {
                tbody.innerHTML = `<tr><td colspan="3">Nenhum SEO cadastrado</td></tr>`;
                return;
              }
              dados.forEach(item => {
                tbody.innerHTML += `
            <tr>
                <td>${item.titulo}</td>
                <td>${item.ativo ? '<span class="badge bg-success">Ativo</span>' : '<span class="badge bg-secondary">Inativo</span>'}</td>
                <td>
                    <button class="btn btn-sm btn-warning" onclick='editarSeo(${JSON.stringify(item)})'>Editar</button>
                    <button class="btn btn-sm btn-danger" onclick="excluirSeo(${item.id})">Excluir</button>
                </td>
            </tr>`;
              });
            }

            document.getElementById('formSeo').addEventListener('submit', async (e) => {
              e.preventDefault();
              if (!paginaAtual) { alert('Selecione uma página primeiro'); return; }
              const id = document.getElementById('seoId').value;
              const dados = {
                pagina: paginaAtual,
                titulo: document.getElementById('titulo').value,
                descricao: document.getElementById('descricao').value,
                keywords: document.getElementById('keywords').value,
                texto_h1: document.getElementById('texto_h1').value,
                texto_conteudo: document.getElementById('texto_conteudo').value,
                link_canonico: document.getElementById('link_canonico').value,
                ativo: document.getElementById('ativo').checked
              };
              const metodo = id ? 'PUT' : 'POST';
              const url = id ? `/api/seo-templates/${id}` : '/api/seo-templates';
              await fetch(url, { method: metodo, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(dados) });
              resetFormSeo();
              carregarSeoDaPagina();
            });

            function editarSeo(item) {
              document.getElementById('seoId').value = item.id;
              document.getElementById('titulo').value = item.titulo;
              document.getElementById('descricao').value = item.descricao || '';
              document.getElementById('keywords').value = item.keywords || '';
              document.getElementById('texto_h1').value = item.texto_h1 || '';
              document.getElementById('texto_conteudo').value = item.texto_conteudo || '';
              document.getElementById('link_canonico').value = item.link_canonico || '';
              document.getElementById('ativo').checked = item.ativo;
            }

            async function excluirSeo(id) {
              if (!confirm('Excluir SEO desta página?')) return;
              await fetch(`/api/seo-templates/${id}`, { method: 'DELETE' });
              carregarSeoDaPagina();
            }

            function resetFormSeo() {
              document.getElementById('formSeo').reset();
              document.getElementById('seoId').value = '';
            }
          </script>

        </div>

      </div>

      <!-- ============================= -->
      <!-- ABA CIDADES (original)        -->
      <!-- ============================= -->
      <div class="painel-content" id="cidades">
        <section class="container mt-4">

          <div class="d-flex justify-content-between align-items-center mb-3">
            <h3>Cidades</h3>
            <button class="btn btn-primary" id="btn-mostrar-cadastro">
              + Nova Cidade
            </button>
          </div>

          <div class="mb-4">
            <label class="form-label">Selecionar cidade</label>
            <select id="select-cidades" class="form-select s2-cidades" style="width:100%">
              <option value="">Selecione uma cidade</option>
            </select>
          </div>

          <div id="box-editar" class="card p-3 mb-4 d-none">
            <h5>Editar Cidade</h5>
            <form id="form-editar-cidade" enctype="multipart/form-data">
              <input class="form-control mb-2" type="text" name="nome" placeholder="Nome" />
              <input class="form-control mb-2" type="text" name="estado" placeholder="Estado" />
              <div class="row g-3 mb-2">
                <div class="col-md-6">
                  <label class="form-label small text-muted">Imagem desktop</label>
                  <input class="form-control mb-2" type="file" name="imagem" accept="image/*" />
                  <img id="preview-imagem" class="mb-2 border rounded" style="width:180px; display:none;" />
                </div>
                <div class="col-md-6">
                  <label class="form-label small text-muted">Imagem mobile</label>
                  <input class="form-control mb-2" type="file" name="imagem_mobile" accept="image/*" />
                  <img id="preview-imagem-mobile" class="mb-2 border rounded" style="width:120px; display:none;" />
                </div>
              </div>
              <textarea class="form-control mb-2" name="descricao"></textarea>
              <div class="d-flex gap-2">
                <button class="btn btn-success" type="submit">Salvar</button>
                <button class="btn btn-danger" type="button" id="btn-excluir">Excluir</button>
              </div>
            </form>
          </div>

          <div id="box-cadastrar" class="card p-3 d-none">
            <h5>Nova Cidade</h5>
            <form id="form-cadastrar-cidade" enctype="multipart/form-data">
              <input class="form-control mb-2" type="text" name="nome" placeholder="Nome" required />
              <input class="form-control mb-2" type="text" name="estado" placeholder="Estado" required />
              <div class="row g-3 mb-2">
                <div class="col-md-6">
                  <label class="form-label small text-muted">Imagem desktop</label>
                  <input class="form-control" type="file" name="imagem" accept="image/*" />
                </div>
                <div class="col-md-6">
                  <label class="form-label small text-muted">Imagem mobile</label>
                  <input class="form-control" type="file" name="imagem_mobile" accept="image/*" />
                </div>
              </div>
              <textarea class="form-control mb-2" name="descricao"></textarea>
              <button class="btn btn-primary" type="submit">Cadastrar</button>
            </form>
          </div>

        </section>

        <script>
          const select = document.getElementById("select-cidades");
          const boxEditar = document.getElementById("box-editar");
          const boxCadastrar = document.getElementById("box-cadastrar");
          const btnMostrarCadastro = document.getElementById("btn-mostrar-cadastro");
          const formEditar = document.getElementById("form-editar-cidade");
          const formCadastrar = document.getElementById("form-cadastrar-cidade");
          const preview = document.getElementById("preview-imagem");
          const previewMobile = document.getElementById("preview-imagem-mobile");
          const btnExcluir = document.getElementById("btn-excluir");

          let cidadeSelecionada = null;

          function atualizarSelecaoCidade() {
            const selected = select.options[select.selectedIndex];
            if (!selected || !selected.value) { boxEditar.classList.add("d-none"); cidadeSelecionada = null; return; }
            cidadeSelecionada = JSON.parse(selected.dataset.cidade);
            boxEditar.classList.remove("d-none");
            boxCadastrar.classList.add("d-none");
            formEditar.nome.value = cidadeSelecionada.nome;
            formEditar.estado.value = cidadeSelecionada.estado;
            formEditar.descricao.value = cidadeSelecionada.descricao;
            if (cidadeSelecionada.imagem) { preview.src = cidadeSelecionada.imagem; preview.style.display = "block"; }
            else { preview.style.display = "none"; }
            if (cidadeSelecionada.imagem_mobile) { previewMobile.src = cidadeSelecionada.imagem_mobile; previewMobile.style.display = "block"; }
            else { previewMobile.style.display = "none"; }
          }

          async function carregarCidades() {
            const res = await fetch("/api/cidades");
            const cidades = await res.json();
            select.innerHTML = `<option value="">Selecione uma cidade</option>`;
            cidades.forEach(cidade => {
              const option = document.createElement("option");
              option.value = cidade.id;
              option.textContent = `${cidade.nome} - ${cidade.estado}`;
              option.dataset.cidade = JSON.stringify(cidade);
              select.appendChild(option);
            });
          }

          select.addEventListener("change", atualizarSelecaoCidade);

          btnMostrarCadastro.addEventListener("click", () => {
            boxCadastrar.classList.remove("d-none");
            boxEditar.classList.add("d-none");
            select.value = "";
            cidadeSelecionada = null;
          });

          formEditar.imagem.addEventListener("change", () => {
            const file = formEditar.imagem.files[0];
            if (!file) return;
            preview.src = URL.createObjectURL(file);
            preview.style.display = "block";
          });

          formEditar.imagem_mobile.addEventListener("change", () => {
            const file = formEditar.imagem_mobile.files[0];
            if (!file) return;
            previewMobile.src = URL.createObjectURL(file);
            previewMobile.style.display = "block";
          });

          formEditar.addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!cidadeSelecionada) return;
            const formData = new FormData(formEditar);
            await fetch(`/api/cidades/${cidadeSelecionada.id}`, { method: "PUT", body: formData });
            alert("Atualizado!");
            carregarCidades();
          });

          btnExcluir.addEventListener("click", async () => {
            if (!cidadeSelecionada) return;
            if (!confirm("Excluir cidade?")) return;
            await fetch(`/api/cidades/${cidadeSelecionada.id}`, { method: "DELETE" });
            boxEditar.classList.add("d-none");
            cidadeSelecionada = null;
            carregarCidades();
          });

          formCadastrar.addEventListener("submit", async (e) => {
            e.preventDefault();
            const formData = new FormData(formCadastrar);
            await fetch("/api/cidades", { method: "POST", body: formData });
            alert("Cadastrado!");
            formCadastrar.reset();
            boxCadastrar.classList.add("d-none");
            carregarCidades();
          });

          carregarCidades();
        </script>
      </div>

      <!-- ============================= -->
      <!-- ✅ ABA BAIRROS (NOVA)         -->
      <!-- ============================= -->
      <div class="painel-content" id="bairros">
        <section class="container mt-4">

          <!-- TOPO -->
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h3>Bairros</h3>
            <button class="btn btn-primary" id="btn-mostrar-cadastro-bairro">
              + Novo Bairro
            </button>
          </div>

          <!-- SELECT DE CIDADES para filtrar bairros -->
          <div class="mb-3">
            <label class="form-label">Filtrar por cidade</label>
            <select id="select-cidade-filtro-bairro" class="form-select s2-cidade-filtro" style="width:100%">
              <option value="">Todas as cidades</option>
            </select>
          </div>

          <!-- SELECT DE BAIRROS -->
          <div class="mb-4">
            <label class="form-label">Selecionar bairro</label>
            <select id="select-bairros" class="form-select s2-bairro" style="width:100%">
              <option value="">Selecione um bairro</option>
            </select>
          </div>

          <!-- ✏️ EDITAR BAIRRO -->
          <div id="box-editar-bairro" class="card p-3 mb-4 d-none">
            <h5>Editar Bairro</h5>
            <form id="form-editar-bairro">
              <div class="mb-2">
                <label class="form-label">Nome do bairro</label>
                <input class="form-control" type="text" name="nome" placeholder="Nome do bairro" required />
              </div>
              <div class="mb-2">
                <label class="form-label">Cidade (atrelar)</label>
                <select class="form-select s2-cidade-editar" name="cidade_id" id="select-cidade-editar-bairro"
                  style="width:100%" required>
                  <option value="">Selecione uma cidade</option>
                </select>
              </div>
              <div class="mb-2">
                <label class="form-label">URL canônica gerada</label>
                <textarea class="form-control bg-light" id="preview-url-bairro" rows="6" readonly
                  placeholder="Gerada automaticamente"></textarea>
                <small class="text-muted">Formato: /categoria/bairro/cidade/estado</small>
              </div>
              <div class="d-flex gap-2 mt-3">
                <button class="btn btn-success" type="submit">Salvar</button>
                <button class="btn btn-danger" type="button" id="btn-excluir-bairro">Excluir</button>
              </div>
            </form>
          </div>

          <!-- ➕ CADASTRAR BAIRRO -->
          <div id="box-cadastrar-bairro" class="card p-3 d-none">
            <h5>Novo Bairro</h5>
            <form id="form-cadastrar-bairro">
              <div class="mb-2">
                <label class="form-label">Nome do bairro</label>
                <input class="form-control" type="text" name="nome" placeholder="Ex: Centro, Jardim América..."
                  required />
              </div>
              <div class="mb-2">
                <label class="form-label">Atrelar à cidade</label>
                <select class="form-select s2-cidade-novo" name="cidade_id" id="select-cidade-novo-bairro"
                  style="width:100%" required>
                  <option value="">Selecione uma cidade</option>
                </select>
              </div>
              <div class="mb-2">
                <label class="form-label">URL canônica que será gerada</label>
                <textarea class="form-control bg-light" id="preview-url-novo-bairro" rows="5" readonly
                  placeholder="Gerada automaticamente ao escolher cidade e nome"></textarea>
                <small class="text-muted">Formato: /categoria/bairro/cidade/estado</small>
              </div>
              <button class="btn btn-primary mt-2" type="submit">Cadastrar</button>
            </form>
          </div>

        </section>

        <script>
          // ── Estado global da aba Bairros ──
          let bairroSelecionado = null;
          let cidadesCache = [];
          let abaBairrosIniciada = false;

          // ── Helpers ──
          function slugifyBairro(texto) {
            return (texto || "")
              .toLowerCase()
              .normalize("NFD")
              .replace(/[\u0300-\u036f]/g, "")
              .replace(/[^a-z0-9]+/g, "-")
              .replace(/^-+|-+$/g, "");
          }

          function montarUrlBairro(cidade, estado, bairro) {
            if (!cidade || !estado || !bairro) return "";
            const slugCidade = slugifyBairro(cidade);
            const slugEstado = slugifyBairro(estado);
            const slugBairro = slugifyBairro(bairro);
            return [
              `Carros: /carros/${slugBairro}/${slugCidade}/${slugEstado}`,
              `Motos: /motos/${slugBairro}/${slugCidade}/${slugEstado}`,
              `Utilitários: /utilitarios/${slugBairro}/${slugCidade}/${slugEstado}`,
              `Revendas: /buscar-revendas/${slugBairro}/${slugCidade}/${slugEstado}`,
              `Particular: /particular/${slugBairro}/${slugCidade}/${slugEstado}`,
              `Cidade: /cidade/${slugBairro}/${slugCidade}/${slugEstado}`
            ].join("\n");
          }

          // ── Carregar cidades nos selects da aba Bairros ──
          async function carregarCidadesParaBairros() {
            if (cidadesCache.length) return cidadesCache;
            const res = await fetch("/api/cidades");
            cidadesCache = await res.json();
            return cidadesCache;
          }

          function preencherSelectCidades(selectEl, selecionadoId) {
            selectEl.innerHTML = `<option value="">Selecione uma cidade</option>`;
            cidadesCache.forEach(cidade => {
              const opt = document.createElement("option");
              opt.value = cidade.id;
              opt.textContent = `${cidade.nome} - ${cidade.estado}`;
              opt.dataset.nome = cidade.nome;
              opt.dataset.estado = cidade.estado;
              if (selecionadoId && String(cidade.id) === String(selecionadoId)) opt.selected = true;
              selectEl.appendChild(opt);
            });
          }

          // ── Carregar bairros no select principal ──
          async function carregarBairros(filtroNomeCidade) {
            let url = "/api/bairros";
            if (filtroNomeCidade) url += `?cidade=${encodeURIComponent(filtroNomeCidade)}`;
            const res = await fetch(url);
            const bairros = await res.json();

            const selectBairros = document.getElementById("select-bairros");
            selectBairros.innerHTML = `<option value="">Selecione um bairro</option>`;
            bairros.forEach(b => {
              const opt = document.createElement("option");
              opt.value = b.id;
              opt.textContent = `${b.nome} — ${b.cidade_nome} (${b.estado})`;
              opt.dataset.bairro = JSON.stringify(b);
              selectBairros.appendChild(opt);
            });
          }

          // ── Init Select2 (chamado uma vez após DOM estar pronto) ──
          function initSelect2() {
            // Filtro de cidade
            $(".s2-cidade-filtro").select2({
              placeholder: "Todas as cidades",
              allowClear: true,
              language: { noResults: () => "Nenhuma cidade encontrada" }
            }).on("change", function () {
              carregarBairros($(this).val());
              document.getElementById("select-bairros").value = "";
              $(".s2-bairro").val(null).trigger("change");
              document.getElementById("box-editar-bairro").classList.add("d-none");
              bairroSelecionado = null;
            });

            // Select de bairro
            $(".s2-bairro").select2({
              placeholder: "Selecione um bairro",
              allowClear: true,
              language: { noResults: () => "Nenhum bairro encontrado" }
            }).on("change", function () {
              const id = $(this).val();
              if (!id) {
                document.getElementById("box-editar-bairro").classList.add("d-none");
                bairroSelecionado = null;
                return;
              }
              const opt = document.getElementById("select-bairros").options[document.getElementById("select-bairros").selectedIndex];
              if (!opt || !opt.dataset.bairro) return;
              bairroSelecionado = JSON.parse(opt.dataset.bairro);
              document.getElementById("box-editar-bairro").classList.remove("d-none");
              document.getElementById("box-cadastrar-bairro").classList.add("d-none");
              carregarCidadesParaBairros().then(() => {
                preencherSelectCidades(document.getElementById("select-cidade-editar-bairro"), bairroSelecionado.cidade_id);
                reinitS2CidadeEditar();
              });
              document.getElementById("form-editar-bairro").nome.value = bairroSelecionado.nome;
              document.getElementById("preview-url-bairro").value =
                montarUrlBairro(bairroSelecionado.cidade_nome || bairroSelecionado.cidade, bairroSelecionado.estado, bairroSelecionado.nome);
            });

            // Select cidade no painel Cidades
            $(".s2-cidades").select2({
              placeholder: "Selecione uma cidade",
              allowClear: true,
              language: { noResults: () => "Nenhuma cidade encontrada" }
            }).on("change", function () {
              atualizarSelecaoCidade();
            });
          }

          function reinitS2CidadeNovo() {
            $(".s2-cidade-novo").select2({
              placeholder: "Selecione uma cidade",
              allowClear: true,
              language: { noResults: () => "Nenhuma cidade encontrada" }
            }).off("change").on("change", function () {
              const opt = this.options[this.selectedIndex];
              const nome = document.getElementById("form-cadastrar-bairro").nome.value;
              if (opt && opt.dataset.nome) {
                document.getElementById("preview-url-novo-bairro").value =
                  montarUrlBairro(opt.dataset.nome, opt.dataset.estado, nome);
              }
            });
          }

          function reinitS2CidadeEditar() {
            $(".s2-cidade-editar").select2({
              placeholder: "Selecione uma cidade",
              allowClear: true,
              language: { noResults: () => "Nenhuma cidade encontrada" }
            }).off("change").on("change", function () {
              const opt = this.options[this.selectedIndex];
              const nome = document.getElementById("form-editar-bairro").nome.value;
              if (opt && opt.dataset.nome) {
                document.getElementById("preview-url-bairro").value =
                  montarUrlBairro(opt.dataset.nome, opt.dataset.estado, nome);
              }
            });
          }

          // ── Init da aba (roda apenas uma vez) ──
          async function initAbaBairros() {
            if (abaBairrosIniciada) return;
            abaBairrosIniciada = true;
            await carregarCidadesParaBairros();

            // Preenche filtro de cidades
            const selectFiltroCidade = document.getElementById("select-cidade-filtro-bairro");
            selectFiltroCidade.innerHTML = `<option value="">Todas as cidades</option>`;
            cidadesCache.forEach(c => {
              const opt = document.createElement("option");
              opt.value = c.nome;
              opt.textContent = `${c.nome} - ${c.estado}`;
              selectFiltroCidade.appendChild(opt);
            });

            // Re-init Select2 após preencher as opções
            $(".s2-cidade-filtro").val(null).trigger("change.select2");

            await carregarBairros();
          }

          // ── Eventos ──

          // Filtro por cidade
          document.getElementById("select-cidade-filtro-bairro").addEventListener("change", function () {
            carregarBairros(this.value);
            document.getElementById("select-bairros").value = "";
            document.getElementById("box-editar-bairro").classList.add("d-none");
            bairroSelecionado = null;
          });

          // Selecionar bairro para editar
          document.getElementById("select-bairros").addEventListener("change", async function () {
            const selected = this.options[this.selectedIndex];
            if (!selected.value) {
              document.getElementById("box-editar-bairro").classList.add("d-none");
              bairroSelecionado = null;
              return;
            }

            bairroSelecionado = JSON.parse(selected.dataset.bairro);
            document.getElementById("box-editar-bairro").classList.remove("d-none");
            document.getElementById("box-cadastrar-bairro").classList.add("d-none");

            await carregarCidadesParaBairros();
            const selectEditarCidade = document.getElementById("select-cidade-editar-bairro");
            preencherSelectCidades(selectEditarCidade, bairroSelecionado.cidade_id);

            document.getElementById("form-editar-bairro").nome.value = bairroSelecionado.nome;

            // Gera preview da URL
            document.getElementById("preview-url-bairro").value =
              montarUrlBairro(bairroSelecionado.cidade_nome, bairroSelecionado.estado, bairroSelecionado.nome);
          });

          // Botão "+ Novo Bairro"
          // CORREÇÃO: await carregarCidadesParaBairros() ANTES de abrir o form,
          // independente de a aba ter sido clicada antes.
          document.getElementById("btn-mostrar-cadastro-bairro").addEventListener("click", async () => {
            await carregarCidadesParaBairros(); // ← garante que o cache existe

            document.getElementById("box-cadastrar-bairro").classList.remove("d-none");
            document.getElementById("box-editar-bairro").classList.add("d-none");
            document.getElementById("select-bairros").value = "";
            bairroSelecionado = null;

            preencherSelectCidades(document.getElementById("select-cidade-novo-bairro"));
            document.getElementById("form-cadastrar-bairro").reset();
            document.getElementById("preview-url-novo-bairro").value = "";
          });

          // Preview URL ao digitar nome (novo bairro)
          document.getElementById("form-cadastrar-bairro").nome.addEventListener("input", function () {
            const selectCidade = document.getElementById("select-cidade-novo-bairro");
            const opt = selectCidade.options[selectCidade.selectedIndex];
            if (opt && opt.dataset.nome) {
              document.getElementById("preview-url-novo-bairro").value =
                montarUrlBairro(opt.dataset.nome, opt.dataset.estado, this.value);
            }
          });

          document.getElementById("select-cidade-novo-bairro").addEventListener("change", function () {
            const opt = this.options[this.selectedIndex];
            const nome = document.getElementById("form-cadastrar-bairro").nome.value;
            if (opt && opt.dataset.nome) {
              document.getElementById("preview-url-novo-bairro").value =
                montarUrlBairro(opt.dataset.nome, opt.dataset.estado, nome);
            }
          });

          // Preview URL ao editar
          document.getElementById("form-editar-bairro").nome.addEventListener("input", function () {
            const selectCidade = document.getElementById("select-cidade-editar-bairro");
            const opt = selectCidade.options[selectCidade.selectedIndex];
            if (opt && opt.dataset.nome) {
              document.getElementById("preview-url-bairro").value =
                montarUrlBairro(opt.dataset.nome, opt.dataset.estado, this.value);
            }
          });

          document.getElementById("select-cidade-editar-bairro").addEventListener("change", function () {
            const opt = this.options[this.selectedIndex];
            const nome = document.getElementById("form-editar-bairro").nome.value;
            if (opt && opt.dataset.nome) {
              document.getElementById("preview-url-bairro").value =
                montarUrlBairro(opt.dataset.nome, opt.dataset.estado, nome);
            }
          });

          // ✅ CADASTRAR bairro
          document.getElementById("form-cadastrar-bairro").addEventListener("submit", async (e) => {
            e.preventDefault();
            const form = e.target;
            const nome = form.nome.value.trim();
            const selectCidade = document.getElementById("select-cidade-novo-bairro");
            const opt = selectCidade.options[selectCidade.selectedIndex];

            if (!nome) { alert("Informe o nome do bairro."); return; }
            if (!opt || !opt.value) { alert("Selecione uma cidade para atrelar o bairro."); return; }

            const payload = {
              nome,
              cidade: opt.dataset.nome,
              estado: opt.dataset.estado,
              slug: slugifyBairro(nome)
            };

            try {
              const res = await fetch("/api/bairros", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
              });
              const json = await res.json();
              if (res.ok) {
                alert("Bairro cadastrado com sucesso!");
                form.reset();
                document.getElementById("preview-url-novo-bairro").value = "";
                document.getElementById("box-cadastrar-bairro").classList.add("d-none");
                await carregarBairros();
              } else {
                alert("Erro: " + (json.message || "Não foi possível cadastrar."));
              }
            } catch (err) {
              console.error("Erro ao cadastrar bairro:", err);
              alert("Erro de conexão com o servidor.");
            }
          });

          // ✅ EDITAR bairro
          document.getElementById("form-editar-bairro").addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!bairroSelecionado) return;

            const form = e.target;
            const nome = form.nome.value.trim();
            const selectCidade = document.getElementById("select-cidade-editar-bairro");
            const opt = selectCidade.options[selectCidade.selectedIndex];

            if (!nome) { alert("Informe o nome do bairro."); return; }
            if (!opt || !opt.value) { alert("Selecione uma cidade."); return; }

            const payload = {
              nome,
              cidade: opt.dataset.nome,
              estado: opt.dataset.estado,
              slug: slugifyBairro(nome)
            };

            try {
              const res = await fetch(`/api/bairros/${bairroSelecionado.id}`, {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
              });
              const json = await res.json();
              if (res.ok) {
                alert("Bairro atualizado!");
                document.getElementById("box-editar-bairro").classList.add("d-none");
                bairroSelecionado = null;
                await carregarBairros();
              } else {
                alert("Erro: " + (json.message || "Não foi possível atualizar."));
              }
            } catch (err) {
              console.error("Erro ao atualizar bairro:", err);
              alert("Erro de conexão com o servidor.");
            }
          });

          // ✅ EXCLUIR bairro
          document.getElementById("btn-excluir-bairro").addEventListener("click", async () => {
            if (!bairroSelecionado) return;
            if (!confirm(`Excluir o bairro "${bairroSelecionado.nome}"?`)) return;

            try {
              const res = await fetch(`/api/bairros/${bairroSelecionado.id}`, { method: "DELETE" });
              if (res.ok) {
                alert("Bairro excluído!");
                document.getElementById("box-editar-bairro").classList.add("d-none");
                bairroSelecionado = null;
                document.getElementById("select-bairros").value = "";
                await carregarBairros();
              } else {
                alert("Erro ao excluir.");
              }
            } catch (err) {
              console.error("Erro ao excluir bairro:", err);
              alert("Erro de conexão com o servidor.");
            }
          });

          // Inicia a aba quando for clicada
          document.querySelector('[data-target="bairros"]').addEventListener("click", () => {
            initAbaBairros();
          });

          // Inicia Select2 assim que o jQuery estiver pronto
          $(document).ready(function () {
            initSelect2();
          });
        </script>
      </div>

      <!-- BANNERS -->
      <div class="painel-content" id="banners">
        <div class="container mt-4" style="max-width:900px">
          <h3>Gerenciar Banners</h3>

          <div class="card mb-4">
            <div class="card-body">
              <h5 class="card-title">Adicionar Banner</h5>
              <form id="formBanner" enctype="multipart/form-data">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label">Título (opcional)</label>
                    <input type="text" class="form-control" name="titulo" placeholder="Ex: Promoção de Verão">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Link (opcional)</label>
                    <input type="text" class="form-control" name="link" placeholder="https://...">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Imagem *</label>
                    <input type="file" class="form-control" name="imagem" accept="image/*" required>
                  </div>
                  <div class="col-md-3">
                    <label class="form-label">Ordem</label>
                    <input type="number" class="form-control" name="ordem" value="0" min="0">
                  </div>
                  <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-danger w-100">Adicionar</button>
                  </div>
                </div>
              </form>
            </div>
          </div>

          <div class="card">
            <div class="card-body">
              <h5 class="card-title">Banners Cadastrados</h5>
              <div class="table-responsive">
                <table class="table table-striped">
                  <thead>
                    <tr>
                      <th>Imagem</th>
                      <th>Título</th>
                      <th>Link</th>
                      <th>Ordem</th>
                      <th>Ativo</th>
                      <th>Ações</th>
                    </tr>
                  </thead>
                  <tbody id="tabelaBanners"></tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <script>
          async function carregarBannersAdmin() {
            const resp = await fetch('/api/admin/banners');
            const banners = await resp.json();
            const tbody = document.getElementById('tabelaBanners');
            tbody.innerHTML = '';
            if (!banners.length) {
              tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">Nenhum banner cadastrado</td></tr>';
              return;
            }
            banners.forEach(b => {
              tbody.innerHTML += `
      <tr>
        <td><img src="/uploads/banners/${b.imagem}" style="height:60px;border-radius:4px;"></td>
        <td>${b.titulo || '-'}</td>
        <td>${b.link ? '<a href="' + b.link + '" target="_blank">Ver</a>' : '-'}</td>
        <td>${b.ordem}</td>
        <td>
          <button class="btn btn-sm ${b.ativo ? 'btn-success' : 'btn-secondary'}"
            onclick="toggleBanner(${b.id}, ${!b.ativo}, '${b.titulo || ''}', '${b.link || ''}', ${b.ordem})">
            ${b.ativo ? 'Ativo' : 'Inativo'}
          </button>
        </td>
        <td>
          <button class="btn btn-sm btn-danger" onclick="excluirBanner(${b.id})">
            <i class="bi bi-trash"></i>
          </button>
        </td>
      </tr>
    `;
            });
          }

          async function toggleBanner(id, ativo, titulo, link, ordem) {
            await fetch('/api/admin/banners/' + id, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ titulo, link, ordem, ativo })
            });
            carregarBannersAdmin();
          }

          async function excluirBanner(id) {
            if (!confirm('Excluir este banner?')) return;
            await fetch('/api/admin/banners/' + id, { method: 'DELETE' });
            carregarBannersAdmin();
          }

          document.getElementById('formBanner').addEventListener('submit', async function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            const resp = await fetch('/api/admin/banners', { method: 'POST', body: formData });
            if (resp.ok) {
              this.reset();
              carregarBannersAdmin();
              alert('Banner adicionado!');
            } else {
              alert('Erro ao adicionar banner');
            }
          });

          carregarBannersAdmin();
        </script>
      </div>

      <div class="painel-content" id="editar-textos">
        <section class="mt-3">
          <div class="container mt-4">
            <h3>Gerenciar opções do menu Serviços</h3>
            <div class="card mb-4">
              <div class="card-body">
                <form id="formOpcao">
                  <input type="hidden" id="opcaoId">
                  <div class="row g-3">
                    <div class="col-md-4">
                      <label class="form-label">Nome da opção</label>
                      <input type="text" id="nome" class="form-control" required>
                    </div>
                    <div class="col-md-4">
                      <label class="form-label">URL de destino</label>
                      <input type="text" id="url" class="form-control" required>
                    </div>
                    <div class="col-md-2">
                      <label class="form-label">Ordem</label>
                      <input type="number" id="ordem" class="form-control" value="0">
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="ativo" checked>
                        <label class="form-check-label">Ativo</label>
                      </div>
                    </div>
                  </div>
                  <div class="mt-3">
                    <button class="btn btn-primary" type="submit">Salvar</button>
                    <button class="btn btn-secondary" type="button" onclick="resetForm()">Cancelar</button>
                  </div>
                </form>
              </div>
            </div>
            <div class="card">
              <div class="card-body">
                <table class="table table-striped align-middle">
                  <thead>
                    <tr>
                      <th>Ordem</th>
                      <th>Nome</th>
                      <th>URL</th>
                      <th>Status</th>
                      <th style="width:150px">Ações</th>
                    </tr>
                  </thead>
                  <tbody id="tabelaOpcoes"></tbody>
                </table>
              </div>
            </div>
          </div>

          <script>
            async function carregarOpcoes() {
              const res = await fetch('/api/servicos-select');
              const dados = await res.json();
              const tbody = document.getElementById('tabelaOpcoes');
              tbody.innerHTML = '';
              dados.forEach(op => {
                tbody.innerHTML += `
            <tr>
                <td>${op.ordem}</td>
                <td>${op.nome}</td>
                <td>${op.url}</td>
                <td>${op.ativo ? '<span class="badge bg-success">Ativo</span>' : '<span class="badge bg-secondary">Inativo</span>'}</td>
                <td>
                    <button class="btn btn-sm btn-warning" onclick='editarOpcao(${JSON.stringify(op)})'>Editar</button>
                    <button class="btn btn-sm btn-danger" onclick="excluirOpcao(${op.id})">Excluir</button>
                </td>
            </tr>`;
              });
            }

            document.getElementById('formOpcao').addEventListener('submit', async (e) => {
              e.preventDefault();
              const id = document.getElementById('opcaoId').value;
              const dados = {
                nome: document.getElementById('nome').value,
                url: document.getElementById('url').value,
                ordem: document.getElementById('ordem').value,
                ativo: document.getElementById('ativo').checked
              };
              const metodo = id ? 'PUT' : 'POST';
              const endpoint = id ? `/api/servicos-select/${id}` : '/api/servicos-select';
              await fetch(endpoint, { method: metodo, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(dados) });
              resetForm();
              carregarOpcoes();
            });

            function editarOpcao(op) {
              document.getElementById('opcaoId').value = op.id;
              document.getElementById('nome').value = op.nome;
              document.getElementById('url').value = op.url;
              document.getElementById('ordem').value = op.ordem;
              document.getElementById('ativo').checked = op.ativo;
            }

            async function excluirOpcao(id) {
              if (!confirm('Deseja excluir esta opção?')) return;
              await fetch(`/api/servicos-select/${id}`, { method: 'DELETE' });
              carregarOpcoes();
            }

            function resetForm() {
              document.getElementById('formOpcao').reset();
              document.getElementById('opcaoId').value = '';
            }

            carregarOpcoes();
          </script>
        </section>
      </div>

      <div class="painel-content" id="editar-imagens">
        <div class="container mt-4" style="max-width:800px">
          <h3 class="mb-3">Imagens do Site</h3>
          <div class="card" style="padding: 20px;">
            <div class="card mb-4">
              <div class="card-body">
                <h5 class="mb-3">Logo do Header</h5>
                <div class="d-flex align-items-center gap-3 flex-wrap">
                  <div class="text-center">
                    <img id="previewLogo" class="border rounded"
                      style="max-height:80px; min-height:80px; object-fit:contain; padding:6px;">
                  </div>
                  <div class="flex-grow-1">
                    <input type="hidden" id="logoAtual">
                    <input type="file" id="inputLogo" class="form-control mb-2" accept="image/*">
                    <div class="d-flex gap-2">
                      <button class="btn btn-outline-danger" id="btnRemoverLogo" type="button">Remover imagem</button>
                      <small class="text-muted align-self-center">PNG ou JPG recomendado</small>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="card mb-4">
              <div class="card-body">
                <h5 class="mb-3">Ícone da Página (Favicon)</h5>
                <div class="d-flex align-items-center gap-3 flex-wrap">
                  <div class="text-center">
                    <img id="previewFavicon" class="border rounded"
                      style="max-height:50px; min-height:50px; object-fit:contain; padding:6px;">
                  </div>
                  <div class="flex-grow-1">
                    <input type="hidden" id="faviconAtual">
                    <input type="file" id="inputFavicon" class="form-control mb-2" accept="image/*">
                    <div class="d-flex gap-2">
                      <button class="btn btn-outline-danger" id="btnRemoverFavicon" type="button">Remover
                        imagem</button>
                      <small class="text-muted align-self-center">Preferência: PNG 32x32</small>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <button class="btn btn-primary w-100 mt-3" onclick="salvarImagensSiteConfig()">Salvar alterações</button>
          </div>

          <div class="card">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Banners de Cidades</h5>
                <button class="btn btn-primary" onclick="adicionarImagemRegiao()">+ Novo banner</button>
              </div>
              <div class="mb-3">
                <label class="form-label">Selecione a cidade</label>
                <select id="selectCidade" class="form-select">
                  <option value="">Selecione uma cidade</option>
                </select>
              </div>
              <div id="listaRegiao" class="d-flex flex-column gap-3"></div>
              <div id="emptyRegiao" class="text-center text-muted d-none">Nenhum banner cadastrado para esta cidade
              </div>
              <div class="d-grid mt-4">
                <button class="btn btn-primary" onclick="salvarImagensRegiao()">Salvar alterações</button>
              </div>
            </div>

            <template id="templateRegiao">
              <div class="slide-item border p-3 rounded">
                <input type="hidden" class="input-id">
                <div class="row g-3">
                  <div class="col-md-3">
                    <label class="form-label small text-muted">Desktop</label>
                    <img class="preview preview-desktop img-fluid rounded border mb-2"
                      src="/uploads/anuncios/regioes/1774637770227-851750240.png" />
                    <input type="file" class="form-control input-imagem mb-2" accept="image/*">
                  </div>
                  <div class="col-md-3">
                    <label class="form-label small text-muted">Mobile</label>
                    <img class="preview preview-mobile img-fluid rounded border mb-2"
                      src="/uploads/anuncios/regioes/1774637770227-851750240.png" />
                    <input type="file" class="form-control input-imagem-mobile mb-2" accept="image/*">
                  </div>
                  <div class="col-md-6">
                    <input type="url" class="form-control input-link mb-2"
                      placeholder="URL de direcionamento (opcional)">
                    <button type="button" class="btn btn-danger btn-remover">Remover</button>
                  </div>
                </div>
              </div>
            </template>
          </div>

          <script>
            const API_CIDADES = "/api/cidades";
            const API_LISTAR_CIDADES = "/api/admin/regioes/imagens";
            const API_SALVAR_CIDADES = "/api/admin/regioes/imagens";
            const API_EXCLUIR_CIDADES = "/api/admin/regioes/imagens";

            document.addEventListener("DOMContentLoaded", () => {
              carregarCidades();
              document.getElementById("selectCidade").addEventListener("change", carregarImagensRegiao);
            });

            async function carregarCidades() {
              try {
                const res = await fetch(API_CIDADES);
                const data = await res.json();
                const select = document.getElementById("selectCidade");
                select.innerHTML = `<option value="">Selecione uma cidade</option>`;
                data.forEach(loc => {
                  const option = document.createElement("option");
                  option.value = loc.id;
                  option.textContent = `${loc.nome} - ${loc.estado}`;
                  option.dataset.nome = loc.nome;
                  option.dataset.estado = loc.estado;
                  select.appendChild(option);
                });
              } catch (err) { console.error("Erro ao carregar cidades:", err); }
            }

            function adicionarImagemRegiao(dados = {}) {
              const template = document.getElementById("templateRegiao");
              const clone = template.content.cloneNode(true);
              const item = clone.querySelector(".slide-item");
              const inputId = item.querySelector(".input-id");
              const inputImagem = item.querySelector(".input-imagem");
              const inputImagemMobile = item.querySelector(".input-imagem-mobile");
              const inputLink = item.querySelector(".input-link");
              const preview = item.querySelector(".preview-desktop");
              const previewMobile = item.querySelector(".preview-mobile");
              const btnRemover = item.querySelector(".btn-remover");
              if (dados.id) inputId.value = dados.id;
              if (dados.imagem) preview.src = dados.imagem;
              if (dados.imagemMobile) previewMobile.src = dados.imagemMobile;
              else if (dados.imagem) previewMobile.src = dados.imagem;
              if (dados.link) inputLink.value = dados.link;
              inputImagem.addEventListener("change", () => {
                const file = inputImagem.files[0];
                if (file) preview.src = URL.createObjectURL(file);
              });
              inputImagemMobile.addEventListener("change", () => {
                const file = inputImagemMobile.files[0];
                if (file) previewMobile.src = URL.createObjectURL(file);
              });
              btnRemover.addEventListener("click", async () => {
                const id = inputId.value;
                if (!id) { item.remove(); verificarEmptyState(); return; }
                if (!confirm("Deseja excluir esta imagem?")) return;
                try {
                  const res = await fetch(`${API_EXCLUIR_CIDADES}/${id}`, { method: "DELETE" });
                  if (res.ok) { item.remove(); verificarEmptyState(); }
                  else alert("Erro ao excluir");
                } catch (err) { console.error(err); }
              });
              document.getElementById("listaRegiao").appendChild(clone);
              verificarEmptyState();
            }

            async function carregarImagensRegiao() {
              const selectCidade = document.getElementById("selectCidade");
              const cidadeId = selectCidade.value;
              const lista = document.getElementById("listaRegiao");
              const empty = document.getElementById("emptyRegiao");
              lista.innerHTML = "";
              if (!cidadeId) { empty.classList.remove("d-none"); return; }
              try {
                const res = await fetch(`${API_LISTAR_CIDADES}?cidade_id=${encodeURIComponent(cidadeId)}`);
                const imagens = await res.json();
                if (!imagens.length) { empty.classList.remove("d-none"); return; }
                empty.classList.add("d-none");
                imagens.forEach(img => {
                  adicionarImagemRegiao({
                    id: img.id,
                    imagem: `/uploads/anuncios/${img.imagem}`,
                    imagemMobile: img.imagem_mobile ? `/uploads/anuncios/${img.imagem_mobile}` : "",
                    link: img.link || ""
                  });
                });
              } catch (err) { console.error("Erro ao carregar imagens:", err); }
            }

            async function salvarImagensRegiao() {
              const selectCidade = document.getElementById("selectCidade");
              const cidadeId = selectCidade.value;
              const selectedOption = selectCidade.options[selectCidade.selectedIndex];
              const cidade = selectedOption?.dataset?.nome || "";
              const estado = selectedOption?.dataset?.estado || "";
              const itens = document.querySelectorAll(".slide-item");
              if (!cidadeId) { alert("Selecione uma cidade"); return; }
              if (itens.length === 0) { alert("Adicione pelo menos uma imagem"); return; }
              const formData = new FormData();
              formData.append("cidade_id", cidadeId);
              formData.append("cidade", cidade);
              formData.append("estado", estado);
              itens.forEach(item => {
                const id = item.querySelector(".input-id").value;
                const fileInput = item.querySelector(".input-imagem");
                const fileInputMobile = item.querySelector(".input-imagem-mobile");
                const linkInput = item.querySelector(".input-link");
                const file = fileInput.files[0];
                const fileMobile = fileInputMobile.files[0];
                formData.append("ids[]", id || "");
                formData.append("temImagem[]", file ? "true" : "false");
                formData.append("temImagemMobile[]", fileMobile ? "true" : "false");
                formData.append("links[]", linkInput.value.trim());
                if (file) formData.append("imagens", file);
                if (fileMobile) formData.append("imagensMobile", fileMobile);
              });
              try {
                const res = await fetch(API_SALVAR_CIDADES, { method: "POST", body: formData });
                const json = await res.json();
                if (res.ok) { alert("Salvo com sucesso!"); carregarImagensRegiao(); }
                else alert(json.message || "Erro ao salvar");
              } catch (err) { console.error("Erro ao salvar:", err); }
            }

            function verificarEmptyState() {
              const lista = document.getElementById("listaRegiao");
              const empty = document.getElementById("emptyRegiao");
              if (lista.children.length === 0) empty.classList.remove("d-none");
              else empty.classList.add("d-none");
            }
          </script>

          <script>
            const API_CONFIG_LISTAR = "/api/configuracoes-site";
            const API_CONFIG_SALVAR = "/api/admin/configuracoes-site";
            let removerLogo = false;
            let removerFavicon = false;

            function previewImagem(input, previewId) {
              const file = input.files[0];
              if (!file) return;
              document.getElementById(previewId).src = URL.createObjectURL(file);
            }

            function marcarRemocao(tipo) {
              if (tipo === "logo") { removerLogo = true; document.getElementById("previewLogo").src = ""; document.getElementById("inputLogo").value = ""; }
              if (tipo === "favicon") { removerFavicon = true; document.getElementById("previewFavicon").src = ""; document.getElementById("inputFavicon").value = ""; }
            }

            async function carregarConfiguracoesSite() {
              try {
                const resposta = await fetch(API_CONFIG_LISTAR);
                const config = await resposta.json();
                if (!config) return;
                if (config.logo) { document.getElementById("previewLogo").src = "/uploads/anuncios/" + config.logo; document.getElementById("logoAtual").value = config.logo; }
                if (config.favicon) { document.getElementById("previewFavicon").src = "/uploads/anuncios/" + config.favicon; document.getElementById("faviconAtual").value = config.favicon; }
              } catch (erro) { console.error("Erro ao carregar configurações:", erro); }
            }

            async function salvarImagensSiteConfig() {
              const formData = new FormData();
              const fileLogo = document.getElementById("inputLogo").files[0];
              const fileFavicon = document.getElementById("inputFavicon").files[0];
              formData.append("removerLogo", removerLogo);
              formData.append("removerFavicon", removerFavicon);
              if (fileLogo) formData.append("logo", fileLogo);
              if (fileFavicon) formData.append("favicon", fileFavicon);
              try {
                const resposta = await fetch(API_CONFIG_SALVAR, { method: "POST", body: formData });
                const json = await resposta.json();
                if (resposta.ok) { alert(json.message || "Configurações salvas!"); removerLogo = false; removerFavicon = false; carregarConfiguracoesSite(); }
                else alert(json.message || "Erro ao salvar.");
              } catch (erro) { console.error("Erro ao salvar:", erro); alert("Erro de conexão com o servidor."); }
            }

            document.getElementById("inputLogo").addEventListener("change", function () { removerLogo = false; previewImagem(this, "previewLogo"); });
            document.getElementById("inputFavicon").addEventListener("change", function () { removerFavicon = false; previewImagem(this, "previewFavicon"); });
            document.getElementById("btnRemoverLogo").addEventListener("click", () => marcarRemocao("logo"));
            document.getElementById("btnRemoverFavicon").addEventListener("click", () => marcarRemocao("favicon"));
            document.addEventListener("DOMContentLoaded", () => { carregarConfiguracoesSite(); });
          </script>

          <div class="card">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Carrossel da Página Home</h5>
                <button class="btn btn-primary" onclick="adicionarSlide()">+ Nova imagem</button>
              </div>
              <div id="listaSlides" class="d-flex flex-column gap-3"></div>
              <div class="d-grid mt-4">
                <button class="btn btn-primary" onclick="salvarImagensSite()">Salvar alterações</button>
              </div>
            </div>
          </div>

          <template id="templateSlide">
            <div class="card slide-item home-carousel-card border">
              <input type="hidden" class="input-id">
              <div class="card-body">
                <div class="home-carousel-grid">
                  <div class="home-carousel-media-grid">
                    <div class="home-carousel-media">
                      <label class="form-label small text-muted">Desktop</label>
                      <img class="preview preview-desktop img-fluid rounded mb-2 border"
                        style="max-height:120px; object-fit:cover;">
                      <input type="file" class="form-control input-imagem" accept="image/*">
                      <small class="text-muted">Nova imagem desktop</small>
                    </div>
                    <div class="home-carousel-media">
                      <label class="form-label small text-muted">Mobile</label>
                      <img class="preview preview-mobile img-fluid rounded mb-2 border"
                        style="max-height:120px; object-fit:cover;">
                      <input type="file" class="form-control input-imagem-mobile" accept="image/*">
                      <small class="text-muted">Nova imagem mobile</small>
                    </div>
                  </div>
                  <div class="home-carousel-fields">
                    <input type="text" class="form-control mb-2 input-titulo"
                      placeholder="Título exibido sobre a imagem">
                    <input type="text" class="form-control mb-2 input-descricao" placeholder="Descrição">
                    <input type="text" class="form-control mb-3 input-link" placeholder="Link ao clicar">
                    <div class="home-carousel-options">
                      <div class="form-check">
                        <input class="form-check-input input-ativo" type="checkbox" checked>
                        <label class="form-check-label">Visível no site</label>
                      </div>
                      <div>
                        <label class="form-label mb-0">Ordem</label>
                        <input type="number" class="form-control input-ordem" value="0" style="width:90px;">
                      </div>
                    </div>
                  </div>
                  <div class="home-carousel-actions">
                    <button type="button" class="btn btn-outline-danger btn-remover">Excluir</button>
                    <small class="text-muted text-center">Marcar para remover</small>
                  </div>
                </div>
              </div>
            </div>
          </template>

        </div>
      </div>

      <div class="painel-content" id="analise">
        <section class="mt-3">
          <div id="cards-anuncios-analise" class="d-flex flex-wrap gap-3">
            <!-- Cards inseridos via JS -->
          </div>
        </section>
      </div>

      <div class="painel-content" id="publicados">
        <section class="mt-3">
          <div id="cards-anuncios-publicados" class="d-flex flex-wrap gap-3">
            <!-- Cards inseridos via JS -->
          </div>
        </section>
      </div>

      <div class="painel-content" id="perfil">
        <div class="container mt-4" style="max-width:500px">
          <h3 class="mb-3">Dados do Administrador</h3>
          <div class="mb-3">
            <label class="form-label">Email</label>
            <input id="adminEmail" type="email" class="form-control">
          </div>
          <div class="mb-3">
            <label class="form-label">Nova senha</label>
            <input id="adminSenha" type="password" class="form-control">
          </div>
          <div class="mb-3">
            <label class="form-label">Confirmar nova senha</label>
            <input id="adminConfirmarSenha" type="password" class="form-control">
          </div>
          <button class="btn btn-danger w-100" onclick="salvarAdmin()">Atualizar dados</button>
        </div>
        <script>
          async function carregarAdmin() {
            try {
              const res = await fetch('/api/admin/usuario');
              const admin = await res.json();
              document.getElementById("adminEmail").value = admin.email || "";
            } catch (erro) { alert("Erro ao carregar dados do admin"); }
          }

          async function salvarAdmin() {
            const email = document.getElementById("adminEmail").value.trim();
            const senha = document.getElementById("adminSenha").value;
            const confirmar = document.getElementById("adminConfirmarSenha").value;
            if (!email) { alert("Informe o email"); return; }
            if (senha && senha !== confirmar) { alert("As senhas não coincidem"); return; }
            try {
              const res = await fetch('/api/admin/usuario', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, senha })
              });
              const dados = await res.json();
              alert(dados.message);
              document.getElementById("adminSenha").value = "";
              document.getElementById("adminConfirmarSenha").value = "";
            } catch (erro) { alert("Erro ao atualizar dados"); }
          }

          carregarAdmin();
        </script>
      </div>

    </div>

  </section>


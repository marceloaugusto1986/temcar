<form id="formCadastroVeiculo" class="row g-3">

    <!-- TIPO -->
    <div class="col-md-4">
        <label class="form-label">Tipo de Automóvel</label>
        <select class="form-select">
            <option>Carro</option>
            <option>Moto</option>
            <option>Caminhão</option>
            <option>Ônibus</option>
            <option>Van</option>
            <option>Utilitário</option>
            <option>Pickup</option>
            <option>SUV</option>
            <option>Triciclo</option>
            <option>Quadriciclo</option>
            <option>Barco</option>
            <option>Jet Ski</option>
        </select>
    </div>

    <!-- MARCA -->
    <div class="col-md-4">
        <label class="form-label">Marca</label>
        <select class="form-select">
            <option>Chevrolet</option>
            <option>Volkswagen</option>
            <option>Fiat</option>
            <option>Ford</option>
            <option>Honda</option>
            <option>Toyota</option>
            <option>Hyundai</option>
            <option>Renault</option>
            <option>Nissan</option>
            <option>BMW</option>
            <option>Mercedes-Benz</option>
            <option>Audi</option>
            <option>Jeep</option>
            <option>Kia</option>
            <option>Peugeot</option>
            <option>Citroën</option>
        </select>
    </div>

    <!-- VERSÃO -->
    <div class="col-md-4">
        <label class="form-label">Versão / Modelo</label>
        <input type="text" class="form-control" placeholder="Ex: Onix LTZ 1.0 Turbo">
    </div>

    <!-- ANO -->
    <div class="col-md-3">
        <label class="form-label">Ano Fabricação</label>
        <input type="number" class="form-control">
    </div>

    <div class="col-md-3">
        <label class="form-label">Ano Modelo</label>
        <input type="number" class="form-control">
    </div>

    <!-- KM -->
    <div class="col-md-3">
        <label class="form-label">KM</label>
        <input type="number" class="form-control">
    </div>

    <!-- CONDIÇÃO -->
    <div class="col-md-3">
        <label class="form-label">Condição</label>
        <select class="form-select">
            <option>Novo</option>
            <option>Usado</option>
            <option>Seminovo</option>
        </select>
    </div>

    <!-- CÂMBIO -->
    <div class="col-md-4">
        <label class="form-label">Câmbio</label>
        <select class="form-select">
            <option>Manual</option>
            <option>Automático</option>
            <option>Automático CVT</option>
            <option>Automatizado</option>
            <option>Elétrico</option>
        </select>
    </div>

    <!-- MOTORIZAÇÃO -->
    <div class="col-md-4">
        <label class="form-label">Motorização</label>
        <select class="form-select">
            <option>0.8</option>
            <option>1.0</option>
            <option>1.3</option>
            <option>1.4</option>
            <option>1.6</option>
            <option>2.0</option>
            <option>2.5</option>
            <option>3.0</option>
            <option>Elétrico</option>
        </select>
    </div>

    <!-- PORTAS -->
    <div class="col-md-4">
        <label class="form-label">Portas</label>
        <select class="form-select">
            <option>2</option>
            <option>3</option>
            <option>4</option>
            <option>5</option>
        </select>
    </div>

    <!-- CARROCERIA -->
    <div class="col-md-4">
        <label class="form-label">Carroceria</label>
        <select class="form-select">
            <option>Hatch</option>
            <option>Sedan</option>
            <option>SUV</option>
            <option>Coupé</option>
            <option>Conversível</option>
            <option>Pickup</option>
            <option>Perua</option>
            <option>Minivan</option>
        </select>
    </div>

    <!-- COMBUSTÍVEL -->
    <div class="col-md-4">
        <label class="form-label">Combustível</label>
        <select class="form-select">
            <option>Gasolina</option>
            <option>Etanol</option>
            <option>Flex</option>
            <option>Diesel</option>
            <option>Elétrico</option>
            <option>Híbrido</option>
        </select>
    </div>

    <!-- TRAÇÃO -->
    <div class="col-md-4">
        <label class="form-label">Tração</label>
        <select class="form-select">
            <option>Dianteira</option>
            <option>Traseira</option>
            <option>4x4</option>
            <option>AWD</option>
        </select>
    </div>

    <!-- COR -->
    <div class="col-md-4">
        <label class="form-label">Cor</label>
        <select class="form-select">
            <option>Branco</option>
            <option>Preto</option>
            <option>Prata</option>
            <option>Cinza</option>
            <option>Azul</option>
            <option>Vermelho</option>
            <option>Verde</option>
            <option>Marrom</option>
            <option>Bege</option>
        </select>
    </div>

    <!-- ACESSÓRIOS -->
    <div class="col-12">
        <label class="form-label fw-bold">Acessórios</label>
        <div class="row">
            <div class="col-md-3"><input type="checkbox"> Ar-condicionado</div>
            <div class="col-md-3"><input type="checkbox"> Direção elétrica</div>
            <div class="col-md-3"><input type="checkbox"> Airbag</div>
            <div class="col-md-3"><input type="checkbox"> ABS</div>
            <div class="col-md-3"><input type="checkbox"> Multimídia</div>
            <div class="col-md-3"><input type="checkbox"> Câmera de ré</div>
            <div class="col-md-3"><input type="checkbox"> Sensor de estacionamento</div>
            <div class="col-md-3"><input type="checkbox"> Controle de tração</div>
            <div class="col-md-3"><input type="checkbox"> Bancos em couro</div>
            <div class="col-md-3"><input type="checkbox"> Teto solar</div>
        </div>
    </div>

    <div class="col-12">
        <label class="form-label">Imagens do veículo (máx. 10)</label>
        <input type="file" class="form-control" id="imagens" accept="image/*" multiple>
        <small class="text-muted">
            Você pode adicionar imagens uma por vez ou várias de uma vez.
        </small>
    </div>

    <div class="col-12 mt-3">
        <div id="previewImagens" class="d-flex flex-wrap gap-3"></div>
    </div>

    <!-- PREÇO -->
    <div class="col-md-4">
        <label class="form-label">Preço (R$)</label>
        <input type="number" class="form-control" id="preco" min="0" step="0.01" placeholder="Ex: 75000" required>
    </div>

    <!-- DESCRIÇÃO -->
    <div class="col-12">
        <label class="form-label">Descrição</label>
        <textarea class="form-control" id="descricao" rows="4"
            placeholder="Descreva o estado do veículo, histórico, diferenciais..." required></textarea>
    </div>

    <!-- BOTÃO FINAL -->
    <div class="col-12 text-center mt-4">
        <button type="button" class="btn btn-primary btn-lg px-5" style="background: #C90B0C; color: #fff; border: 1px solid red;">
            Salvar Veículo
        </button>
    </div>

</form>
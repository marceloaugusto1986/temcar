      const groupCpf = document.getElementById('groupCpf');

      /* =========================
         CONTROLE POR TIPO
      ========================== */
      if (isRevenda) {
        // REVenda: CNPJ + Telefone, sem CPF
        groupCpf.style.display = 'none';

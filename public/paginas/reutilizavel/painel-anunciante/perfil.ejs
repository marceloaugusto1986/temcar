<!-- Logo da Revenda -->
<div id="logo-container" style="text-align:center; padding: 10px;"></div>
<div id="perfilUsuario" class="row g-4"></div>
<div id="editarUser" class="row g-4 d-none"></div>



<script>
/* RECUPERAR ID DA SESSÃO */
async function recuperarSessao() {
  const response = await fetch('/api/get/usuario/sessao', {
    credentials: 'include'
  });

  if (!response.ok) throw new Error('Usuário não autenticado');
  const usuario = await response.json();
  return usuario.id;
}

/* FUNÇÃO PARA RENDERIZAR O BLOCO DE LOGO */
async function renderizarLogo() {
  try {
    const infoIDsessao = await recuperarSessao();

    // Buscar perfil do usuário
    const perfilRes = await fetch(`/api/perfil-anunciante/${infoIDsessao}`, {
      credentials: 'include'
    });
    if (!perfilRes.ok) throw new Error('Erro ao buscar perfil');
    const { usuario } = await perfilRes.json();

    // Mostrar apenas se for revenda
    if (usuario.tipo !== 'revenda') return;

    // Buscar logo
    let logoAtual = null;
    try {
      const logoRes = await fetch(`/api/revenda/logo/${infoIDsessao}`, {
        credentials: 'include'
      });
      if (logoRes.ok) {
        const data = await logoRes.json();
        logoAtual = data.logo || null;
      }
    } catch {
      console.warn('Não foi possível buscar logo.');
    }

    const previewLogo = logoAtual
      ? `<img id="logoRevendaImg" src="${logoAtual}" alt="Logo Revenda"
               style="max-height:150px; max-width:150px; object-fit:contain; border:1px solid #ccc; border-radius:8px;">`
      : `<div id="logoRevendaImg" class="text-muted small border rounded-3 d-flex align-items-center justify-content-center"
               style="height:120px; width:150px;">Sem logo</div>`;

    // Renderiza HTML
    document.getElementById('logo-container').innerHTML = `
      <div class="border rounded-3 p-4 bg-white shadow-sm" style="display:inline-block;">
        <h6 class="text-uppercase text-muted mb-3">Logo da Revenda</h6>
        <div class="d-flex flex-column align-items-center gap-2">
          ${previewLogo}
          <input type="file" id="logoRevendaInput" accept="image/*">
          <div>
            <button class="btn btn-success btn-sm" id="btnCreateUpdateLogo">Salvar/Atualizar</button>
            <button class="btn btn-danger btn-sm" id="btnDeleteLogo">Excluir</button>
          </div>
          <div id="feedbackLogo" class="small mt-1"></div>
        </div>
      </div>
    `;

    // Eventos
    document.getElementById('btnCreateUpdateLogo')
            .addEventListener('click', () => salvarOuAtualizarLogo(infoIDsessao));
    document.getElementById('btnDeleteLogo')
            .addEventListener('click', () => excluirLogo(infoIDsessao));

  } catch (error) {
    console.error(error);
    document.getElementById('logo-container').innerHTML = `
      <div class="alert alert-danger">Não foi possível carregar a logo da revenda.</div>
    `;
  }
}

/* FUNÇÃO PARA SALVAR OU ATUALIZAR LOGO */
async function salvarOuAtualizarLogo(usuarioId) {
  const input = document.getElementById('logoRevendaInput');
  const feedback = document.getElementById('feedbackLogo');
  feedback.textContent = '';

  if (!input.files || input.files.length === 0) {
    feedback.textContent = 'Selecione uma imagem.';
    feedback.className = 'text-danger small mt-1';
    return;
  }

  const file = input.files[0];
  const formData = new FormData();
  formData.append('logo', file);

  try {
    // Tenta PUT (atualizar), se não existir faz POST
    let response = await fetch(`/api/revenda/logo/${usuarioId}`, {
      method: 'PUT',
      credentials: 'include',
      body: formData
    });

    // Se não existir no banco ainda, criar
    if (response.status === 400) {
      response = await fetch(`/api/revenda/logo/${usuarioId}`, {
        method: 'POST',
        credentials: 'include',
        body: formData
      });
    }

    const data = await response.json();

    if (!response.ok) {
      feedback.textContent = data.error || 'Erro ao salvar logo.';
      feedback.className = 'text-danger small mt-1';
      return;
    }

    const preview = document.getElementById('logoRevendaImg');
    if (preview?.tagName === 'IMG') {
      preview.src = data.logo;
    } else if (preview) {
      preview.outerHTML = `<img id="logoRevendaImg" src="${data.logo}" alt="Logo Revenda"
        style="max-height:150px; max-width:150px; object-fit:contain; border:1px solid #ccc; border-radius:8px;">`;
    }
    feedback.textContent = 'Logo salva/atualizada com sucesso!';
    feedback.className = 'text-success small mt-1';
    input.value = '';
  } catch (error) {
    console.error(error);
    feedback.textContent = 'Erro de comunicação com o servidor.';
    feedback.className = 'text-danger small mt-1';
  }
}

/* FUNÇÃO PARA EXCLUIR LOGO */
async function excluirLogo(usuarioId) {
  const feedback = document.getElementById('feedbackLogo');
  feedback.textContent = '';

  if (!confirm('Deseja realmente excluir a logo da revenda?')) return;

  try {
    const response = await fetch(`/api/revenda/logo/${usuarioId}`, {
      method: 'DELETE',
      credentials: 'include'
    });
    const data = await response.json();

    if (!response.ok) {
      feedback.textContent = data.error || 'Erro ao excluir logo.';
      feedback.className = 'text-danger small mt-1';
      return;
    }

    const preview = document.getElementById('logoRevendaImg');
    if (preview) {
      preview.outerHTML = `<div id="logoRevendaImg" class="text-muted small border rounded-3 d-flex align-items-center justify-content-center"
        style="height:120px; width:150px;">Sem logo</div>`;
    }
    feedback.textContent = 'Logo excluída com sucesso!';
    feedback.className = 'text-success small mt-1';
  } catch (error) {
    console.error(error);
    feedback.textContent = 'Erro de comunicação com o servidor.';
    feedback.className = 'text-danger small mt-1';
  }
}

// Inicializa
renderizarLogo();
</script>

<script>

  /* RECUPERAR ID DA SESSÃO */
  async function recuperarSessao() {
    const response = await fetch('/api/get/usuario/sessao', {
      credentials: 'include'
    });

    if (!response.ok) {
      throw new Error('Usuário não autenticado');
    }

    const usuario = await response.json();

    return usuario.id;
  }

  function obterCidadesAtendimentoPerfil(usuario) {
    if (!usuario || !usuario.cidades_atendimento) return [];
    if (Array.isArray(usuario.cidades_atendimento)) return usuario.cidades_atendimento;

    try {
      return JSON.parse(usuario.cidades_atendimento) || [];
    } catch (error) {
      return [];
    }
  }

  function renderizarPillsCidades(cidades) {
    if (!cidades || !cidades.length) return '<span class="text-muted">Nenhuma cidade adicional cadastrada.</span>';

    return cidades
      .map(cidade => `<span class="cidade-atendimento-pill">${formatarLocalAtendimento(cidade)}</span>`)
      .join('');
  }

  function formatarLocalAtendimento(cidade) {
    const nomeCidade = cidade.cidade || cidade.nome || '';
    const estado = cidade.estado || '';
    return cidade.bairro
      ? `${cidade.bairro}, ${nomeCidade} - ${estado}`
      : `${nomeCidade} - ${estado}`;
  }

  /* PREENCHER IFORMAÇÕES DO USUÁRIO */
  (async () => {
  try {
    const infoIDsessao = await recuperarSessao();

    const response = await fetch(
      `/api/perfil-anunciante/${infoIDsessao}`,
      { credentials: 'include' }
    );

    if (!response.ok) {
      throw new Error('Usuário não autenticado');
    }

    const { usuario } = await response.json();
    const isRevenda = usuario.tipo === 'revenda';

    const perfil = document.getElementById('perfilUsuario');

    perfil.innerHTML = `
      <div class="row g-4">

        <!-- 🔹 DADOS BÁSICOS -->
        <div class="col-12">
          <div class="border rounded-3 p-4 bg-white shadow-sm">
            <h6 class="text-uppercase text-muted mb-3">Informações Básicas</h6>

            <div class="col-sm-12 col-md-4 mb-3">
              <button class="btn btn-warning" onclick="editarPerfil()">
                <i class="bi bi-pencil-square"></i> Editar
              </button>
            </div>

            <div class="row g-3">
              <div class="col-sm-6">
                <div class="info-box">
                  <span class="info-label">Nome</span>
                  <div class="info-value">${usuario.nome ?? '-'}</div>
                </div>
              </div>

              <div class="col-sm-4">
                <div class="info-box">
                  <span class="info-label">Tipo</span>
                  <div class="info-value">${usuario.tipo ?? '-'}</div>
                </div>
              </div>

              ${
                isRevenda
                  ? `
                    <div class="col-sm-4">
                      <div class="info-box">
                        <span class="info-label">CNPJ</span>
                        <div class="info-value">${usuario.cnpj ?? '-'}</div>
                      </div>
                    </div>
                  `
                  : `
                    <div class="col-sm-4">
                      <div class="info-box">
                        <span class="info-label">CPF</span>
                        <div class="info-value">${usuario.cpf ?? '-'}</div>
                      </div>
                    </div>
                  `
              }

              <div class="col-sm-4">
                <div class="info-box">
                  <span class="info-label">Plano</span>
                  <div class="info-value">${usuario.plano_desejado ?? '-'}</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 🔹 CONTATO -->
        <div class="col-12">
          <div class="border rounded-3 p-4 bg-white shadow-sm">
            <h6 class="text-uppercase text-muted mb-3">Contato</h6>

            <div class="row g-3">
              <div class="col-sm-6 col-md-4">
                <div class="info-box">
                  <span class="info-label">WhatsApp</span>
                  <div class="info-value">${usuario.whatsapp || '-'}</div>
                </div>
              </div>

              ${
                isRevenda
                  ? `
                    <div class="col-sm-6 col-md-4">
                      <div class="info-box">
                        <span class="info-label">Telefone</span>
                        <div class="info-value">${usuario.telefone ?? '-'}</div>
                      </div>
                    </div>
                  `
                  : ''
              }

              <div class="col-sm-6 col-md-4">
                <div class="info-box">
                  <span class="info-label">E-mail</span>
                  <div class="info-value">${usuario.email ?? '-'}</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 🔹 ENDEREÇO -->
        <div class="col-12">
          <div class="border rounded-3 p-4 bg-white shadow-sm">
            <h6 class="text-uppercase text-muted mb-3">Endereço</h6>

            <div class="row g-3">
              <div class="col-6 col-md-3">
                <div class="info-box">
                  <span class="info-label">CEP</span>
                  <div class="info-value">${usuario.cep || '-'}</div>
                </div>
              </div>

              <div class="col-12 col-md-5">
                <div class="info-box">
                  <span class="info-label">Rua</span>
                  <div class="info-value">${usuario.rua || '-'}</div>
                </div>
              </div>

              <div class="col-6 col-md-2">
                <div class="info-box">
                  <span class="info-label">Nº</span>
                  <div class="info-value">${usuario.numero || '-'}</div>
                </div>
              </div>

              <div class="col-sm-6 col-md-4">
                <div class="info-box">
                  <span class="info-label">Bairro</span>
                  <div class="info-value">${usuario.bairro || '-'}</div>
                </div>
              </div>

              <div class="col-sm-6 col-md-4">
                <div class="info-box">
                  <span class="info-label">Cidade</span>
                  <div class="info-value">${usuario.cidade || '-'}</div>
                </div>
              </div>

              <div class="col-6 col-md-2">
                <div class="info-box">
                  <span class="info-label">Estado</span>
                  <div class="info-value">${usuario.estado || '-'}</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 🔹 CIDADES DE ATUAÇÃO -->
        <div class="col-12">
          <div class="border rounded-3 p-4 bg-white shadow-sm">
            <h6 class="text-uppercase text-muted mb-3">Cidades onde seus anúncios são encontrados</h6>
            <div class="cidade-atendimento-lista">
              ${renderizarPillsCidades(obterCidadesAtendimentoPerfil(usuario))}
            </div>
          </div>
        </div>

        <!-- 🔹 SEGURANÇA -->
        <div class="col-12">
          <div class="border rounded-3 p-4 bg-white shadow-sm">
            <h6 class="text-uppercase text-muted mb-3">Segurança</h6>

            <div class="row g-3 align-items-end">
              <div class="col-sm-12 col-md-4">
                <label class="form-label small text-muted">Nova senha</label>
                <input type="password" id="novaSenha" class="form-control">
              </div>

              <div class="col-sm-12 col-md-4">
                <button class="btn btn-warning w-100" onclick="alterarSenha()">
                  Alterar senha
                </button>
              </div>

              <div class="col-sm-12 col-md-4">
                <div id="senhaFeedback" class="small"></div>
              </div>
            </div>
          </div>
        </div>

      </div>
    `;
  } catch (error) {
    console.error(error);
    document.getElementById('perfilUsuario').innerHTML = `
      <div class="alert alert-danger">
        Você precisa estar logado para acessar este perfil.
      </div>
    `;
  }
})();

  /* ALTERAR SENHA DO USUÁRIO */
  async function alterarSenha() {
    const novaSenha = document.getElementById('novaSenha').value;
    const feedback = document.getElementById('senhaFeedback');

    feedback.textContent = '';

    if (!novaSenha || novaSenha.length < 6) {
      feedback.textContent = 'A senha deve ter pelo menos 6 caracteres.';
      feedback.className = 'text-danger';
      return;
    }

    try {
      const infoIDsessao = await recuperarSessao();
      const response = await fetch(
        `/api/alterar-senha-anunciante/${infoIDsessao}/senha`,
        {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ novaSenha })
        }
      );

      const data = await response.json();

      if (!response.ok) {
        feedback.textContent = data.message || 'Erro ao alterar senha.';
        feedback.className = 'text-danger';
        return;
      }

      feedback.textContent = 'Senha alterada com sucesso.';
      feedback.className = 'text-success';
      document.getElementById('novaSenha').value = '';

    } catch (err) {
      console.error(err);
      feedback.textContent = 'Erro de comunicação com o servidor.';
      feedback.className = 'text-danger';
    }
  }

  /* ABRIR FORM DE EDIÇÃO */
  function abrirFormDeEdicao() {
    document.querySelector('#perfilUsuario').classList.add('d-none');
    document.querySelector('#editarUser').classList.remove('d-none');
  }

  /* FECHAR FORM DE EDIÇÃO */
  function fecharFormDeEdicao() {
    document.querySelector('#editarUser').classList.add('d-none');
    document.querySelector('#perfilUsuario').classList.remove('d-none');
  }

  /* PREENCHER E EDITAR INFORMAÇÕES DO USUÁRIO */
  async function editarPerfil() {
    abrirFormDeEdicao();

    try {
      const infoIDsessao = await recuperarSessao();

      /* =========================
         GET – BUSCAR DADOS DO PERFIL
      ========================== */
      const response = await fetch(
        `/api/perfil-anunciante/${infoIDsessao}`,
        { credentials: 'include' }
      );

      if (!response.ok) {
        throw new Error('Usuário não autenticado');
      }

      const { usuario } = await response.json();
      const isRevenda = usuario.tipo === 'revenda';

      const containerEditarUsuario = document.getElementById('editarUser');

      /* =========================
         RENDERIZA O FORM
      ========================== */
      containerEditarUsuario.innerHTML = `
      <div class="border rounded-3 p-4 bg-white shadow-sm">
        <h6 class="text-uppercase text-muted mb-3">Editar Perfil</h6>

        <form id="formEditarPerfil" class="row g-3">

          <div class="col-md-6">
            <label class="form-label">Nome</label>
            <input type="text" id="editNome" class="form-control">
          </div>

          <div class="col-md-6" id="groupCpf">
            <label class="form-label">CPF</label>
            <input type="text" id="editCpf" class="form-control">
          </div>


          <div class="col-md-6" id="groupCnpj">
            <label class="form-label">CNPJ</label>
            <input type="text" id="editCnpj" class="form-control">
          </div>

          <div class="col-md-6">
            <label class="form-label">WhatsApp</label>
            <input type="text" id="editWhatsapp" class="form-control">
          </div>

          <div class="col-md-6" id="groupTelefone">
            <label class="form-label">Telefone</label>
            <input type="text" id="editTelefone" class="form-control">
          </div>

          <div class="col-md-6">
            <label class="form-label">E-mail</label>
            <input type="email" id="editEmail" class="form-control">
          </div>

          <div class="col-md-4">
            <label class="form-label">CEP</label>
            <input type="text" id="editCep" class="form-control">
          </div>

          <div class="col-md-6">
            <label class="form-label">Rua</label>
            <input type="text" id="editRua" class="form-control">
          </div>

          <div class="col-md-2">
            <label class="form-label">Número</label>
            <input type="text" id="editNumero" class="form-control">
          </div>

          <div class="col-md-4">
            <label class="form-label">Bairro</label>
            <input type="text" id="editBairro" class="form-control">
          </div>

          <div class="col-md-4">
            <label class="form-label">Cidade</label>
            <input type="text" id="editCidade" class="form-control">
          </div>

          <div class="col-md-2">
            <label class="form-label">Estado</label>
            <input type="text" id="editEstado" class="form-control">
          </div>

          <div class="col-12">
            <hr class="my-2">
            <h6 class="text-uppercase text-muted mb-2">Cidades onde seus anúncios são encontrados</h6>
            <div class="row g-3 align-items-end">
              <div class="col-md-8">
                <label class="form-label">Local de atuação</label>
                <select id="editCidadeAtendimento" class="form-control">
                  <option value="">Selecione uma cidade ou bairro</option>
                </select>
              </div>
              <div class="col-md-4">
                <button type="button" id="btnAddCidadeAtendimento" class="btn btn-outline-danger w-100">
                  Adicionar local
                </button>
              </div>
            </div>
            <small class="text-muted d-block mt-2">Escolha até 3 locais.</small>
            <div id="editCidadesAtendimentoLista" class="cidade-atendimento-lista"></div>
          </div>

          <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-success">Salvar</button>
            <button type="button" class="btn btn-secondary" onclick="fecharFormDeEdicao()">Cancelar</button>
          </div>

        </form>
      </div>
    `;

      /* =========================
         CAPTURA ELEMENTOS
      ========================== */
      const editNome = document.getElementById('editNome');
      const editCpf = document.getElementById('editCpf');
      const editCnpj = document.getElementById('editCnpj');
      const editWhatsapp = document.getElementById('editWhatsapp');
      const editTelefone = document.getElementById('editTelefone');
      const editEmail = document.getElementById('editEmail');
      const editCep = document.getElementById('editCep');

        groupCpf.style.display = 'block';
        editCpf.disabled = false;
        editCpf.required = true;

        groupCnpj.style.display = 'none';
        groupTelefone.style.display = 'none';

        editCnpj.disabled = true;
        editTelefone.disabled = true;

        editCnpj.required = false;
        editTelefone.required = false;

        editCnpj.value = '';
        editTelefone.value = '';
      }


      /* =========================
         PREENCHER DADOS
      ========================== */
      editNome.value = usuario.nome ?? '';
      editCpf.value = usuario.cpf ?? '';
      editWhatsapp.value = usuario.whatsapp ?? '';
      editEmail.value = usuario.email ?? '';
      editCep.value = usuario.cep ?? '';
      editRua.value = usuario.rua ?? '';
      editNumero.value = usuario.numero ?? '';
      editBairro.value = usuario.bairro ?? '';
      editCidade.value = usuario.cidade ?? '';
      editEstado.value = usuario.estado ?? '';

      const cidadesAtendimentoSelecionadas = obterCidadesAtendimentoPerfil(usuario)
        .map(item => ({
          bairro: item.bairro || '',
          nome: item.nome || item.cidade,
          cidade: item.cidade || item.nome,
          estado: item.estado
        }))
        .filter(item => (item.nome || item.cidade) && item.estado)
        .slice(0, 3);

      function chaveCidadeAtendimento(cidade) {
        return `${cidade.bairro || ''}|${cidade.nome || cidade.cidade}|${cidade.estado}`.toLowerCase();
      }

      function renderizarCidadesAtendimentoEdicao() {
        const lista = document.getElementById('editCidadesAtendimentoLista');
        if (!lista) return;

        lista.innerHTML = '';

        if (!cidadesAtendimentoSelecionadas.length) {
          lista.innerHTML = '<span class="text-muted">Nenhuma cidade adicional cadastrada.</span>';
          return;
        }

        cidadesAtendimentoSelecionadas.forEach((cidade, index) => {
          const item = document.createElement('span');
          item.className = 'cidade-atendimento-pill';
          item.textContent = formatarLocalAtendimento(cidade);

          const remover = document.createElement('button');
          remover.type = 'button';
          remover.setAttribute('aria-label', `Remover ${cidade.nome || cidade.cidade}`);
          remover.textContent = 'x';
          remover.addEventListener('click', () => {
            cidadesAtendimentoSelecionadas.splice(index, 1);
            renderizarCidadesAtendimentoEdicao();
          });

          item.appendChild(remover);
          lista.appendChild(item);
        });
      }

      async function carregarSelectCidadesAtendimentoEdicao() {
        const select = document.getElementById('editCidadeAtendimento');
        if (!select) return;

        try {
          const [resCidades, resBairros] = await Promise.all([
            fetch('/api/cidades'),
            fetch('/api/bairros')
          ]);
          if (!resCidades.ok) throw new Error('Erro ao carregar cidades');

          const cidades = await resCidades.json();
          const bairros = resBairros.ok ? await resBairros.json() : [];
          const locais = [
            ...cidades.map(cidade => ({
              tipo: 'cidade',
              nome: cidade.nome,
              cidade: cidade.nome,
              estado: cidade.estado,
              bairro: ''
            })),
            ...bairros.map(bairro => ({
              tipo: 'bairro',
              nome: bairro.cidade || bairro.cidade_nome,
              cidade: bairro.cidade || bairro.cidade_nome,
              estado: bairro.estado,
              bairro: bairro.nome
            }))
          ];

          locais
            .filter(local => local.cidade && local.estado)
            .sort((a, b) => formatarLocalAtendimento(a).localeCompare(formatarLocalAtendimento(b), 'pt-BR'))
            .forEach(local => {
              const option = document.createElement('option');
              option.value = JSON.stringify(local);
              option.textContent = formatarLocalAtendimento(local);
              select.appendChild(option);
            });
        } catch (error) {
          console.error(error);
        }
      }

      // Cidades de atuação valem para qualquer tipo de anunciante (revenda ou particular)
      renderizarCidadesAtendimentoEdicao();
      carregarSelectCidadesAtendimentoEdicao();

      document.getElementById('btnAddCidadeAtendimento')?.addEventListener('click', () => {
        const select = document.getElementById('editCidadeAtendimento');
        if (!select || !select.value) return;

        if (cidadesAtendimentoSelecionadas.length >= 3) {
          alert('Escolha no máximo 3 locais de atuação.');
          return;
        }

        const cidade = JSON.parse(select.value);
        const jaExiste = cidadesAtendimentoSelecionadas.some(item =>
          chaveCidadeAtendimento(item) === chaveCidadeAtendimento(cidade)
        );

        if (!jaExiste) {
          cidadesAtendimentoSelecionadas.push({
            bairro: cidade.bairro || '',
            nome: cidade.nome,
            cidade: cidade.cidade || cidade.nome,
            estado: cidade.estado
          });
          renderizarCidadesAtendimentoEdicao();
        }

        select.value = '';
      });

      /* =========================
         PUT – SALVAR ALTERAÇÕES
      ========================== */
      document
        .getElementById('formEditarPerfil')
        .addEventListener('submit', async (e) => {
          e.preventDefault();

          const dadosAtualizados = {
            nome: editNome.value,
            cpf: editCpf.value,
            whatsapp: editWhatsapp.value,
            email: editEmail.value,
            cep: editCep.value,
            rua: editRua.value,
            numero: editNumero.value,
            bairro: editBairro.value,
            cidade: editCidade.value,
            estado: editEstado.value
          };

          if (isRevenda) {
            dadosAtualizados.cnpj = editCnpj.value;
            dadosAtualizados.telefone = editTelefone.value;
          }

          // Cidades de atuação valem para revenda e particular
          dadosAtualizados.cidadesAtendimento = cidadesAtendimentoSelecionadas;

          try {
            const response = await fetch(
              `/api/editar-perfil-anunciante/${infoIDsessao}`,
              {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify(dadosAtualizados)
              }
            );

            if (!response.ok) {
              throw new Error('Erro ao atualizar perfil');
            }

            alert('Perfil atualizado com sucesso!');
            fecharFormDeEdicao();
            window.location.reload();
          } catch (error) {
            console.error(error);
            alert('Erro ao salvar alterações');
          }
        });

    } catch (error) {
      console.error(error);
      alert('Erro ao carregar dados do perfil');
    }
  }


</script>

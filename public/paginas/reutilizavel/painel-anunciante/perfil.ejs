    border: 1px solid #9fa1a3;
    background-color: #fdfdfd;
  }

  .info-label {
    display: block;
    font-size: 0.75rem;
    color: #6c757d;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
    letter-spacing: 0.03em;
  }


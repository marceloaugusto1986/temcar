<style>
    .site-footer {
        background: linear-gradient(135deg, #C90B0C, #930708);
        color: #fff;
        position: relative;
        overflow: hidden;
    }

    .site-footer::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 15% 10%, rgba(255, 255, 255, .16), transparent 30%);
        pointer-events: none;
    }

    .site-footer .container {
        position: relative;
    }

    .footer-link {
        color: rgba(255, 255, 255, .82);
        text-decoration: none;
        transition: 0.2s ease;
        display: inline-block;
        margin-bottom: 6px;
    }

    .footer-link:hover {
        color: #fff;
        padding-left: 5px;
    }

    .footer-copy {
        background: #111;
        color: rgba(255, 255, 255, .62);
    }
</style>

<!-- FOOTER -->
<footer class="mt-5 site-footer">
    <div class="container py-5">

        <div class="row g-4">

            <!-- INSTITUCIONAL -->
            <div class="col-md-4 col-sm-6">
                <h5 class="fw-bold mb-3">Institucional</h5>
                <ul class="list-unstyled">
                    <li><a href="/quem-somos" class="footer-link">Quem Somos</a></li>
                    <li><a href="/fale-conosco" class="footer-link">Fale Conosco</a></li>
                    <li><a href="/regras-gerais" class="footer-link">Regras Gerais</a></li>
                    <li><a href="/politica-de-privacidade" class="footer-link">Política de Privacidade</a></li>
                    <li><a href="/termos-de-uso" class="footer-link">Termos de Uso</a></li>
                </ul>
            </div>

            <!-- FERRAMENTAS -->
            <div class="col-md-3 col-sm-6">
                <h5 class="fw-bold mb-3">Ferramentas</h5>
                <ul class="list-unstyled">
                    <li><a href="/buscar-cidades" class="footer-link">Busque por Cidades</a></li>
                    <li><a href="/tabela-fipe" class="footer-link">Tabela FIPE</a></li>
                </ul>
            </div>

            <!-- SERVIÇOS -->
            <div class="col-md-3 col-sm-6">
                <h5 class="fw-bold mb-3">Serviços</h5>
                <ul id="footerServicos" class="list-unstyled">
                    <li><span class="footer-link">Carregando serviços...</span></li>
                </ul>
            </div>

            <!-- VENDER -->
            <div class="col-md-2 col-sm-6">
                <h5 class="fw-bold mb-3"><a href="#" style="color:#fff;text-decoration:none;">Planos</a></h5>
                <ul class="list-unstyled">
                    <li><a href="/planos-particular" class="footer-link">Planos Particular</a></li>
                    <li><a href="/planos-revenda" class="footer-link">Planos Revenda</a></li>
                </ul>
            </div>

        </div>
    </div>

    <!-- COPYRIGHT -->
    <div class="footer-copy">
        <div class="container py-3 text-center">
            © <%= new Date().getFullYear() %> Copyright TEMCAR.com.br - Todos os direitos reservados.
        </div>
    </div>
</footer>

<script>
    async function carregarFooterServicos() {
        const lista = document.getElementById('footerServicos');
        if (!lista) return;

        try {
            const res = await fetch('/api/servicos-select/ativos');

            if (!res.ok) {
                throw new Error('Erro ao buscar serviços');
            }

            const servicos = await res.json();
            lista.innerHTML = '';

            if (!servicos.length) {
                lista.innerHTML = '<li><span class="footer-link">Nenhum serviço disponível</span></li>';
                return;
            }

            servicos.forEach(servico => {
                const item = document.createElement('li');
                const link = document.createElement('a');

                link.className = 'footer-link';
                link.href = servico.url || '#';
                link.textContent = servico.nome;

                if (servico.url && /^https?:\/\//i.test(servico.url)) {
                    link.target = '_blank';
                    link.rel = 'noopener noreferrer';
                }

                item.appendChild(link);
                lista.appendChild(item);
            });
        } catch (erro) {
            console.error('Erro ao carregar serviços no footer:', erro);
            lista.innerHTML = '<li><span class="footer-link">Serviços indisponíveis</span></li>';
        }
    }

    carregarFooterServicos();
</script>

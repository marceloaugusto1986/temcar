<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('reutilizavel/seo-head', { seo: typeof seo !== 'undefined' ? seo : {} }) %>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<style>
    body {
        background: linear-gradient(135deg, #ffffff, #f8f8f8);
    }

    .cadastro-card {
        border-radius: 18px;
    }

    .form-control,
    .form-select {
        border-radius: 10px;
        padding: 12px;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #dc3545;
        box-shadow: 0 0 0 0.15rem rgba(220, 53, 69, 0.25);
    }

    h6 {
        color: #444;
    }

    .btn-danger {
        border-radius: 12px;
        font-weight: 600;
    }

    hr {
        opacity: 0.1;
    }

    .cidade-atendimento-lista {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
    }

    .cidade-atendimento-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #e1e1e1;
        border-radius: 999px;
        background: #fff;
        color: #2b2f36;
        padding: 7px 10px 7px 12px;
        font-weight: 600;
        font-size: .9rem;
    }

    .cidade-atendimento-pill button {
        border: 0;
        background: transparent;
        color: #C90B0C;
        font-weight: 800;
        line-height: 1;
    }
</style>

<body>
    <%- include('./reutilizavel/header-public') %>

    <div class="container d-flex justify-content-center my-5">
        <div class="col-12 col-sm-11 col-md-10 col-lg-8 col-xl-7">

            <div class="card shadow-lg border-0 cadastro-card">
                <div class="card-body p-4 p-md-5">

                    <!-- TÍTULO -->
                    <div class="text-center mb-4">
                        <h4 class="fw-bold text-danger">Cadastro Revenda</h4>
                        <p class="text-muted small">Cadastre sua empresa para anunciar</p>
                    </div>

                    <form id="formRevenda">

                        <!-- DADOS DA EMPRESA -->
                        <h6 class="fw-bold mb-3">Dados da empresa</h6>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Nome da empresa</label>
                                <input type="text" class="form-control" id="nome" placeholder="Nome da revenda"
                                    required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">E-mail</label>
                                <input type="email" class="form-control" id="email"
                                    placeholder="contato@revenda.com" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">WhatsApp</label>
                                <input type="tel" class="form-control" id="whatsapp" placeholder="(00) 00000-0000"
                                    required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Telefone fixo</label>
                                <input type="tel" class="form-control" id="telefone" placeholder="(00) 0000-0000">
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">CNPJ</label>
                                <input type="text" class="form-control" id="cnpj" placeholder="00.000.000/0000-00"
                                    required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Plano</label>
                                <select class="form-select" id="planoRevenda" required>
                                    <option value="">Selecione um plano</option>
                                </select>
                            </div>
                        </div>

                        <hr class="my-4">

                        <!-- ENDEREÇO -->
                        <h6 class="fw-bold mb-3">Endereço</h6>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">CEP</label>
                                <input type="text" class="form-control" id="cep" placeholder="00000-000">
                            </div>

                            <div class="col-md-8">
                                <label class="form-label">Rua</label>
                                <input type="text" class="form-control" id="rua">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Número</label>
                                <input type="text" class="form-control" id="numero">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Bairro</label>
                                <input type="text" class="form-control" id="bairro">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Cidade</label>
                                <input type="text" class="form-control" id="cidade">
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Estado</label>
                                <select class="form-select" id="estado">
                                    <option value="">Selecione</option>
                                    <option>SP</option>
                                    <option>RJ</option>
                                    <option>MG</option>
                                    <option>RS</option>
                                </select>
                            </div>
                        </div>

                        <hr class="my-4">

                        <!-- CIDADES DE ATUAÇÃO -->
                        <h6 class="fw-bold mb-3">Cidades onde deseja ser encontrado</h6>

                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label">Cidade de atuação</label>
                                <select class="form-select" id="cidadeAtendimento">
                                    <option value="">Selecione uma cidade</option>
                                </select>
                                <div class="form-text">
                                    Ao informar cidades, seus anúncios também poderão aparecer nas buscas dessas regiões.
                                </div>
                            </div>

                            <div class="col-md-4 d-flex align-items-start">
                                <button type="button" class="btn btn-outline-danger w-100 mt-md-4" id="btnAdicionarCidade">
                                    Adicionar cidade
                                </button>
                            </div>

                            <div class="col-12">
                                <div id="cidadesAtendimentoLista" class="cidade-atendimento-lista"></div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <!-- ACESSO -->
                        <h6 class="fw-bold mb-3">Acesso</h6>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Senha</label>
                                <input type="password" class="form-control" id="senha" placeholder="••••••••"
                                    required>
                            </div>
                        </div>

                        <!-- CTA -->
                        <div class="mt-4">
                            <button type="submit" class="btn btn-danger btn-lg w-100">
                                Criar conta da revenda
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>

    <%- include('./reutilizavel/footer-public') %>
            
    <script src="./../js/cadastro-revenda.js"></script>
</body>

</html>

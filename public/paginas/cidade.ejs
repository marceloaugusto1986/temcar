<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('reutilizavel/seo-head', { seo: typeof seo !=='undefined' ? seo : {} }) %>
        <%- include('reutilizavel/jsonld-breadcrumb', { breadcrumbs: typeof breadcrumbs !=='undefined' ? breadcrumbs :
            [] }) %>
            <script src="/js/site-config.js" defer></script>


            <!-- Bootstrap 5 -->
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
            <link rel="stylesheet" href="/css/revenda.css">
</head>

<style>
    /* Sem sidebar: layout original (container Bootstrap centralizado) */
    body { background: white; }

    .layout.sem-sidebar {
        display: block;
    }
    .layout.sem-sidebar .conteudo {
        flex: unset;
        max-width: 1140px;
        margin: 3rem auto;
        padding: 0 12px;
    }

    /* Bairro inline no modo sem-sidebar */
    #cidade-filtros.in-sidebar {
        display: block;
        border: none;
        background: transparent;
        padding: 0;
        border-radius: 0;
        margin: 0;
        gap: 0;
    }
    #cidade-filtros.in-sidebar .cidade-filtro-help { display: none; }
    #cidade-filtros.in-sidebar .cidade-filtro-label { font-weight: 700; color: #212529; font-size: 1rem; margin-bottom: 0.25rem; }
    #cidade-filtros.in-sidebar .cidade-filtro-control { width: 100%; }
    #cidade-filtros.in-sidebar .cidade-filtro-bairro { margin-bottom: 1rem; }

    .card-text-limit {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        /* 👈 número de linhas */
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .cidade-banner .overlay {
        background: rgba(0, 0, 0, 0.5);
    }

    .cidade-banner {
        width: 100%;
        max-width: 100vw;
        height: clamp(190px, 24vw, 250px);
        background: #1f1f1f;
        overflow: hidden;
    }

    .cidadeBannerSwiper,
    .cidadeBannerSwiper .swiper-wrapper,
    .cidadeBannerSwiper .swiper-slide {
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .cidadeBannerSwiper .swiper-slide {
        min-width: 0;
    }

    .cidade-banner-link,
    .cidade-banner-picture {
        display: block;
        width: 100%;
        height: 100%;
    }

    .cidade-banner-img {
        width: 100%;
        height: 100%;
        max-width: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
    }

    .cidade-banner-fallback {
        height: 100%;
        background: linear-gradient(135deg, #C90B0C 0%, #7b0708 100%);
    }

    .cidadeBannerSwiper .swiper-pagination-bullet {
        background: #fff;
        opacity: .65;
    }

    .cidadeBannerSwiper .swiper-pagination-bullet-active {
        background: #C90B0C;
        opacity: 1;
    }

    .cidadeBannerSwiper .swiper-button-next,
    .cidadeBannerSwiper .swiper-button-prev {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        color: #fff;
        background: rgba(0, 0, 0, .35);
    }

    .cidadeBannerSwiper .swiper-button-next::after,
    .cidadeBannerSwiper .swiper-button-prev::after {
        font-size: 18px;
    }

    .descricao-card {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .cidade-empty-state {
        width: 100%;
        border: 1px solid rgba(201, 11, 12, 0.18);
        border-radius: 8px;
        background:
            linear-gradient(135deg, rgba(201, 11, 12, 0.08), rgba(255, 255, 255, 0) 55%),
            #fff;
        padding: 32px;
        text-align: center;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    }

    .cidade-empty-icon {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #C90B0C;
        color: #fff;
        font-size: 1.6rem;
        margin-bottom: 16px;
    }

    .cidade-empty-title {
        color: #222;
        font-size: 1.25rem;
        line-height: 1.35;
        margin-bottom: 14px;
    }

    .cidade-empty-promo {
        color: #444;
        font-size: 1rem;
        margin-bottom: 22px;
    }

    .cidade-empty-promo strong {
        color: #C90B0C;
    }

    .cidade-empty-actions {
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .cidade-empty-actions .btn {
        border-radius: 6px;
        font-weight: 700;
        padding: 10px 18px;
    }

    .cidade-filtros {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 26px;
        padding: 14px;
        border: 1px solid rgba(201, 11, 12, .14);
        border-radius: 8px;
        background:
            linear-gradient(135deg, rgba(201, 11, 12, .06), rgba(255, 255, 255, 0) 60%),
            #fafafa;
    }

    .cidade-filtro-copy {
        min-width: 0;
    }

    .cidade-filtro-label {
        display: block;
        color: #C90B0C;
        font-weight: 800;
        font-size: .86rem;
        margin-bottom: 2px;
    }

    .cidade-filtro-help {
        color: #68707d;
        font-size: .88rem;
    }

    .cidade-filtro-control {
        width: min(100%, 320px);
    }

    .cidade-filtro-bairro {
        min-height: 44px;
        border-color: rgba(201, 11, 12, .22);
        border-radius: 8px;
        font-weight: 700;
        color: #2b2f36;
        box-shadow: none;
    }

    .cidade-filtro-bairro:focus {
        border-color: #C90B0C;
        box-shadow: 0 0 0 .18rem rgba(201, 11, 12, .12);
    }

    @media (max-width: 576px) {
        .cidade-banner {
            height: auto;
            background: #C90B0C;
        }

        .cidadeBannerSwiper,
        .cidadeBannerSwiper .swiper-wrapper,
        .cidadeBannerSwiper .swiper-slide {
            height: auto;
        }

        .cidade-banner-img {
            height: auto;
            object-fit: contain;
            object-position: center;
        }

        .cidade-banner-link {
            height: auto;
        }

        .cidade-banner-fallback {
            min-height: 140px;
        }

        .cidadeBannerSwiper .swiper-button-next,
        .cidadeBannerSwiper .swiper-button-prev {
            display: none;
        }

        .cidade-page-content {
            margin-top: 28px !important;
            margin-bottom: 32px !important;
        }

        .cidade-page-panel {
            padding: 18px 14px !important;
        }

        .cidade-page-panel h4 {
            font-size: 1.28rem;
            line-height: 1.25;
        }

        .cidade-filtros {
            align-items: stretch;
            flex-direction: column;
            padding: 12px;
        }

        .cidade-filtro-control {
            width: 100%;
        }

        #container-card-primary .vehicle-card {
            width: min(280px, calc(100vw - 76px)) !important;
        }

        .cidade-empty-state {
            padding: 24px 18px;
        }
    }
</style>

<body>
    <%- include('./reutilizavel/header-public') %>

        <% if (typeof seo !=='undefined' && seo.texto_h1) { %>
            <h1 class="visually-hidden">
                <%= seo.texto_h1 %>
            </h1>
            <% } else { %>
                <h1 class="visually-hidden">Veículos à Venda - TEMCAR</h1>
                <% } %>

                    <!-- Banner da cidade em slider -->
                    <section class="cidade-banner position-relative text-white">
                        <div class="swiper cidadeBannerSwiper" id="cidadeBannerSlider">
                            <div class="swiper-wrapper" id="cidadeBannerWrapper">
                                <div class="swiper-slide">
                                    <div class="cidade-banner-fallback"></div>
                                </div>
                            </div>
                            <div class="swiper-button-prev"></div>
                            <div class="swiper-button-next"></div>
                            <div class="swiper-pagination"></div>
                        </div>
                    </section>

                    <!-- Filtros inline (visíveis quando ≤20 registros) -->
                    <div class="container" id="bairro-container">
                        <div class="d-flex gap-3 flex-wrap mt-3">
                            <div id="cidade-filtros" class="cidade-filtros d-none" style="flex:1; min-width:220px; margin-bottom:0;">
                                <div class="cidade-filtro-copy">
                                    <span class="cidade-filtro-label">Filtrar por bairro</span>
                                    <span class="cidade-filtro-help">Veja ofertas em uma região específica da cidade.</span>
                                </div>
                                <div class="cidade-filtro-control">
                                    <select id="filtro-bairro-cidade" class="form-select cidade-filtro-bairro">
                                        <option value="">Todos os bairros</option>
                                    </select>
                                </div>
                            </div>
                            <div id="filtro-tipo-container" class="cidade-filtros d-none" style="flex:1; min-width:220px; margin-bottom:0;">
                                <div class="cidade-filtro-copy">
                                    <span class="cidade-filtro-label">Tipo de anúncio</span>
                                    <span class="cidade-filtro-help">Filtre por particular ou loja.</span>
                                </div>
                                <div class="cidade-filtro-control">
                                    <select id="filtro-tipo-anunciante" class="form-select cidade-filtro-bairro">
                                        <option value="">Todos</option>
                                        <option value="particular">Particular</option>
                                        <option value="revenda">Loja / Revenda</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Botão filtro mobile -->
                    <div class="d-lg-none d-none" id="btn-filtro-wrapper">
                        <button class="btn btn-danger btn-abrir-filtro" onclick="toggleFiltro()">
                            <i class="bi bi-funnel"></i> Filtrar resultados
                        </button>
                    </div>

                    <div class="layout sem-sidebar" id="main-layout">

                        <!-- SIDEBAR -->
                        <aside class="barra_lateral d-none" id="sidebar">

                            <div class="sidebar-header">
                                <h5 class="m-0">Filtros</h5>
                                <button class="btn btn-sm btn-outline-dark" onclick="toggleFiltro()">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>

                            <div class="sidebar-body">

                                <strong>Barra de pesquisa</strong>
                                <input id="filtroBusca" class="form-control mb-3" placeholder="Ex.: Chevrolet Tracker">

                                <!-- bairro será movido aqui via JS quando >20 registros -->
                                <div id="sidebar-bairro-slot"></div>

                                <strong>Marcas</strong>
                                <div id="filtroMarcas" class="mb-3"></div>

                                <strong>Modelo / Versão</strong>
                                <select id="filtroModelo" class="form-select mb-3">
                                    <option value="">Todos</option>
                                </select>

                                <strong>Ano</strong>
                                <div class="d-flex gap-2 mb-3">
                                    <select id="filtroAnoMin" class="form-select">
                                        <option value="">Min.</option>
                                    </select>
                                    <select id="filtroAnoMax" class="form-select">
                                        <option value="">Max.</option>
                                    </select>
                                </div>

                                <strong>Faixa de preço</strong>
                                <input id="filtroPrecoMin" class="form-control mb-2" placeholder="Min">
                                <input id="filtroPrecoMax" class="form-control mb-3" placeholder="Max">

                                <strong>Quilometragem</strong>
                                <input id="filtroKmMin" class="form-control mb-2" placeholder="Min">
                                <input id="filtroKmMax" class="form-control mb-3" placeholder="Max">

                                <strong>Câmbio</strong>
                                <select id="filtroCambio" class="form-select mb-3">
                                    <option value="">Todos</option>
                                </select>

                                <strong>Combustível</strong>
                                <select id="filtroCombustivel" class="form-select mb-3">
                                    <option value="">Todos</option>
                                </select>

                                <strong>Estado do veículo</strong>
                                <div class="mb-3">
                                    <label><input type="checkbox" id="filtroNovo"> Novo</label><br>
                                    <label><input type="checkbox" id="filtroUsado"> Usado</label>
                                </div>

                                <strong>Blindagem</strong>
                                <div class="mb-3">
                                    <label><input type="checkbox" id="filtroBlindado"> Com blindagem</label><br>
                                    <label><input type="checkbox" id="filtroNaoBlindado"> Sem blindagem</label>
                                </div>

                                <strong>Carroceria</strong>
                                <select id="filtroCarroceria" class="form-select mb-3">
                                    <option value="">Todas</option>
                                </select>

                                <strong>Tipo de anúncio</strong>
                                <div class="mb-3">
                                    <label><input type="checkbox" id="filtroParticular"> Particular</label><br>
                                    <label><input type="checkbox" id="filtroRevenda"> Loja / Revenda</label>
                                </div>

                            </div>

                            <div class="sidebar-footer d-flex gap-2">
                                <button onclick="limparFiltros()" class="btn btn-outline-secondary w-50">Limpar</button>
                                <button onclick="aplicarFiltros()" class="btn btn-danger w-50">Aplicar filtros</button>
                            </div>

                        </aside>

                        <div class="overlay" id="overlay" onclick="toggleFiltro()"></div>

                        <!-- CONTEÚDO -->
                        <main class="conteudo">
                            <div class="bg-white p-3 rounded cidade-page-panel" style="min-height: 70vh;">
                                <h4 id="titulo-cidade" class="mb-3 fw-bold" style="color:#C90B0C;"></h4>

                                <div id="container-card-primary" class="d-flex gap-3 flex-wrap pb-2"></div>

                                <nav class="mt-4">
                                    <ul class="pagination justify-content-center" id="paginacao"></ul>
                                </nav>
                            </div>
                        </main>

                    </div>

                    <!-- Filtro passado pelo servidor (inclui bairro agora) -->
                    <script>
                        window.FILTRO = <%- JSON.stringify(typeof filtro !== 'undefined' ? filtro : {}) %>;
                        window.SEO_PAGINA = <%- JSON.stringify(typeof seo !== 'undefined' ? seo : {}) %>;
                    </script>

                    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
                    <script src="/js/cidade.js?v=31"></script>

                    <%- include('./reutilizavel/footer-public') %>


</body>

</html>

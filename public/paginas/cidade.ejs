<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('reutilizavel/seo-head', { seo: typeof seo !=='undefined' ? seo : {} }) %>
        <%- include('reutilizavel/jsonld-breadcrumb', { breadcrumbs: typeof breadcrumbs !=='undefined' ? breadcrumbs :
            [] }) %>
            <script src="/js/site-config.js" defer></script>


            <!-- Bootstrap 5 -->
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
</head>

<style>
    .card-text-limit {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        /* 👈 número de linhas */
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .cidade-banner .overlay {
        background: rgba(0, 0, 0, 0.5);
    }

    .cidade-banner {
        width: 100%;
        max-width: 100vw;
        height: clamp(190px, 24vw, 250px);
        background: #1f1f1f;
        overflow: hidden;
    }

    .cidadeBannerSwiper,
    .cidadeBannerSwiper .swiper-wrapper,
    .cidadeBannerSwiper .swiper-slide {
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .cidadeBannerSwiper .swiper-slide {
        min-width: 0;
    }

    .cidade-banner-link,
    .cidade-banner-picture {
        display: block;
        width: 100%;
        height: 100%;
    }

    .cidade-banner-img {
        width: 100%;
        height: 100%;
        max-width: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
    }

    .cidade-banner-fallback {
        height: 100%;
        background: linear-gradient(135deg, #C90B0C 0%, #7b0708 100%);
    }

    .cidadeBannerSwiper .swiper-pagination-bullet {
        background: #fff;
        opacity: .65;
    }

    .cidadeBannerSwiper .swiper-pagination-bullet-active {
        background: #C90B0C;
        opacity: 1;
    }

    .cidadeBannerSwiper .swiper-button-next,
    .cidadeBannerSwiper .swiper-button-prev {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        color: #fff;
        background: rgba(0, 0, 0, .35);
    }

    .cidadeBannerSwiper .swiper-button-next::after,
    .cidadeBannerSwiper .swiper-button-prev::after {
        font-size: 18px;
    }

    .descricao-card {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .cidade-empty-state {
        width: 100%;
        border: 1px solid rgba(201, 11, 12, 0.18);
        border-radius: 8px;
        background:
            linear-gradient(135deg, rgba(201, 11, 12, 0.08), rgba(255, 255, 255, 0) 55%),
            #fff;
        padding: 32px;
        text-align: center;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    }

    .cidade-empty-icon {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #C90B0C;
        color: #fff;
        font-size: 1.6rem;
        margin-bottom: 16px;
    }

    .cidade-empty-title {
        color: #222;
        font-size: 1.25rem;
        line-height: 1.35;
        margin-bottom: 14px;
    }

    .cidade-empty-promo {
        color: #444;
        font-size: 1rem;
        margin-bottom: 22px;
    }

    .cidade-empty-promo strong {
        color: #C90B0C;
    }

    .cidade-empty-actions {
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .cidade-empty-actions .btn {
        border-radius: 6px;
        font-weight: 700;
        padding: 10px 18px;
    }

    @media (max-width: 576px) {
        .cidade-banner {
            height: auto;
            background: #C90B0C;
        }

        .cidadeBannerSwiper,
        .cidadeBannerSwiper .swiper-wrapper,
        .cidadeBannerSwiper .swiper-slide {
            height: auto;
        }

        .cidade-banner-img {
            height: auto;
            object-fit: contain;
            object-position: center;
        }

        .cidade-banner-link {
            height: auto;
        }

        .cidade-banner-fallback {
            min-height: 140px;
        }

        .cidadeBannerSwiper .swiper-button-next,
        .cidadeBannerSwiper .swiper-button-prev {
            display: none;
        }

        .cidade-page-content {
            margin-top: 28px !important;
            margin-bottom: 32px !important;
        }

        .cidade-page-panel {
            padding: 18px 14px !important;
        }

        .cidade-page-panel h4 {
            font-size: 1.28rem;
            line-height: 1.25;
        }

        #container-card-primary .vehicle-card {
            width: min(280px, calc(100vw - 76px)) !important;
        }

        .cidade-empty-state {
            padding: 24px 18px;
        }
    }
</style>

<body>
    <%- include('./reutilizavel/header-public') %>

        <% if (typeof seo !=='undefined' && seo.texto_h1) { %>
            <h1 class="visually-hidden">
                <%= seo.texto_h1 %>
            </h1>
            <% } else { %>
                <h1 class="visually-hidden">Veículos à Venda - TEMCAR</h1>
                <% } %>

                    <!-- Banner da cidade em slider -->
                    <section class="cidade-banner position-relative text-white">
                        <div class="swiper cidadeBannerSwiper" id="cidadeBannerSlider">
                            <div class="swiper-wrapper" id="cidadeBannerWrapper">
                                <div class="swiper-slide">
                                    <div class="cidade-banner-fallback"></div>
                                </div>
                            </div>
                            <div class="swiper-button-prev"></div>
                            <div class="swiper-button-next"></div>
                            <div class="swiper-pagination"></div>
                        </div>
                    </section>

                    <section class="container my-5 cidade-page-content" style="min-height: 80vh !important;">

                        <div class="bg-white p-3 rounded cidade-page-panel">
                            <h4 id="titulo-cidade" class="mb-4 fw-bold" style="color:#C90B0C;"></h4>

                            <div id="container-card-primary" class="d-flex gap-3 overflow-auto pb-2"></div>

                            <nav class="mt-4">
                                <ul class="pagination justify-content-center" id="paginacao"></ul>
                            </nav>

                        </div>

                    </section>

                    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
                    <script src="/js/cidade.js?v=11"></script>

                    <%- include('./reutilizavel/footer-public') %>


</body>

</html>

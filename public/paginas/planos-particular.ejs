<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('reutilizavel/seo-head', { seo: typeof seo !== 'undefined' ? seo : {} }) %>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<style>
  body {
    font-family: Arial, sans-serif;
    margin: 0;
    background: #f5f5f5;
  }

  .container {
    max-width: 1300px;
    margin: auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
    justify-content: center;
    align-items: center;
  }

  .cards {
    display: flex;
    gap: 20px;
    align-items: stretch;
    /* garante mesma altura */
    width: 100%;
  }

  .card {
    flex: 1;
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    text-align: center;


    display: flex;
    flex-direction: column;
    justify-content: space-between;
    /* distribui conteúdo */
    transition: transform 0.3s ease;
    /* transição suave */
  }

  .card:hover {
    transform: scale(1.01);
    /* aumenta o tamanho ao passar o mouse */
  }

  .card-principal {
    background-color: #a3a6cfbe;
    min-height: 350px;
    max-height: 350px;

    width: 250px;
  }

  .card-interno {
    margin-top: 15px;
  }

  .card h3 {
    margin-bottom: 10px;
  }

  .cards {
    display: flex;
    flex-wrap: wrap;
    min-width: 100%;
    margin-top: 50px;
  }

  .container-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    justify-content: center;
    align-items: center;
    margin: 0 auto;
    margin-top: 50px;
  }

  .titulo-plano {
    background-color: #ece9f8;
    border-radius: 10px;
    text-align: center;
    padding: 5px;

    margin: 0 auto;
    font-weight: bold;
    color: #6f74b9;
  }

  .titulo-dias {
    background-color: #6f74b9;
    border-radius: 10px;
    text-align: center;
    padding: 5px;
    margin: 0 auto 15px auto;
    font-weight: bold;
    color: white;
  }

  .promocao {
    background-color: #c90b0c;
    border-radius: 10px;
    text-align: center;
    padding: 10px;
    margin: 0 auto;
    color: white;
    font-size: 16px;
    font-weight: bold;
  }

  .botao-anunciar {
    font-size: 18px;
    border: none;
    border-radius: 10px;
    background-color: #6f74b9;
    color: white;
    padding: 10px;
    width: 200px;
    cursor: pointer;
    transition: transform 0.3s ease, background-color 0.3s ease;
    margin-bottom: 20px;
    /* transição suave */
  }

  .botao-anunciar:hover {
    transform: scale(1.05);
    /* aumento do tamanho */
    background-color: #5a6497;
    /* cor de fundo mais escura ao passar o mouse */
  }

  /* RESPONSIVO */
  @media (max-width: 768px) {
    .cards {
      flex-direction: column;

    }
  }
</style>

<body>

  <%- include('./reutilizavel/header-public') %>

    <h1
      style="width: 100%; padding: 40px 0 40px 0; background-color: #c90b0c; text-align: center; font-weight: bold; color: white; font-family:'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;">
      PLANOS PARTICULAR</h1>

    <main class="container">

      <section class="cards">
        <% (planos || []).forEach((plano, index) => { %>
          <div class="container-card">
            <div class="card card-principal">
              <% if (index === 1) { %>
                <h4
                  style="background-color: #6f74b9; color: white; padding: 1px; border-top-left-radius: 10px; border-top-right-radius: 10px; position: relative; top: -51px;">
                  Recomendamos</h4>
              <% } %>
              <h3 class="titulo-plano" style="<%= index === 1 ? 'position: relative; top: -35px;' : '' %>">
                <%= plano.nome %>
              </h3>

              <div class="card card-interno" style="<%= index === 1 ? 'position: relative; top: -35px;' : '' %>">
                <h3 class="titulo-dias">
                  <% if (plano.dias_publicacao) { %>
                    <%= plano.dias_publicacao %> dias
                  <% } else { %>
                    Até vender
                  <% } %>
                </h3>
                <p><%= plano.descricao %></p>

                <h3 class="promocao">
                  Promoção: Grátis até julho/2026
                </h3>
              </div>
            </div>

            <button class="botao-anunciar" onclick="window.location.href='/cadastro-particular?plano=<%= plano.codigo %>';">ANUNCIAR</button>
          </div>
        <% }) %>
      </section>
    </main>

    <%- include('./reutilizavel/footer-public') %>

</body>

</html>

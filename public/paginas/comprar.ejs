<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('reutilizavel/seo-head', { seo: typeof seo !== 'undefined' ? seo : {} }) %>
    <%- include('reutilizavel/jsonld-breadcrumb', { breadcrumbs: typeof breadcrumbs !== 'undefined' ? breadcrumbs : [] }) %>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<style>
    .pagination .page-link {
        color: #C90B0C;
        border-color: #e0e0e0;
        font-weight: 500;
        transition: background-color .15s, color .15s, border-color .15s;
    }
    .pagination .page-link:hover {
        color: #a30909;
        background-color: rgba(201, 11, 12, .08);
        border-color: #C90B0C;
    }
    .pagination .page-item.active .page-link {
        background-color: #C90B0C;
        border-color: #C90B0C;
        color: #fff;
    }
    .pagination .page-item.disabled .page-link {
        color: #adb5bd;
        border-color: #e0e0e0;
        background-color: transparent;
    }

    .descricao-card {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .comprar-banner {
        background: linear-gradient(135deg, #C90B0C 0%, #8B0000 100%);
        padding: 50px 0;
    }

    .categoria-card {
        transition: transform 0.2s;
        cursor: pointer;
        text-decoration: none;
    }

    .categoria-card:hover {
        transform: translateY(-5px);
    }
</style>

<body>
    <%- include('./reutilizavel/header-public') %>

    <% if (typeof seo !== 'undefined' && seo.texto_h1) { %>
    <h1 class="visually-hidden"><%= seo.texto_h1 %></h1>
    <% } else { %>
    <h1 class="visually-hidden">Comprar Veículos - TEMCAR</h1>
    <% } %>

    <!-- Banner -->
    <section class="comprar-banner text-white text-center">
        <div class="container">
            <h2 class="fw-bold mb-2">Comprar Veículos</h2>
            <p class="mb-0">Encontre carros, motos e utilitários com os melhores preços no TEMCAR</p>
        </div>
    </section>

    <!-- Categorias -->
    <section class="container my-5">
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <a href="/carros" class="categoria-card card shadow-sm h-100 text-center p-4">
                    <i class="bi bi-car-front-fill" style="font-size:3rem;color:#C90B0C;"></i>
                    <h3 class="fw-bold mt-3">Carros</h3>
                    <p class="text-muted">Carros novos, seminovos e usados</p>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/motos" class="categoria-card card shadow-sm h-100 text-center p-4">
                    <i class="bi bi-bicycle" style="font-size:3rem;color:#C90B0C;"></i>
                    <h3 class="fw-bold mt-3">Motos</h3>
                    <p class="text-muted">Motos novas, seminovas e usadas</p>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/utilitarios" class="categoria-card card shadow-sm h-100 text-center p-4">
                    <i class="bi bi-truck" style="font-size:3rem;color:#C90B0C;"></i>
                    <h3 class="fw-bold mt-3">Utilitários</h3>
                    <p class="text-muted">Utilitários novos, seminovos e usados</p>
                </a>
            </div>
        </div>

        <!-- Anúncios recentes -->
        <div class="bg-white p-3 rounded">
            <h4 class="fw-bold mb-4" style="color:#C90B0C;">Anúncios Recentes</h4>

            <div id="loading" class="text-center py-5">
                <div class="spinner-border text-danger" role="status">
                    <span class="visually-hidden">Carregando...</span>
                </div>
            </div>

            <div id="container-card-primary" class="row g-3"></div>

            <nav class="mt-4">
                <ul class="pagination justify-content-center" id="paginacao"></ul>
            </nav>
        </div>
    </section>

    <script>
        window.FILTRO = {};
    </script>
    <script src="/js/veiculos.js?v=15"></script>

    <%- include('./reutilizavel/footer-public') %>
</body>

</html>

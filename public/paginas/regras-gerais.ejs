<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('reutilizavel/seo-head', { seo: typeof seo !== 'undefined' ? seo : {} }) %>
  <script src="./../js/site-config.js" defers></script>
  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<style>
  body {
    font-family: Arial, sans-serif;
    margin: 0;
    background: #f5f5f5;
  }

  .container {
    max-width: 1200px;
    margin: auto;
  }

  /* SECTION 1 */
  .two-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    margin-bottom: 60px;
  }

  .text h2 {
    margin-bottom: 15px;
  }

  .accordion {
    margin-top: 20px;
  }

  .accordion-item {
    border-bottom: 1px solid #ccc;
  }

  .accordion-header {
    cursor: pointer;
    padding: 15px;
    background: #eee;
    font-weight: bold;
  }

  .accordion-content {
    display: none;
    padding: 15px;
    background: #fff;
  }

  .image {
    display: flex;
    justify-content: center;
  }

  .image img {
    width: 100%;
    border-radius: 10px;
  }

  /* SECTION 2 */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .card {
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    text-align: center;
  }

  .card h3 {
    margin-bottom: 10px;
  }

  /* RESPONSIVO */
  @media (max-width: 768px) {
    .two-columns {
      grid-template-columns: 1fr;
    }

    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>

<body>
  <%- include('./reutilizavel/header-public') %>

    <h1
      style="width: 100%; padding: 40px 0 40px 0; background-color: #c90b0c; text-align: center; font-weight: bold; color: white; font-family:'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;">
      REGRAS GERAIS</h1>
    <main class="container my-5">
      <!-- <section id="regrasGeraisContainer"></section> -->

      <div class="container">

        <!-- SECTION 1 -->
        <section class="two-columns">

          <!-- COLUNA ESQUERDA -->
          <div class="text">
            <h2>Regras gerais</h2>

            <style>
              .accordion-content {
                max-height: 0;
                overflow: hidden;
                transition: max-height 0.3s ease;
                background: #fff;
                padding: 0 15px;
              }

              .accordion-item.active .accordion-content {
                max-height: 300px;
                /* suficiente pro conteúdo */
                padding: 15px;
              }

              .accordion-header {
                display: flex;
                align-items: center;
                cursor: pointer;
                padding: 15px;
                background: #eee;
                font-weight: bold;
              }

              .icon {
                color: red;
                margin-right: 10px;
                font-size: 18px;
              }

              .title {
                flex: 1;
              }

              .arrow {
                transition: transform 0.3s ease;
              }

              /* seta girando */
              .accordion-item.active .arrow {
                transform: rotate(90deg);
              }
            </style>

            <div class="accordion">

              <div class="accordion-item">
                <div class="accordion-header">
                  <span class="icon">+</span>
                  <span class="title">1. O TEMCAR vende veículos ou recebe comissão pelas vendas?</span>
                  <span class="arrow">▶</span>
                </div>
                <div class="accordion-content">
                  Não. O TEMCAR atua apenas como provedor de espaço para anúncios.<br>

                  Não comercializa veículos.<br>

                  Não participa das transações.<br>

                  Não recebe comissões sobre negócios fechados por meio dos anúncios.<br>
                </div>
              </div>

              <div class="accordion-item">
                <div class="accordion-header">
                  <span class="icon">+</span>
                  <span class="title">2. O TEMCAR garante a qualidade ou veracidade das informações dos anúncios?</span>
                  <span class="arrow">▶</span>
                </div>
                <div class="accordion-content">
                  Não.<br>
                  A responsabilidade pelas informações apresentadas é exclusiva do anunciante.
                  O TEMCAR não garante:<br>

                  Qualidade do veículo<br>

                  Procedência<br>

                  Veracidade das informações<br>

                  Condições de pagamento<br>

                  Consequências diretas ou indiretas do uso das informações<br>
                </div>
              </div>

              <div class="accordion-item">
                <div class="accordion-header">
                  <span class="icon">+</span>
                  <span class="title">3. O TEMCAR participa das negociações entre vendedor e comprador?</span>
                  <span class="arrow">▶</span>
                </div>
                <div class="accordion-content">
                  De forma alguma. <br>
                  O TEMCAR não se envolve nas negociações entre vendedores, compradores ou lojistas, não sendo:<br>

                  Parte<br>

                  Agente<br>

                  Procurador<br>

                  Responsável<br>

                  Representante<br>

                  A negociação é totalmente independente entre as partes.
                </div>
              </div>

              <div class="accordion-item">
                <div class="accordion-header">
                  <span class="icon">+</span>
                  <span class="title">4. Quem define condições como preço, forma de pagamento e entrega do
                    veículo?</span>
                  <span class="arrow">▶</span>
                </div>
                <div class="accordion-content">
                  Essas condições são definidas exclusivamente entre o anunciante e o interessado.<br>
                  Eles são responsáveis por ajustar:<br>

                  Preço<br>

                  Prazos<br>

                  Forma de pagamento<br>

                  Entrega<br>

                  Demais condições da negociação<br>
                </div>
              </div>

              <div class="accordion-item">
                <div class="accordion-header">
                  <span class="icon">+</span>
                  <span class="title">5. O TEMCAR participa da venda, transporte ou entrega do veículo?</span>
                  <span class="arrow">▶</span>
                </div>
                <div class="accordion-content">
                  Não.<br>
                  O TEMCAR não efetiva a venda nem atua em:<br>

                  Transporte<br>

                  Entrega<br>

                  Transferência de documentos<br>

                  Garantias legais ou contratuais<br>

                  Toda responsabilidade é do vendedor e do comprador.<br>
                </div>
              </div>

              <div class="accordion-item">
                <div class="accordion-header">
                  <span class="icon">+</span>
                  <span class="title">6. O TEMCAR oferece garantia sobre os veículos anunciados?</span>
                  <span class="arrow">▶</span>
                </div>
                <div class="accordion-content">
                  Não. <br>
                  O TEMCAR não oferece qualquer tipo de garantia, incluindo:<br>

                  Existência<br>

                  Qualidade<br>

                  Quantidade<br>

                  Características técnicas<br>

                  Segurança<br>

                  Fabricação e montagem<br>

                  Idoneidade do anunciante<br>
                  As partes devem realizar suas próprias verificações.
                </div>
              </div>

              <div class="accordion-item">
                <div class="accordion-header">
                  <span class="icon">+</span>
                  <span class="title">7. O TEMCAR se responsabiliza por erros nos anúncios?</span>
                  <span class="arrow">▶</span>
                </div>
                <div class="accordion-content">
                  Não. <br>
                  Todos os dados preenchidos no anúncio são de responsabilidade exclusiva do anunciante, inclusive erros
                  de digitação.
                </div>
              </div>

              <div class="accordion-item">
                <div class="accordion-header">
                  <span class="icon">+</span>
                  <span class="title">8. É seguro pagar sem ver o veículo?</span>
                  <span class="arrow">▶</span>
                </div>
                <div class="accordion-content">
                  Recomendamos fortemente que NÃO. <br>
                  Antes de realizar qualquer pagamento:<br>

                  Veja o veículo pessoalmente.<br>

                  Solicite uma vistoria cautelar em uma empresa especializada.<br>

                  Desconfie de preços muito abaixo da média do mercado.
                </div>
              </div>
            </div>

            <script>
              const items = document.querySelectorAll(".accordion-item");

              items.forEach(item => {
                const header = item.querySelector(".accordion-header");
                const icon = item.querySelector(".icon");

                header.addEventListener("click", () => {

                  const isActive = item.classList.contains("active");

                  // fecha todos
                  items.forEach(i => {
                    i.classList.remove("active");
                    i.querySelector(".icon").textContent = "+";
                  });

                  // abre o clicado
                  if (!isActive) {
                    item.classList.add("active");
                    icon.textContent = "-";
                  }
                });
              });
            </script>
          </div>

          <!-- COLUNA DIREITA -->
          <div class="image">
            <img src="./../icones/img-regras-gerais.jpeg" style="max-width: 400px;" alt="Imagem exemplo">
          </div>

        </section>

      </div>

      <script>
        const headers = document.querySelectorAll(".accordion-header");

        headers.forEach(header => {
          header.addEventListener("click", () => {
            const content = header.nextElementSibling;

            content.style.display =
              content.style.display === "block" ? "none" : "block";
          });
        });
      </script>
    </main>

    <script>
      async function carregarRegrasGerais() {
        try {
          const res = await fetch('/api/admin/regras-gerais');
          const blocos = await res.json();

          const container = document.getElementById('regrasGeraisContainer');

          if (!blocos.length) {
            container.innerHTML = '<p class="text-muted">Conteúdo em breve.</p>';
            return;
          }

          container.innerHTML = blocos.map(b => `
      <div class="mb-5">
        ${b.titulo ? `<h2>${b.titulo}</h2>` : ''}
        ${b.subtitulo ? `<h5 class="text-muted">${b.subtitulo}</h5>` : ''}
        <p>${formatarTexto(b.texto)}</p>
      </div>
    `).join('');

        } catch (erro) {
          console.error(erro);
          regrasGeraisContainer.innerHTML = '<p class="text-danger">Erro ao carregar conteúdo.</p>';
        }
      }

      function formatarTexto(texto) {
        return texto ? texto.replace(/\n/g, '<br>') : '';
      }

      carregarRegrasGerais();
    </script>
    <%- include('./reutilizavel/footer-public') %>
</body>

</html>
<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('reutilizavel/seo-head', { seo: typeof seo !== 'undefined' ? seo : {} }) %>
    <%- include('reutilizavel/jsonld-breadcrumb', { breadcrumbs: typeof breadcrumbs !== 'undefined' ? breadcrumbs : [] }) %>
    <script src="/js/site-config.js" defer></script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/revenda.css">

    <style>
        /* ── HERO BANNER ── */
        .revendas-hero {
            background: linear-gradient(to right, #C90B0C, #a53c3c);
            color: #fff;
            padding: 24px 20px 20px;
        }

        .revendas-hero .breadcrumb-link {
            color: #fff;
            text-decoration: none;
            font-weight: 700;
            letter-spacing: .5px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .revendas-hero h1 {
            font-size: clamp(1.6rem, 4vw, 2.2rem);
            font-weight: 700;
            margin: 10px 0 0;
        }

        .revendas-hero h1 span {
            text-decoration: underline;
            text-decoration-thickness: 6px;
            text-underline-offset: 8px;
        }

        /* ── FILTRO ── */
        .filtro-revendas {
            max-width: 1200px;
            margin: 20px auto;
            padding: 20px;
            background: #f8f8f8;
            border-radius: 10px;
            border: 1px solid #e1e1e1;
        }

        .filtro-revendas form {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .filtro-revendas select {
            flex: 1 1 200px;
            padding: 10px 12px;
            font-size: 14px;
            border-radius: 6px;
            border: 1px solid #ccc;
            background: #fff;
        }

        .filtro-revendas select:focus {
            outline: none;
            border-color: #C90B0C;
            box-shadow: 0 0 0 2px rgba(201,11,12,.15);
        }

        .btn-buscar {
            padding: 10px 24px;
            background: #C90B0C;
            color: #fff;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 700;
            transition: opacity .2s;
        }

        .btn-buscar:hover { opacity: .88; }

        @media (max-width: 600px) {
            .btn-buscar { width: 100%; }
        }

        /* ── CARDS GRID ── */
        .revendas-section {
            max-width: 1200px;
            margin: 0 auto;
            padding: 10px 20px 40px;
        }

        .cards-container {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 16px;
        }

        @media (max-width: 992px) {
            .cards-container { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }

        @media (max-width: 600px) {
            .cards-container { grid-template-columns: 1fr; }
        }

        /* ── CARD REVENDA ── */
        .revenda-card {
            display: flex;
            gap: 15px;
            background: #fff;
            border-radius: 10px;
            border: 1px solid #e1e1e1;
            padding: 16px;
            align-items: center;
            box-shadow: 0 4px 10px rgba(0,0,0,.06);
            transition: transform .2s ease, box-shadow .2s ease;
            cursor: pointer;
        }

        .revenda-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 18px rgba(0,0,0,.12);
        }

        .revenda-logo {
            width: 110px;
            max-width: 35%;
            height: 90px;
            object-fit: contain;
            border-radius: 8px;
            border: 1px solid #eee;
            flex-shrink: 0;
        }

        .revenda-info { flex: 1; min-width: 0; }

        .revenda-info h3 {
            font-size: 1.1rem;
            font-weight: 700;
            margin: 0 0 4px;
            color: #1f2328;
        }

        .revenda-info .local {
            font-size: .88rem;
            color: #666;
            margin-bottom: 10px;
        }

        .ver-estoque {
            display: inline-flex;
            align-items: center;
            padding: 7px 14px;
            background: #C90B0C;
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: .85rem;
            font-weight: 700;
            cursor: pointer;
            transition: background .2s, transform .2s;
        }

        .ver-estoque:hover {
            background: #a80809;
            transform: translateY(-1px);
        }

        @media (max-width: 600px) {
            .revenda-card { flex-direction: column; align-items: flex-start; }
            .revenda-logo { width: 100%; max-width: 100%; height: 180px; object-fit: contain; }
        }

        /* ── EMPTY STATE ── */
        .cidade-empty-state {
            grid-column: 1 / -1;
            border: 1px solid rgba(201,11,12,.18);
            border-radius: 8px;
            background: linear-gradient(135deg, rgba(201,11,12,.08), rgba(255,255,255,0) 55%), #fff;
            padding: 32px;
            text-align: center;
            box-shadow: 0 8px 24px rgba(0,0,0,.06);
        }

        .cidade-empty-icon {
            width: 56px; height: 56px;
            border-radius: 50%;
            display: inline-flex; align-items: center; justify-content: center;
            background: #C90B0C; color: #fff;
            font-size: 1.6rem; margin-bottom: 16px;
        }

        .cidade-empty-title { color: #222; font-size: 1.15rem; margin-bottom: 12px; }
        .cidade-empty-promo { color: #444; font-size: .95rem; margin-bottom: 20px; }
        .cidade-empty-promo strong { color: #C90B0C; }

        .cidade-empty-actions { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }
        .cidade-empty-actions .btn { border-radius: 6px; font-weight: 700; padding: 10px 18px; }
    </style>
</head>

<body>
    <%- include('./reutilizavel/header-public') %>

    <!-- HERO -->
    <section class="revendas-hero">
        <nav class="d-flex align-items-center gap-2 small mb-2">
            <a href="/" class="breadcrumb-link">
                <i class="bi bi-house-fill"></i> Início
            </a>
            <i class="bi bi-chevron-right" style="font-size:.75rem;opacity:.7;"></i>
            <a href="/buscar-revendas" class="breadcrumb-link">Revendas</a>
        </nav>
        <h1 id="titulo-revendas-hero"><span>Encontre</span> uma revenda</h1>
    </section>

    <!-- FILTRO -->
    <section class="filtro-revendas">
        <h2 id="titulo-revendas" class="fw-bold mb-3" style="font-size:1.25rem;color:#1f2328;">Revendas Parceiras</h2>
        <form id="filtro-form">
            <select id="select-revenda">
                <option value="">Busque pelo nome</option>
            </select>
            <select id="select-cidadeRevenda">
                <option value="">Filtre por cidade</option>
            </select>
            <button type="submit" class="btn-buscar">
                <i class="bi bi-search me-1"></i> Buscar
            </button>
        </form>
    </section>

    <!-- CARDS + PAGINAÇÃO -->
    <section class="revendas-section">
        <div id="cards-container" class="cards-container"></div>

        <nav class="mt-4">
            <ul class="pagination justify-content-center" id="paginacao"></ul>
        </nav>
    </section>

    <%- include('./reutilizavel/footer-public') %>

    <script>
        window.FILTRO = <%- JSON.stringify(typeof filtro !== 'undefined' ? filtro : {}) %>;
    </script>
    <script src="/js/buscar-revendas.js?v=5"></script>
</body>

</html>

<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('reutilizavel/seo-head', { seo: typeof seo !== 'undefined' ? seo : {} }) %>
    <%- include('reutilizavel/jsonld-breadcrumb', { breadcrumbs: typeof breadcrumbs !== 'undefined' ? breadcrumbs : [] }) %>
    <script src="/js/site-config.js" defer></script>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<style>
    .revendas-section {
        max-width: 1200px;
        margin: 0 auto;
        padding: 10px 20px;
        font-family: Arial, sans-serif;
    }

    .revendas-section h2 {
        margin-bottom: 24px;
    }

    .cards-container {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 20px;
    }

    .titulo-regiao {
        width: 100%;
    }

    .revenda-card {
        width: 100%;
        display: flex;
        gap: 16px;
        padding: 20px;
        border: 1px solid #e1e1e1;
        border-radius: 10px;
        background: #fff;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.06);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .revenda-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
    }
/* 
    .revenda-logo {
        width: 180px;
        height: 180px;
        border-radius: 8px;
        object-fit: cover;
        border: 1px solid #ddd;
        background: #fafafa;
    } */

    .revenda-info {
        flex: 1;
    }

    .revenda-info h3 {
        font-size: 22px;
        margin: 0 0 6px;
    }

    .revenda-info .local {
        font-size: 16px;
        color: #666;
        margin-bottom: 8px;
    }

    /* descrição limitada a 3 linhas */
    .revenda-info .descricao {
        font-size: 16px;
        color: #444;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 10px;
    }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 14px;
        margin-top: 30px;
    }

    .pagination button {
        padding: 8px 16px;
        cursor: pointer;
    }

    .pagination button:disabled {
        opacity: 0.5;
        cursor: default;
    }
</style>

<style>
    .filtro-revendas {
        max-width: 1200px;
        margin: 20px auto 20px;
        padding: 20px;
        background: #f8f8f8;
        border-radius: 10px;
        border: 1px solid #e1e1e1;
    }

    .filtro-revendas form {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .filtro-revendas select {
        flex: 1 1 200px;
        padding: 10px 12px;
        font-size: 14px;
        border-radius: 6px;
        border: 1px solid #ccc;
        background: #fff;
    }

    .filtro-revendas select:focus {
        outline: none;
        border-color: #C90B0C;
    }

    .btn-buscar {
        padding: 10px 20px;
        background: #C90B0C;
        color: #fff;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: bold;
    }

    .btn-buscar:hover {
        opacity: 0.9;
    }

    /* mobile */
    @media (max-width: 600px) {
        .btn-buscar {
            width: 100%;
        }
    }
</style>

<style>
    * {
        margin: 0;
        padding: 0;
    }

    /* PRIMEIRA PARTE */

    .revendas-section {
        max-width: 1200px;
        margin: 0 auto;
        padding: 10px 20px;
        font-family: Arial, sans-serif;
    }

    .revendas-section h2 {
        margin-bottom: 24px;
    }

    .cards-container {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
    }

    .titulo-regiao {
        width: 100%;
    }

    .revenda-card {
        display: flex;
        gap: 15px;
        background: white;
        border-radius: 10px;
        padding: 12px;
        align-items: center;
        width: 100%;
        max-width: none;
    }

    /* IMAGEM */
    .revenda-logo {
        width: 150px;
        max-width: 45%;
        height: auto;
        object-fit: contain;
        border-radius: 8px;
        border: 2px solid white;
        display: block;
        margin: 0 auto;
    }

    /* INFO */
    .revenda-info {
        flex: 1;
    }

    .ver-estoque {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 34px;
        padding: 7px 14px;
        background: #C90B0C;
        color: #fff;
        border: 1px solid #C90B0C;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 700;
        line-height: 1;
        cursor: pointer;
        transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    }

    .ver-estoque:hover {
        background: #a80809;
        border-color: #a80809;
        transform: translateY(-1px);
    }

    /* MOBILE */
    @media (max-width: 992px) {
        .cards-container {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 768px) {
        .cards-container {
            grid-template-columns: 1fr;
        }

        .revenda-card {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
        }

        .revenda-logo {
            width: 100%;
            max-width: 100%;
            height: 220px;
            object-fit: contain;
        }

        .revenda-info {
            width: 100%;
        }

        .revenda-card .revenda-info h3 {
            margin: 2px 0 6px;
        }
    }

    .revenda-info h3 {
        font-size: 22px;
        margin: 0 0 6px;
    }

    .revenda-info .local {
        font-size: 16px;
        color: #666;
        margin-bottom: 8px;
    }

    /* descrição limitada a 3 linhas */
    .revenda-info .descricao {
        font-size: 16px;
        color: #444;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 10px;
    }

    .cidade-empty-state {
        width: 100%;
        border: 1px solid rgba(201, 11, 12, 0.18);
        border-radius: 8px;
        background:
            linear-gradient(135deg, rgba(201, 11, 12, 0.08), rgba(255, 255, 255, 0) 55%),
            #fff;
        padding: 32px;
        text-align: center;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    }

    .cidade-empty-icon {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #C90B0C;
        color: #fff;
        font-size: 1.6rem;
        margin-bottom: 16px;
    }

    .cidade-empty-title {
        color: #222;
        font-size: 1.25rem;
        line-height: 1.35;
        margin-bottom: 14px;
    }

    .cidade-empty-promo {
        color: #444;
        font-size: 1rem;
        margin-bottom: 22px;
    }

    .cidade-empty-promo strong { color: #C90B0C; }

    .cidade-empty-actions {
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .cidade-empty-actions .btn {
        border-radius: 6px;
        font-weight: 700;
        padding: 10px 18px;
    }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 14px;
        margin-top: 30px;
    }

    .pagination button {
        padding: 8px 16px;
        cursor: pointer;
    }

    .pagination button:disabled {
        opacity: 0.5;
        cursor: default;
    }

    /* SEGUNDA PARTE */

    .filtro-revendas {
        max-width: 1200px;
        margin: 20px auto 20px;
        padding: 20px;
        background: #f8f8f8;
        border-radius: 10px;
        border: 1px solid #e1e1e1;
    }

    .filtro-revendas form {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .filtro-revendas select,
    .input_cidades {
        flex: 1 1 200px;
        padding: 10px 12px;
        font-size: 14px;
        border-radius: 6px;
        border: 1px solid #ccc;
        background: #fff;
    }

    .filtro-revendas select:focus {
        outline: none;
        border-color: #C90B0C;
    }

    .input_cidades:focus {
        outline: none;
        border-color: #C90B0C;
    }

    .btn-buscar {
        padding: 10px 20px;
        background: #C90B0C;
        color: #fff;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: bold;
    }

    .btn-buscar:hover {
        opacity: 0.9;
    }

    /* mobile */
    @media (max-width: 600px) {
        .btn-buscar {
            width: 100%;
        }
    }
</style>

<body>

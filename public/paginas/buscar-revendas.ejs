    </button>

</form>
        </section>

        <section class="revendas-section">

            <div id="cards-container" class="cards-container"></div>

            <div class="pagination">
                <button id="prev-btn">Anterior</button>
                <span id="page-info"></span>
                <button id="next-btn">Próximo</button>
            </div>
        </section>

        <%- include('./reutilizavel/footer-public') %>

            <script>
                window.FILTRO = <%- JSON.stringify(typeof filtro !== 'undefined' ? filtro : {}) %>;
            </script>
            <script src="/js/buscar-revendas.js?v=3"></script>

</body>

</html>

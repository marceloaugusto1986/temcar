<!-- SCRIPT DO COMPONENTE -->
<script>
(function () {
  const BASE = 'https://temcar.com.br/images/';

  const CARS = [
    { brand: 'Chevrolet',  model: 'Celta',   img: BASE + 'celta.jpg',   href: '/carros?marca=Celta'   },
    { brand: 'Toyota',     model: 'Corolla', img: BASE + 'corolla.jpg', href: '/carros?marca=Corolla' },
    { brand: 'Volkswagen', model: 'Gol',     img: BASE + 'gol.jpg',     href: '/carros?marca=Gol'     },
    { brand: 'Hyundai',    model: 'Hb20',    img: BASE + 'hb20.jpg',    href: '/carros?marca=HB20'    },
    { brand: 'Toyota',     model: 'Hilux',   img: BASE + 'hilux.jpg',   href: '/carros?marca=Hilux'   },
    { brand: 'Chevrolet',  model: 'Onix',    img: BASE + 'onix.jpg',    href: '/carros?marca=Onix'    },
    { brand: 'Fiat',       model: 'Palio',   img: BASE + 'palio.jpg',   href: '/carros?marca=Palio'   },
    { brand: 'Chevrolet',  model: 'S10',     img: BASE + 's10.jpg',     href: '/carros?marca=S10'     },
    { brand: 'Renault',    model: 'Sandero', img: BASE + 'sandero.jpg', href: '/carros?marca=Sandero' },
    { brand: 'Fiat',       model: 'Siena',   img: BASE + 'siena.jpg',   href: '/carros?marca=Siena'   },
    { brand: 'Fiat',       model: 'Strada',  img: BASE + 'strada.jpg',  href: '/carros?marca=Strada'  },
    { brand: 'Fiat',       model: 'Uno',     img: BASE + 'uno.jpg',     href: '/carros?marca=Uno'     },
  ];

  const track    = document.getElementById('cmbTrack');
  const viewport = document.getElementById('cmbViewport');

  /* ── Cria card ── */
  function makeCard(car) {
    const a = document.createElement('a');
    a.className = 'cmb-card';
    a.href = car.href;
    a.draggable = false;
    a.innerHTML = `<div class="cmb-img-wrap">
      <img src="${car.img}" alt="${car.brand} ${car.model}" loading="lazy" draggable="false">
    </div>`;
    return a;
  }

  /* Popula os cards e deixa a rolagem livre, sem snap nem autoplay. */
  CARS.forEach(car => track.appendChild(makeCard(car)));

  /* ── Mouse drag ── */
  let dragStartX = 0, dragStartScroll = 0, dragging = false, moved = false;

  track.addEventListener('mousedown', e => {
    dragging = true; moved = false;
    dragStartX = e.clientX;
    dragStartScroll = viewport.scrollLeft;
  });

  window.addEventListener('mousemove', e => {
    if (!dragging) return;
    const dx = e.clientX - dragStartX;
    if (Math.abs(dx) > 5) moved = true;
    viewport.scrollLeft = dragStartScroll - dx;
  });

  window.addEventListener('mouseup', e => {
    if (!dragging) return;
    dragging = false;
    if (moved) {
      e.preventDefault();
      track.querySelectorAll('a').forEach(a => {
        a._block = true; setTimeout(() => a._block = false, 60);
      });
    }
  });

  track.addEventListener('click', e => {
    const a = e.target.closest('a');
    if (a && a._block) e.preventDefault();
  }, true);

  /* ── Touch swipe ── */
  let touchStartX = 0, touchStartScroll = 0;

  track.addEventListener('touchstart', e => {
    touchStartX = e.touches[0].clientX;
    touchStartScroll = viewport.scrollLeft;
  }, { passive: true });

  track.addEventListener('touchmove', e => {
    const dx = e.touches[0].clientX - touchStartX;
    viewport.scrollLeft = touchStartScroll - dx;
  }, { passive: true });

  /* ── Cursor ── */
  viewport.style.cursor = 'grab';
  track.addEventListener('mousedown', () => viewport.style.cursor = 'grabbing');
  window.addEventListener('mouseup',  () => viewport.style.cursor = 'grab');

})();
</script>



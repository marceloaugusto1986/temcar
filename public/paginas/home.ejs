<!-- ESTILOS GERAIS DO SITE -->
<style>
	body {
		background-color: #f5f5f5 !important;
	}

	/* BOXES */
	.box-filtros {
		background: #fff;
		box-shadow: 2px 2px 2px 2px rgba(95, 93, 93, 0.185);
		border-radius: 10px;
	}

	.custom-box {
		background: #fff;
		border-radius: 8px;
		box-shadow: 0 4px 12px rgba(0, 0, 0, .12);
		padding: 18px;
	}

	.box-limit {
		max-height: 380px;
		overflow: hidden;
	}

	/* BANNER */
	.bannerSwiper {
		width: 100%;
		max-width: 100vw;
		height: clamp(190px, 24vw, 250px);
		overflow: hidden;
	}

	.bannerSwiper .swiper-slide {
		width: 100%;
		height: 100%;
		overflow: hidden;
	}

	.bannerSwiper .swiper-wrapper {
		height: 100%;
	}

	.bannerSwiper a,
	.bannerSwiper picture {
		display: block;
		width: 100%;
		height: 100%;
	}

	.bannerSwiper img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	/* MOBILE BANNER */

	@media(max-width:767px) {
		.bannerSwiper {
			height: auto;
			background: #C90B0C;
		}

		.bannerSwiper .swiper-wrapper,
		.bannerSwiper .swiper-slide,
		.bannerSwiper a,
		.bannerSwiper picture {
			height: auto;
		}

		.bannerSwiper img {
			height: auto;
			object-fit: contain;
		}

	}

	/* CARDS */
	.card img {
		height: 250px;
	}

	.vehicle-card {
		max-width: 320px;
		border-radius: 6px;
	}

	.vehicle-img {
		height: 180px;
		object-fit: cover;
	}

	/* SCROLL HORIZONTAL */
	.scroll-horizontal {
		overflow-x: auto;
		white-space: nowrap;
	}

	.scroll-horizontal::-webkit-scrollbar {
		height: 6px;
	}

	.scroll-horizontal::-webkit-scrollbar-thumb {
		background: #C90B0C;
		border-radius: 4px;
	}

	/* RESPONSIVO */
	@media (max-width: 576px) {


		.vehicle-card {
			max-width: 100%;
		}

		.vehicle-img {
			height: 200px;
		}
	}
</style>

<style>
	.descricao-card {
		display: -webkit-box;
		-webkit-line-clamp: 1;
		/* número de linhas */
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.vehicle-card {
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		width: 280px;
	}

	.vehicle-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 6px 18px rgba(0, 0, 0, 0.15);
	}

	.badge-status {
		position: absolute;
		top: 10px;
		left: 10px;
		z-index: 10;
	}

	.home-models-section {
		position: relative;
		overflow: hidden;
		background:
			linear-gradient(135deg, rgba(201, 11, 12, .24) 0%, rgba(201, 11, 12, .12) 34%, rgba(255, 255, 255, 0) 62%),
			linear-gradient(180deg, #fff6f6 0%, #f3f4f6 100%);
		border: 1px solid rgba(15, 23, 42, .07);
		border-radius: 8px;
		padding: 24px;
		box-shadow: none !important;
	}

	.home-models-section::after {
		content: "";
		position: absolute;
		right: 24px;
		top: 18px;
		width: min(420px, 48%);
		height: 8px;
		border-radius: 999px;
		background: linear-gradient(90deg, rgba(201, 11, 12, .5), rgba(201, 11, 12, .08));
		pointer-events: none;
	}

	.home-models-section > * {
		position: relative;
		z-index: 1;
	}

	.home-models-eyebrow {
		width: 78px;
		height: 8px;
		border-radius: 999px;
		background: #C90B0C;
		margin-bottom: 10px;
	}

	.home-models-title {
		color: #151515;
		font-size: 1.65rem;
		font-weight: 800;
		margin-bottom: 22px;
	}

	.home-models-list {
		display: grid;
		grid-auto-flow: column;
		grid-auto-columns: minmax(260px, 320px);
		gap: 18px;
		overflow-x: auto;
		padding-bottom: 8px;
		scroll-snap-type: x mandatory;
	}

	.home-models-list.swiper-wrapper {
		display: flex;
		gap: 0;
		overflow: visible;
		padding-bottom: 0;
		scroll-snap-type: none;
	}

	.home-models-list .swiper-slide {
		width: 320px;
		height: auto;
	}

	.home-model-card {
		min-height: 285px;
		border-radius: 26px;
		background: #fff;
		color: #151515;
		text-decoration: none;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		scroll-snap-align: start;
		position: relative;
		transition: transform .2s ease, box-shadow .2s ease;
	}

	.home-model-card::before {
		content: "";
		position: absolute;
		top: 20px;
		left: 0;
		width: 34px;
		height: 6px;
		border-radius: 0 999px 999px 0;
		background: #C90B0C;
	}

	.home-model-card:hover {
		color: #151515;
		transform: translateY(-4px);
		box-shadow: 0 14px 28px rgba(0, 0, 0, .14);
	}

	.home-model-info {
		padding: 26px 26px 8px;
	}

	.home-model-brand {
		display: block;
		font-size: .95rem;
		text-transform: uppercase;
		letter-spacing: .04em;
		color: #555;
	}

	.home-model-name {
		display: block;
		font-size: 1.6rem;
		line-height: 1.1;
		font-weight: 800;
		color: #151515;
	}

	.home-model-meta {
		display: block;
		margin-top: 8px;
		color: #C90B0C;
		font-weight: 700;
		font-size: .92rem;
	}

	.home-model-card img {
		width: 100%;
		height: 160px;
		object-fit: contain;
		margin-top: auto;
		padding: 6px 18px 18px;
	}

	@media (max-width: 576px) {
		.home-models-section {
			padding: 18px;
		}

		.home-models-list {
			grid-auto-columns: 82%;
		}

		.home-models-list .swiper-slide {
			width: 82%;
		}
	}
</style>


						<script>
							let swiperCidade = null;

							async function carregarSliderCidade(cidade) {
								try {
									const res = await fetch(`/api/admin/regioes/imagens?cidade=${encodeURIComponent(cidade)}`);
									const imagens = await res.json();

									const wrapper = document.getElementById("bannerWrapperCidade");
									wrapper.innerHTML = "";

									if (!imagens.length) return false; // 🔴 não tem imagens

									imagens.forEach(img => {
										const slide = document.createElement("div");
										slide.classList.add("swiper-slide");

										const picture = document.createElement("picture");
										const sourceMobile = document.createElement("source");
										const imagemDesktop = "/uploads/anuncios/" + img.imagem;
										const imagemMobile = "/uploads/anuncios/" + (img.imagem_mobile || img.imagem);

										sourceMobile.media = "(max-width: 768px)";
										sourceMobile.srcset = imagemMobile;
										picture.appendChild(sourceMobile);

										const imagem = document.createElement("img");
										imagem.src = imagemDesktop;
										imagem.className = "img-cidade";
										imagem.alt = "Banner da cidade";
										imagem.loading = "lazy";
										picture.appendChild(imagem);

										const container = document.createElement("div");
										container.className = "container-img-cidade";
										container.appendChild(picture);
										slide.appendChild(container);

										wrapper.appendChild(slide);
									});

									/* 🔁 recriar swiper */
									if (swiperCidade) swiperCidade.destroy(true, true);

									swiperCidade = new Swiper("#sliderCidade", {
										loop: true,

							autoplay: {
								delay: 2800,
								disableOnInteraction: false
							},

										effect: "fade",
										fadeEffect: {
											crossFade: true
										},

										speed: 1000
									});

									return true; // 🔥 tem imagens

								} catch (err) {
									console.error("Erro ao carregar slider da cidade:", err);
									return false;
								}
							}


							async function atualizarSliderPorCidade(cidade) {
								const sliderPadrao = document.getElementById("sliderPadrao");
								const sliderCidade = document.getElementById("sliderCidade");

								if (!cidade) {
									sliderPadrao.classList.remove("d-none");
									sliderCidade.classList.add("d-none");
									return;
								}

								const temImagens = await carregarSliderCidade(cidade);

								if (temImagens) {
									sliderPadrao.classList.add("d-none");
									sliderCidade.classList.remove("d-none");
								} else {
									sliderPadrao.classList.remove("d-none");
									sliderCidade.classList.add("d-none");
								}
							}
						</script>


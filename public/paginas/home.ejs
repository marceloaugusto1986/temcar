						<script>

							function toggleFiltros() {
								const filtros = document.getElementById("filtros");

								if (filtros.style.display === "grid") {
									filtros.style.display = "none";
								} else {
									filtros.style.display = "grid";
								}
							}

							/* botão categoria ativo */

							document.querySelectorAll(".categorias button").forEach(btn => {
								btn.addEventListener("click", function () {
									// troca botão ativo
									document.querySelectorAll(".categorias button")
										.forEach(b => b.classList.remove("active"))

									this.classList.add("active")

									// pega o tipo do botão clicado
									const tipoSelecionado = this.dataset.tipo

									// aplica o filtro
									aplicarFiltroTipoCarro(tipoSelecionado)
								})
							})

							function normalizarTipoBusca(valor) {
								return String(valor || "")
									.toLowerCase()
									.normalize("NFD")
									.replace(/[\u0300-\u036f]/g, "")
							}

							function atualizarTituloDestaques(tipo) {
								const titulo = document.getElementById("tituloDestaques")
								if (!titulo) return

								const titulos = {
									carro: "Carros em Destaque",
									moto: "Motos em Destaque",
									utilitario: "Utilitários em Destaque"
								}

								titulo.textContent = titulos[normalizarTipoBusca(tipo)] || "Veículos em Destaque"
							}

							function obterTipoSelecionado(tipo) {
								return tipo || document.querySelector(".categorias button.active")?.dataset.tipo || "carro"
							}

							function existeFiltroHomeAtivo() {
								const busca = document.getElementById("barraBuscaMarcaModelo")?.value.trim()
								const cidade = document.getElementById("selectCidadeFilter")?.value
								const revenda = document.getElementById("selectRevendaFilter")?.value
								const tipoSelect = document.getElementById("filtroTipo")?.value
								const marca = document.getElementById("filtroMarca")?.value
								const modelo = document.getElementById("filtroModelo")?.value

								return Boolean(busca || cidade || revenda || tipoSelect || marca || modelo)
							}

							function aplicarFiltroTipoCarro(tipo) {
								const tipoSelecionado = obterTipoSelecionado(tipo)
								let listaFiltrada = existeFiltroHomeAtivo() ? todosItensOriginais : itensOriginais

								if (tipoSelecionado) {
									listaFiltrada = listaFiltrada.filter(item =>
										normalizarTipoBusca(item.tipo_carro || item.tipo_automovel || item.tipo) ===
										normalizarTipoBusca(tipoSelecionado)
									)
								}

								itens = listaFiltrada // 🔥 atualiza lista global
								atualizarTituloDestaques(tipoSelecionado)

								paginaAtual = 1
								renderizarCards()
								renderizarPaginacao()
							}

						</script>

						<!-- Banner -->
						<script>

							let swiper = null;

							async function carregarBannerHome() {

								try {

									const resposta = await fetch("/api/admin/home/carrossel");
									const slides = await resposta.json();

									const wrapper = document.getElementById("bannerWrapper");
									wrapper.innerHTML = "";

									const slidesAtivos = slides
										.filter(s => s.ativo)
										.sort((a, b) => a.ordem - b.ordem);

									slidesAtivos.forEach(slide => {

										const slideDiv = document.createElement("div");
										slideDiv.className = "swiper-slide";

										const picture = document.createElement("picture");
										const sourceMobile = document.createElement("source");
										const img = document.createElement("img");

										sourceMobile.media = "(max-width: 768px)";
										sourceMobile.srcset = "/uploads/anuncios/" + (slide.imagem_mobile || slide.imagem);
										picture.appendChild(sourceMobile);

										img.src = "/uploads/anuncios/" + slide.imagem;
										img.loading = "lazy";
										img.alt = "Banner";
										picture.appendChild(img);

										if (slide.link) {

											const link = document.createElement("a");
											link.href = slide.link;
											link.appendChild(picture);
											slideDiv.appendChild(link);

										} else {

											slideDiv.appendChild(picture);

										}

										wrapper.appendChild(slideDiv);

									});

									iniciarSwiper();

								} catch (erro) {

									console.error("Erro ao carregar banner:", erro);

								}

							}

							function iniciarSwiper() {

								if (swiper) {
									swiper.destroy(true, true);
								}

								swiper = new Swiper("#sliderPadrao", {

									loop: true,
									initialSlide: 0,
									slidesPerView: 1,
									spaceBetween: 0,
									speed: 800,
									effect: "fade",
									fadeEffect: {
										crossFade: true
									},

						autoplay: {
							delay: 2800,
							disableOnInteraction: false,
							pauseOnMouseEnter: true
						},

									on: {

										init: function () {

											// força começar do primeiro slide real
											this.slideToLoop(0, 0);

										},

										touchEnd: function () {

											this.autoplay.start();

										}

									}

								});

							}

							document.addEventListener("DOMContentLoaded", carregarBannerHome);

						</script>

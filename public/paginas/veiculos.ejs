<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('reutilizavel/seo-head', { seo: typeof seo !=='undefined' ? seo : {} }) %>
        <%- include('reutilizavel/jsonld-breadcrumb', { breadcrumbs: typeof breadcrumbs !=='undefined' ? breadcrumbs :
            [] }) %>
            <script src="/js/site-config.js" defer></script>

            <!-- Bootstrap 5 -->
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
            <!-- Swiper -->
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
</head>

<style>
    .descricao-card {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .bannerSwiper {
        width: 100%;
    }

    .bannerSwiper .swiper-slide {
        width: 60%;
    }

    .bannerSwiper img {
        width: 100%;
        height: 350px;
        object-fit: cover;
        border-radius: 8px;
    }

    .bannerSwiper .swiper-slide a {
        display: block;
    }

    @media(max-width:767px) {
        .bannerSwiper .swiper-slide {
            width: 100%;
        }

        .bannerSwiper img {
            height: 200px;
        }
    }

    .veiculos-banner {
        background: linear-gradient(135deg, #C90B0C 0%, #8B0000 100%);
        padding: 40px 0;
    }

    .veiculos-empty-heading {
        color: #C90B0C;
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 24px;
    }

    .veiculos-empty-state {
        width: 100%;
        border: 1px solid rgba(201, 11, 12, 0.22);
        border-radius: 8px;
        background:
            linear-gradient(135deg, rgba(201, 11, 12, 0.08), rgba(255, 255, 255, 0) 55%),
            #fff;
        padding: 32px;
        text-align: center;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    }

    .veiculos-empty-icon {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #C90B0C;
        color: #fff;
        font-size: 1.6rem;
        margin-bottom: 16px;
    }

    .veiculos-empty-title {
        color: #222;
        font-size: 1.25rem;
        line-height: 1.35;
        margin-bottom: 14px;
    }

    .veiculos-empty-promo {
        color: #444;
        font-size: 1rem;
        margin-bottom: 22px;
    }

    .veiculos-empty-promo strong {
        color: #C90B0C;
    }

    .veiculos-empty-actions {
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .veiculos-empty-actions .btn {
        border-radius: 6px;
        font-weight: 700;
        padding: 10px 18px;
    }

    @media(max-width:576px) {
        .veiculos-empty-heading {
            font-size: 1.35rem;
            margin-bottom: 18px;
        }

        .veiculos-empty-state {
            padding: 24px 18px;
        }
    }
</style>

<body>
    <%- include('./reutilizavel/header-public') %>

        <% if (typeof seo !=='undefined' && seo.texto_h1) { %>
            <h1 class="visually-hidden">
                <%= seo.texto_h1 %>
            </h1>
            <% } else { %>
                <h1 class="visually-hidden">Veículos à Venda - TEMCAR</h1>
                <% } %>

                    <!-- Banner Slider -->
                    <div class="swiper bannerSwiper d-none" id="bannerSlider">
                        <div class="swiper-wrapper" id="bannerWrapper"></div>
                        <div class="swiper-button-next" style="color:#C90B0C;"></div>
                        <div class="swiper-button-prev" style="color:#C90B0C;"></div>
                    </div>

                    <!-- Banner fallback -->
                    <section class="veiculos-banner text-white text-center" id="bannerFallback">
                        <div class="container">
                            <h2 class="fw-bold mb-2" id="titulo-pagina"></h2>
                            <p class="mb-0" id="subtitulo-pagina"></p>
                        </div>
                    </section>

                    <!-- Conteúdo -->
                    <section class="container my-5" style="min-height: 80vh !important;">
                        <div class="bg-white p-3 rounded">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h4 id="titulo-resultados" class="fw-bold mb-0" style="color:#C90B0C;"></h4>
                                <span id="total-resultados" class="text-muted"></span>
                            </div>

                            <div id="loading" class="text-center py-5">
                                <div class="spinner-border text-danger" role="status">
                                    <span class="visually-hidden">Carregando...</span>
                                </div>
                            </div>

                            <div id="container-card-primary" class="row g-3"></div>

                            <nav class="mt-4">
                                <ul class="pagination justify-content-center" id="paginacao"></ul>
                            </nav>
                        </div>
                    </section>

                    <!-- Filtro passado pelo servidor (inclui bairro agora) -->
                    <script>
                        window.FILTRO = <%- JSON.stringify(typeof filtro !== 'undefined' ? filtro : {}) %>;
                        window.SEO_PAGINA = <%- JSON.stringify(typeof seo !== 'undefined' ? seo : {}) %>;
                    </script>
                    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
                    <script src="/js/veiculos.js?v=14"></script>

                    <%- include('./reutilizavel/footer-public') %>
</body>

</html>

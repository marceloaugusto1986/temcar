<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <%- include('reutilizavel/seo-head', { seo: typeof seo !=='undefined' ? seo : {} }) %>
        <%- include('reutilizavel/jsonld-breadcrumb', { breadcrumbs: typeof breadcrumbs !=='undefined' ? breadcrumbs :
            [] }) %>
            <%- include('reutilizavel/jsonld-vehicle', { vehicleSchema: typeof vehicleSchema !=='undefined' ? vehicleSchema : null }) %>
            <meta name="viewport" content="width=device-width, initial-scale=1">
            <script src="/js/site-config.js" defer></script>

            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
            <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</head>

<style>
    /* MENU DE APROVAR OU RECUSAR ANÚNCIO */
    .admin-action-bar {
        width: 100%;
        z-index: 999;
        background: #ffffff;
        padding: 12px 20px;
        display: flex;
        justify-content: center;
        gap: 15px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .venda-aviso {
        max-width: 1200px;
        margin: 0 auto;
        color: #2d3035;
        font-size: 0.9rem;
        line-height: 1.65;
    }

    .venda-aviso--desktop {
        margin-top: 48px;
    }

    .venda-aviso--mobile {
        padding: 0 12px;
    }

    .venda-seguranca {
        max-width: 1200px;
        margin: 16px auto 0;
        background: #fff8e1;
        border: 1px solid #ffe082;
        border-radius: 8px;
        padding: 16px 20px;
        font-size: 0.875rem;
        color: #2d3035;
    }

    .venda-seguranca--mobile {
        margin: 12px 12px 0;
    }

    .venda-seguranca__titulo {
        font-weight: 700;
        color: #b45309;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .venda-seguranca__lista {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .venda-seguranca__lista li {
        display: flex;
        gap: 8px;
        line-height: 1.5;
    }

    .venda-seguranca__lista li::before {
        content: "•";
        color: #b45309;
        font-weight: 700;
        flex-shrink: 0;
    }
</style>

<body class="bg-light">
    <%- include('./reutilizavel/header-public') %>

        <% if (typeof seo !=='undefined' && seo.texto_h1) { %>
            <h1 class="visually-hidden">
                <%= seo.texto_h1 %>
            </h1>
            <% } else { %>
                <h1 class="visually-hidden">Detalhes do Veículo à Venda - TEMCAR</h1>
                <% } %>

                    <section id="adminActionBar" class="admin-action-bar d-none">
                        <button class="btn btn-success" id="btnAprovar">
                            Aprovar anúncio
                        </button>

                        <button class="btn btn-danger" id="btnReprovar">
                            Reprovar anúncio
                        </button>

                        <button class="btn btn-primary" id="btnEditarAnuncio">
                            Editar anúncio
                        </button>
                    </section>

                    <section id="adminEditSection" class="container my-4 d-none">
                        <form id="form-editar-anuncio-admin" enctype="multipart/form-data"
                            class="bg-white shadow-sm rounded p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h2 class="h5 m-0">Editar anúncio</h2>
                                <button type="button" class="btn btn-outline-secondary btn-sm"
                                    id="btnCancelarEdicaoAdmin">
                                    Cancelar
                                </button>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label">Tipo</label>
                                    <select class="form-select" name="tipo" required>
                                        <option value="">Selecione</option>
                                        <option>Carro</option>
                                        <option>Moto</option>
                                        <option>Caminhão</option>
                                        <option>Ônibus</option>
                                        <option>Van</option>
                                        <option>Utilitário</option>
                                        <option>Pickup</option>
                                        <option>SUV</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Marca</label>
                                    <select class="form-select" name="marca" required>
                                        <option value="">Selecione</option>
                                        <option>Chevrolet</option>
                                        <option>Volkswagen</option>
                                        <option>Fiat</option>
                                        <option>Ford</option>
                                        <option>Honda</option>
                                        <option>Toyota</option>
                                        <option>Hyundai</option>
                                        <option>Renault</option>
                                        <option>Nissan</option>
                                        <option>BMW</option>
                                        <option>Mercedes-Benz</option>
                                        <option>Audi</option>
                                        <option>Jeep</option>
                                        <option>Kia</option>
                                        <option>Peugeot</option>
                                        <option>Citroën</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Versão / Modelo</label>
                                    <input type="text" class="form-control" name="versao" required>
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label">Ano Fabricação</label>
                                    <input type="number" class="form-control" name="ano_fabricacao" required>
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label">Ano Modelo</label>
                                    <input type="number" class="form-control" name="ano_modelo" required>
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label">KM</label>
                                    <input type="number" class="form-control" name="km" required>
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label">Condição</label>
                                    <select class="form-select" name="condicao">
                                        <option>Novo</option>
                                        <option>Usado</option>
                                        <option>Seminovo</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Câmbio</label>
                                    <select class="form-select" name="cambio">
                                        <option>Manual</option>
                                        <option>Automático</option>
                                        <option>Automático CVT</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Motorização</label>
                                    <select class="form-select" name="motorizacao">
                                        <option>1.0</option>
                                        <option>1.3</option>
                                        <option>1.6</option>
                                        <option>2.0</option>
                                        <option>Elétrico</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Portas</label>
                                    <select class="form-select" name="portas">
                                        <option value="2">2</option>
                                        <option value="4">4</option>
                                        <option value="5">5</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Carroceria</label>
                                    <select class="form-select" name="carroceria">
                                        <option>Hatch</option>
                                        <option>Sedan</option>
                                        <option>SUV</option>
                                        <option>Pickup</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Combustível</label>
                                    <select class="form-select" name="combustivel">
                                        <option>Gasolina</option>
                                        <option>Etanol</option>
                                        <option>Flex</option>
                                        <option>Diesel</option>
                                        <option>Elétrico</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Tração</label>
                                    <select class="form-select" name="tracao">
                                        <option>Dianteira</option>
                                        <option>Traseira</option>
                                        <option>4x4</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Cor</label>
                                    <select class="form-select" name="cor">
                                        <option>Branco</option>
                                        <option>Preto</option>
                                        <option>Prata</option>
                                        <option>Cinza</option>
                                    </select>
                                </div>

                                <div class="col-12">
                                    <label class="form-label fw-bold">Acessórios</label>
                                    <div class="row">
                                        <div class="col-md-3">
                                            <input type="checkbox" data-admin-acessorio="Ar-condicionado">
                                            Ar-condicionado
                                        </div>
                                        <div class="col-md-3">
                                            <input type="checkbox" data-admin-acessorio="Direção elétrica">
                                            Direção elétrica
                                        </div>
                                        <div class="col-md-3">
                                            <input type="checkbox" data-admin-acessorio="Airbag"> Airbag
                                        </div>
                                        <div class="col-md-3">
                                            <input type="checkbox" data-admin-acessorio="ABS"> ABS
                                        </div>
                                        <div class="col-md-3">
                                            <input type="checkbox" data-admin-acessorio="Multimídia"> Multimídia
                                        </div>
                                        <div class="col-md-3">
                                            <input type="checkbox" data-admin-acessorio="Câmera de ré"> Câmera de ré
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <label class="form-label">Imagens</label>
                                    <input type="file" class="form-control" name="imagens" multiple>
                                </div>

                                <div class="col-12">
                                    <div id="previewImagensEdicaoAdmin" class="d-flex flex-wrap gap-3"></div>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Preço</label>
                                    <input type="number" class="form-control" name="preco" required>
                                </div>

                                <div class="col-12">
                                    <label class="form-label">Descrição</label>
                                    <textarea class="form-control" name="descricao" rows="4" required></textarea>
                                </div>

                                <div class="col-12">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch"
                                            id="adminDestaque" name="destaque" value="1">
                                        <label class="form-check-label" for="adminDestaque">
                                            Marcar como destaque
                                        </label>
                                    </div>
                                </div>

                                <div class="col-12 d-flex gap-2">
                                    <button type="submit" class="btn btn-primary px-5">
                                        Salvar alterações
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary px-5"
                                        id="btnCancelarEdicaoAdminRodape">
                                        Cancelar
                                    </button>
                                </div>
                            </div>
                        </form>
                    </section>

                    <div class="container my-4">

                        <!-- 🔹 TOPO: GALERIA + INFO PRINCIPAL -->
                        <div class="row g-4">

                            <style>
                                .galeria-container {
                                    position: relative;
                                    top: -15px;
                                }

                                .galeria {
                                    overflow: hidden;
                                }

                                .galeria-track {
                                    display: flex;
                                    gap: 20px;
                                    transition: transform .4s ease;
                                }

                                /* 3 imagens visíveis */

                                .galeria-track img {
                                    min-width: calc(33.333% - 14px);
                                    height: 320px;
                                    object-fit: cover;
                                }

                                /* BOTÕES */

                                .btn-galeria {
                                    position: absolute;
                                    top: 50%;
                                    transform: translateY(-50%);
                                    background: rgba(0, 0, 0, 0.171);
                                    color: rgb(255, 255, 255);
                                    border: none;
                                    width: 45px;
                                    height: 45px;
                                    border-radius: 20px;
                                    font-size: 22px;
                                    cursor: pointer;
                                    z-index: 5;
                                }

                                .btn-prev {
                                    left: -15px;
                                }

                                .btn-next {
                                    right: -15px;
                                }

                                /* MOBILE */

                                @media(max-width:768px) {

                                    .galeria-track img {
                                        min-width: 100%;
                                    }

                                }
                            </style>

                            <!-- GALERIA -->
                            <div class="container my-4">

                                <div class="galeria-container">

                                    <button class="btn-galeria btn-prev" onclick="moverGaleria(-1)">❮</button>
                                    <button class="btn-galeria btn-next" onclick="moverGaleria(1)">❯</button>

                                    <div class="galeria">
                                        <div id="miniaturas" class="galeria-track"></div>
                                    </div>

                                </div>

                            </div>

                        </div>

                        <div class="container my-5" style="margin-top: -50px !important;">

                            <div class="row g-4">

                                <!-- COLUNA ESQUERDA (no mobile fica depois) -->
                                <div class="col-lg-7 order-2 order-lg-1">

                                    <!-- RESUMO DO VEÍCULO -->
                                    <div class="card shadow-sm mb-4">
                                        <div class="card-body">
                                            <h5 class="fw-bold mb-3">Resumo do veículo</h5>

                                            <div class="row small g-3">
                                                <div class="col-md-4"><strong>Ano Fabricação:</strong> <span
                                                        id="anoFabricacao"></span>
                                                </div>
                                                <div class="col-md-4"><strong>Ano Modelo:</strong> <span
                                                        id="anoModelo"></span></div>
                                                <div class="col-md-4"><strong>KM:</strong> <span id="km"></span></div>
                                                <div class="col-md-4"><strong>Condição:</strong> <span
                                                        id="condicao"></span></div>
                                                <div class="col-md-4"><strong>Câmbio:</strong> <span id="cambio"></span>
                                                </div>
                                                <div class="col-md-4"><strong>Combustível:</strong> <span
                                                        id="combustivel"></span></div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- FICHA TÉCNICA -->
                                    <div class="card shadow-sm">
                                        <div class="card-body">

                                            <h5 class="fw-bold mb-3">Ficha Técnica</h5>

                                            <div class="row small g-3">
                                                <div class="col-md-3">
                                                    <strong>Motorização</strong>
                                                    <div id="motorizacao"></div>
                                                </div>

                                                <div class="col-md-3">
                                                    <strong>Portas</strong>
                                                    <div id="portas"></div>
                                                </div>

                                                <div class="col-md-3">
                                                    <strong>Carroceria</strong>
                                                    <div id="carroceria"></div>
                                                </div>

                                                <div class="col-md-3">
                                                    <strong>Tração</strong>
                                                    <div id="tracao"></div>
                                                </div>

                                                <div class="col-md-3">
                                                    <strong>Cor</strong>
                                                    <div id="cor"></div>
                                                </div>

                                                <div class="col-md-3">
                                                    <strong>Tipo</strong>
                                                    <div id="tipo"></div>
                                                </div>
                                            </div>

                                        </div>
                                    </div>

                                    <!-- ACESSÓRIOS -->
                                    <div class="card mt-4 shadow-sm">
                                        <div class="card-body">
                                            <h5 class="fw-bold mb-3">Acessórios</h5>
                                            <div id="acessorios" class="d-flex flex-wrap gap-2"></div>
                                        </div>
                                    </div>

                                    <!-- DESCRIÇÃO -->
                                    <div class="card mt-4 shadow-sm">
                                        <div class="card-body">
                                            <h5 class="fw-bold mb-3">Descrição</h5>
                                            <p id="descricao" class="mb-0"></p>
                                        </div>
                                    </div>

                                </div>


                                <!-- COLUNA DIREITA -->
                                <div class="col-lg-5 order-1 order-lg-2">

                                    <div class="info-lateral">

                                        <h2 id="tituloVeiculo" class="fw-bold"></h2>

                                        <h3 id="preco" class="text-danger fw-bold my-3"></h3>

                                        <p class="text-muted mb-2">
                                            <i class="bi bi-geo-alt-fill text-danger"></i>
                                            <span id="localizacao"></span>
                                        </p>

                                        <a id="btnWhatsapp" target="_blank" class="btn btn-success btn-lg w-100 mb-3">
                                            <i class="bi bi-whatsapp"></i> Entrar em contato
                                        </a>

                                        <a id="verRevenda" class="btn btn-success btn-lg w-100 mb-3"
                                            style="background-color: red; border: none; ">
                                            <i class="bi bi-buildings"></i> Ver Revenda
                                        </a>

                                    </div>

                                    <!-- ANUNCIANTE -->
                                    <div class="card mt-4 shadow-sm">
                                        <div class="card-body">
                                            <h5 class="fw-bold mb-3">Sobre o anunciante</h5>

                                            <div class="row g-3 small">
                                                <div class="col-md-6">
                                                    <strong>Nome</strong>
                                                    <div id="nomeAnunciante"></div>
                                                </div>

                                                <div class="col-md-6">
                                                    <strong>Tipo</strong>
                                                    <div id="tipoAnunciante"></div>
                                                </div>

                                                <div class="col-md-6">
                                                    <strong>Email</strong>
                                                    <div id="emailAnunciante"></div>
                                                </div>

                                                <div class="col-md-6">
                                                    <strong>Telefone</strong>
                                                    <div id="telefoneAnunciante"></div>
                                                </div>
                                            </div>

                                        </div>
                                    </div>


                                    <div class="venda-seguranca d-none d-lg-block">
                                        <div class="venda-seguranca__titulo">
                                            🔒 Recomendações de Segurança
                                        </div>
                                        <ul class="venda-seguranca__lista">
                                            <li><span><strong>Evite adiantamentos:</strong> Nunca pague valores de
                                                    "sinal", reserva ou transporte antes de ver o veículo
                                                    pessoalmente.</span></li>
                                            <li><span><strong>Faça Vistoria Cautelar:</strong> Contrate uma empresa
                                                    especializada para verificar o histórico estrutural e de sinistros
                                                    do automóvel antes de fechar o negócio.</span></li>
                                            <li><span><strong>Marque em locais públicos:</strong> Se for ver o carro ou
                                                    mostrá-lo a um comprador, escolha locais movimentados e seguros,
                                                    como estacionamentos de shoppings ou em frente a esquadras.</span>
                                            </li>
                                            <li><span><strong>Valide a documentação:</strong> Verifique se o veículo
                                                    possui multas, restrições financeiras (alienação fiduciária) ou
                                                    pendências administrativas antes de realizar a transferência de
                                                    valores.</span></li>
                                        </ul>
                                    </div>

                                </div>

                            </div>

                        </div>
                    </div>

                    <div class="venda-seguranca venda-seguranca--mobile d-lg-none">
                        <div class="venda-seguranca__titulo">
                            🔒 Recomendações de Segurança
                        </div>
                        <ul class="venda-seguranca__lista">
                            <li><span><strong>Evite adiantamentos:</strong> Nunca pague valores de "sinal", reserva ou
                                    transporte antes de ver o veículo pessoalmente.</span></li>
                            <li><span><strong>Faça Vistoria Cautelar:</strong> Contrate uma empresa especializada para
                                    verificar o histórico estrutural e de sinistros do automóvel antes de fechar o
                                    negócio.</span></li>
                            <li><span><strong>Marque em locais públicos:</strong> Se for ver o carro ou mostrá-lo a um
                                    comprador, escolha locais movimentados e seguros, como estacionamentos de shoppings
                                    ou em frente a esquadras.</span></li>
                            <li><span><strong>Valide a documentação:</strong> Verifique se o veículo possui multas,
                                    restrições financeiras (alienação fiduciária) ou pendências administrativas antes de
                                    realizar a transferência de valores.</span></li>
                        </ul>
                    </div>

                    <script>
                        window.TEMCAR_ANUNCIO_ID = <%- JSON.stringify(typeof anuncioId !== 'undefined' ? anuncioId : null) %>;
                    </script>
                    <script src="/js/renderizar-pagina-de-venda.js?v=6"></script>
                    <script src="/js/pagina-de-venda/aprovar-recusar-anuncio.js"></script>
                    <script src="/js/pagina-de-venda/editar-anuncio-admin.js"></script>

                    <%- include('./reutilizavel/footer-public') %>

</body>

</html>
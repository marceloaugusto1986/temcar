                display: flex;
                align-items: center;
                cursor: pointer;
                padding: 15px;
                background: #eee;
                font-weight: bold;
              }

              .icon {
                color: red;
                margin-right: 10px;
                font-size: 18px;
              }

              .title {
                flex: 1;
              }

              .arrow {
                transition: transform 0.3s ease;
              }

              /* seta girando */
              .accordion-item.active .arrow {
                transform: rotate(90deg);
              }

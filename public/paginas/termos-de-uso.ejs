              </div>

              <div class="accordion-item">
                <div class="accordion-header">
                  <span class="icon">+</span>
                  <span class="title">12. Última Atualização</span>
                  <span class="arrow">▶</span>
                </div>
                <div class="accordion-content">
                  A presente versão desta Política de Privacidade foi atualizada em 27 de junho de 2025.
                </div>
              </div>

            </div>

            <script>
              const items = document.querySelectorAll(".accordion-item");

              items.forEach(item => {
                const header = item.querySelector(".accordion-header");
                const icon = item.querySelector(".icon");

                header.addEventListener("click", () => {

                  const isActive = item.classList.contains("active");

                  // fecha todos
                  items.forEach(i => {
                    i.classList.remove("active");
                    i.querySelector(".icon").textContent = "+";
                  });

                  // abre o clicado
                  if (!isActive) {
                    item.classList.add("active");
                    icon.textContent = "-";
                  }
                });
              });
            </script>
          </div>

          <!-- COLUNA DIREITA -->
          <div class="image">
            <img src="./../icones/img-termos-de-uso.jpeg" style="max-width: 400px;" alt="Imagem exemplo">
          </div>

        </section>

      </div>

      <script>
        const headers = document.querySelectorAll(".accordion-header");

        headers.forEach(header => {
          header.addEventListener("click", () => {
            const content = header.nextElementSibling;

            content.style.display =
              content.style.display === "block" ? "none" : "block";
          });
        });
      </script>
    </main>

    <script>
      async function carregarTermosUso() {
        try {
          const res = await fetch('/api/admin/termos-uso');
          const blocos = await res.json();

          const container = document.getElementById('termosUsoContainer');

          if (!blocos.length) {
            container.innerHTML = '<p class="text-muted">Conteúdo em breve.</p>';
            return;
          }

          container.innerHTML = blocos.map(b => `
      <div class="mb-5">
        ${b.titulo ? `<h2>${b.titulo}</h2>` : ''}
        ${b.subtitulo ? `<h5 class="text-muted">${b.subtitulo}</h5>` : ''}
        <p>${formatarTexto(b.texto)}</p>
      </div>
    `).join('');

        } catch (erro) {
          console.error(erro);
          termosUsoContainer.innerHTML = '<p class="text-danger">Erro ao carregar conteúdo.</p>';
        }
      }

      function formatarTexto(texto) {
        return texto ? texto.replace(/\n/g, '<br>') : '';
      }

      carregarTermosUso();
    </script>
    <%- include('./reutilizavel/footer-public') %>
</body>

</html>
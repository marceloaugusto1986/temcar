<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('reutilizavel/seo-head', { seo: typeof seo !== 'undefined' ? seo : {} }) %>
    <%- include('reutilizavel/jsonld-breadcrumb', { breadcrumbs: typeof breadcrumbs !== 'undefined' ? breadcrumbs : [] }) %>
    <script src="/js/site-config.js" defer></script>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<style>
    .vender-banner {
        background: linear-gradient(135deg, #C90B0C 0%, #8B0000 100%);
        padding: 60px 0;
    }

    .passo-card {
        border-left: 4px solid #C90B0C;
    }

    .btn-vender {
        background-color: #C90B0C;
        border-color: #C90B0C;
        color: #fff;
        font-size: 1.2rem;
        padding: 12px 40px;
    }

    .btn-vender:hover {
        background-color: #a00909;
        border-color: #a00909;
        color: #fff;
    }
</style>

<body>
    <%- include('./reutilizavel/header-public') %>

    <% if (typeof seo !== 'undefined' && seo.texto_h1) { %>
    <h1 class="visually-hidden"><%= seo.texto_h1 %></h1>
    <% } else { %>
    <h1 class="visually-hidden">Vender Veículo - TemCar</h1>
    <% } %>

    <!-- Banner -->
    <section class="vender-banner text-white text-center">
        <div class="container">
            <h2 class="fw-bold mb-3">Venda seu Veículo no Temcar</h2>
            <p class="mb-4 fs-5">Anuncie grátis e alcance milhares de compradores em todo o Brasil</p>
            <a href="/anunciar" class="btn btn-vender fw-bold">Anunciar Agora</a>
        </div>
    </section>

    <!-- Como funciona -->
    <section class="container my-5">
        <h3 class="fw-bold text-center mb-4">Como funciona?</h3>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card passo-card p-4 h-100">
                    <div class="text-center mb-3">
                        <i class="bi bi-person-plus-fill" style="font-size:2.5rem;color:#C90B0C;"></i>
                    </div>
                    <h5 class="fw-bold text-center">1. Cadastre-se</h5>
                    <p class="text-muted text-center">Crie sua conta como particular ou revenda em poucos minutos.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card passo-card p-4 h-100">
                    <div class="text-center mb-3">
                        <i class="bi bi-camera-fill" style="font-size:2.5rem;color:#C90B0C;"></i>
                    </div>
                    <h5 class="fw-bold text-center">2. Crie o Anúncio</h5>
                    <p class="text-muted text-center">Adicione fotos, descrição e detalhes do seu veículo.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card passo-card p-4 h-100">
                    <div class="text-center mb-3">
                        <i class="bi bi-cash-coin" style="font-size:2.5rem;color:#C90B0C;"></i>
                    </div>
                    <h5 class="fw-bold text-center">3. Venda!</h5>
                    <p class="text-muted text-center">Receba contatos de compradores interessados e feche o negócio.</p>
                </div>
            </div>
        </div>

        <!-- CTAs -->
        <div class="text-center mt-5">
            <h4 class="fw-bold mb-4">Escolha o tipo de conta</h4>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a href="/cadastro-particular" class="btn btn-outline-danger btn-lg px-5">
                    <i class="bi bi-person-fill me-2"></i>Particular
                </a>
                <a href="/cadastro-revenda" class="btn btn-danger btn-lg px-5">
                    <i class="bi bi-building me-2"></i>Revenda
                </a>
            </div>
        </div>
    </section>

    <%- include('./reutilizavel/footer-public') %>
</body>

</html>

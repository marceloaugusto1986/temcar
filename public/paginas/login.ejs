<!DOCTYPE html>
<html lang="pt-br">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<%- include('reutilizavel/seo-head', { seo: typeof seo !== 'undefined' ? seo : {} }) %>
  <script src="/js/site-config.js" defer></script>
	<!-- Bootstrap 5 -->
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<style>
	body {
		background: linear-gradient(135deg, #ffffff, #f8f8f8);
	}

	.login-card {
		border-radius: 16px;
	}

	.form-control {
		border-radius: 10px;
		padding: 12px;
	}

	.form-control:focus {
		border-color: #dc3545;
		box-shadow: 0 0 0 0.15rem rgba(220, 53, 69, 0.25);
	}

	.btn-danger {
		border-radius: 12px;
		font-weight: 600;
	}

	.btn-outline-danger {
		border-radius: 12px;
		font-weight: 500;
	}
</style>

<body>
	<%- include('./reutilizavel/header-public') %>

	<div class="container d-flex align-items-center justify-content-center min-vh-100">
		<div class="col-11 col-sm-9 col-md-6 col-lg-4">

			<div class="card shadow-lg border-0 login-card">
				<div class="card-body p-4">

					<!-- TÍTULO -->
					<div class="text-center mb-4">
						<h3 class="fw-bold text-danger">TEMCAR</h3>
						<p class="text-muted small">Acesse sua conta</p>
					</div>

					<!-- FORM -->
					<form id="formLogin">

						<!-- EMAIL -->
						<div class="mb-3">
							<label for="userEmailLogin" class="form-label">E-mail</label>
							<input type="email" class="form-control" id="userEmailLogin" name="userEmailLogin"
								placeholder="seu@email.com" required>
						</div>

						<!-- SENHA -->
						<div class="mb-2">
							<label for="senhaLogin" class="form-label">Senha</label>
							<input type="password" class="form-control" id="senhaLogin" name="senhaLogin"
								placeholder="••••••••" required>
						</div>

						<!-- ESQUECI A SENHA -->
						<div class="text-end mb-3">
							<a id="esqueciMinhaSenha" class="link-danger small text-decoration-none" style="cursor: pointer;">
								Esqueci minha senha
							</a>
						</div>

						<!-- BOTÃO LOGIN -->
						<button type="submit" class="btn btn-danger w-100 btn-lg">
							Entrar
						</button>

					</form>

					<script>
document.getElementById("esqueciMinhaSenha").addEventListener("click", function () {

    const email = document.getElementById("userEmailLogin").value.trim()

    if (!email) {
        alert("Por favor, informe seu e-mail para identificação.")
        document.getElementById("userEmailLogin").focus()
        return
    }

    const mensagem = `Olá, vim do site www.temcar.com.br e esqueci minha senha.
Meu e-mail cadastrado é: ${email}`

    const mensagemCodificada = encodeURIComponent(mensagem)

    const telefone = "5521995301954"

    const url = `https://wa.me/${telefone}?text=${mensagemCodificada}`

    window.open(url, "_blank")
})
</script>

					<!-- DIVISOR -->
					<div class="text-center my-3 text-muted small">
						ou
					</div>

					<!-- CRIAR CONTA -->
					<div class="text-center">
						<a href="/criar-conta" class="btn btn-outline-danger w-100">
							Criar conta
						</a>
					</div>

				</div>
			</div>

		</div>
	</div>

	<%- include('./reutilizavel/footer-public') %>

	<script src="/js/login.js"></script>
</body>

</html>